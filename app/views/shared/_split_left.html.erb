<%# Card left panel — shared by editor (surveys/show), preview
    (surveys/_preview_card), and player (player/_play_card).

    Locals:
      card     — the card hash
      progress — integer 0–100
      mode     — :editor, :preview, or :player (default: :preview)
%>
<%
  mode    ||= :preview
  editable = (mode == :editor)
  has_img  = card["image"].present?
%>

<div class="split-left">
  <% if nps_card?(card) %>
    <%# NPS: the LEFT panel plays a Lottie animation that swaps to match the
        slider value (1–5). The lottie-player controller listens for the
        `nps:valueChanged` event dispatched by the slider on the right. %>
    <%= render_nps_reaction(initial_value: 1) %>
  <% elsif has_img %>
    <div class="split-left-img"<%= " data-card-media".html_safe if editable %>
         style="background-image:url('<%= card["image"] %>');"></div>
    <div class="split-left-overlay"<%= " data-card-media".html_safe if editable %>></div>
  <% end %>

  <div class="panel-progress">
    <div class="panel-progress-fill" style="width:<%= progress %>%;"></div>
  </div>

  <%# Editor: prompt the creator to add design (an image). The button stays in
      the DOM for every editor-mode card — including NPS — so type-switching
      in the editor (e.g. range → NPS → range) finds it ready to reappear.
      CSS hides it while a Lottie is mounted (.split-left:has(.nps-lottie) …). %>
  <% if editable %>
    <% if has_img %>
      <button type="button" class="add-media-fab"
              data-action="click->media-picker#open"
              title="<%= t("editor.change_media_title") %>">
        <span class="add-media-fab-plus">＋</span>
        <span><%= t("editor.change_media") %></span>
      </button>
    <% else %>
      <button type="button" class="split-left-design-prompt"
              data-action="click->media-picker#open"
              title="<%= t("editor.add_design_title") %>">
        <span class="split-left-design-prompt-icon">＋</span>
        <span class="split-left-design-prompt-title"><%= t("editor.add_design") %></span>
        <span class="split-left-design-prompt-sub"><%= t("editor.add_design_sub") %></span>
      </button>
    <% end %>
  <% end %>
</div>
