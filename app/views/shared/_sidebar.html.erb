<%#
  Locals:
    active  String — "dashboard" | "create" | "results"
    survey  Survey — optional; when present, adds a "Results" nav item
%>
<% active_key = local_assigns[:active].to_s
   ctx_survey  = local_assigns[:survey] %>

<aside style="width:220px;min-height:100vh;background:#161B2E;border-right:1px solid rgba(255,255,255,0.06);display:flex;flex-direction:column;flex-shrink:0;position:sticky;top:0;height:100vh;overflow:hidden;">

  <%# Logo %>
  <div style="padding:22px 20px 16px;">
    <%= link_to root_path do %>
      <%= image_tag "playverto.svg", style:"height:20px;width:auto;", alt:"Playverto" %>
    <% end %>
  </div>

  <div style="height:1px;background:rgba(255,255,255,0.07);margin:0 16px 10px;"></div>

  <%# Primary nav %>
  <nav style="padding:0 10px;display:flex;flex-direction:column;gap:2px;">

    <%# Dashboard %>
    <% is_db = active_key == "dashboard" %>
    <a href="<%= root_path %>"
       style="display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:10px;border-left:2px solid <%= is_db ? '#00A950' : 'transparent' %>;background:<%= is_db ? 'rgba(0,169,80,0.12)' : 'transparent' %>;color:<%= is_db ? '#fff' : 'rgba(255,255,255,0.45)' %>;font-family:'ABeeZee',sans-serif;font-size:13px;text-decoration:none;transition:background 0.15s,color 0.15s;"
       onmouseover="if(this.style.borderLeftColor!=='rgb(0, 169, 80)'){this.style.background='rgba(255,255,255,0.05)';this.style.color='rgba(255,255,255,0.8)'}"
       onmouseout="if(this.style.borderLeftColor!=='rgb(0, 169, 80)'){this.style.background='transparent';this.style.color='rgba(255,255,255,0.45)'}">
      <svg width="15" height="15" viewBox="0 0 15 15" fill="none" style="flex-shrink:0;opacity:0.8;">
        <rect x="1" y="1" width="5.5" height="5.5" rx="1.3" fill="currentColor"/>
        <rect x="8.5" y="1" width="5.5" height="5.5" rx="1.3" fill="currentColor"/>
        <rect x="1" y="8.5" width="5.5" height="5.5" rx="1.3" fill="currentColor"/>
        <rect x="8.5" y="8.5" width="5.5" height="5.5" rx="1.3" fill="currentColor"/>
      </svg>
      Dashboard
    </a>

    <%# Create Verto %>
    <% is_create = active_key == "create" %>
    <a href="<%= new_survey_path %>"
       style="display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:10px;border-left:2px solid <%= is_create ? '#00A950' : 'transparent' %>;background:<%= is_create ? 'rgba(0,169,80,0.12)' : 'transparent' %>;color:<%= is_create ? '#fff' : 'rgba(255,255,255,0.45)' %>;font-family:'ABeeZee',sans-serif;font-size:13px;text-decoration:none;transition:background 0.15s,color 0.15s;"
       onmouseover="if(this.style.borderLeftColor!=='rgb(0, 169, 80)'){this.style.background='rgba(255,255,255,0.05)';this.style.color='rgba(255,255,255,0.8)'}"
       onmouseout="if(this.style.borderLeftColor!=='rgb(0, 169, 80)'){this.style.background='transparent';this.style.color='rgba(255,255,255,0.45)'}">
      <svg width="15" height="15" viewBox="0 0 15 15" fill="none" style="flex-shrink:0;opacity:0.8;">
        <circle cx="7.5" cy="7.5" r="6.5" stroke="currentColor" stroke-width="1.4"/>
        <path d="M7.5 4.5v6M4.5 7.5h6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      </svg>
      Create Verto
    </a>

    <%# Results — only shown when a survey context is provided %>
    <% if ctx_survey %>
      <% is_results = active_key == "results" %>
      <div style="height:1px;background:rgba(255,255,255,0.06);margin:8px 2px;"></div>
      <a href="<%= survey_results_path(ctx_survey) %>"
         style="display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:10px;border-left:2px solid <%= is_results ? '#00A950' : 'transparent' %>;background:<%= is_results ? 'rgba(0,169,80,0.12)' : 'transparent' %>;color:<%= is_results ? '#fff' : 'rgba(255,255,255,0.45)' %>;font-family:'ABeeZee',sans-serif;font-size:13px;text-decoration:none;transition:background 0.15s,color 0.15s;"
         onmouseover="if(this.style.borderLeftColor!=='rgb(0, 169, 80)'){this.style.background='rgba(255,255,255,0.05)';this.style.color='rgba(255,255,255,0.8)'}"
         onmouseout="if(this.style.borderLeftColor!=='rgb(0, 169, 80)'){this.style.background='transparent';this.style.color='rgba(255,255,255,0.45)'}">
        <svg width="15" height="15" viewBox="0 0 15 15" fill="none" style="flex-shrink:0;opacity:0.8;">
          <rect x="1" y="9" width="3" height="5" rx="0.8" fill="currentColor"/>
          <rect x="6" y="6" width="3" height="8" rx="0.8" fill="currentColor"/>
          <rect x="11" y="3" width="3" height="11" rx="0.8" fill="currentColor"/>
        </svg>
        Results
      </a>
    <% end %>

  </nav>

  <%# Spacer %>
  <div style="flex:1;"></div>

</aside>
