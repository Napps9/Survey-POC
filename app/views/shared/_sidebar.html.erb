<%#
  Locals:
    active  String — "dashboard" | "create" | "results"
    survey  Survey — optional; when present, adds a "Results" nav item
%>
<% active_key = local_assigns[:active].to_s
   ctx_survey  = local_assigns[:survey] %>

<aside style="width:220px;min-height:100vh;background:#161B2E;border-right:1px solid rgba(255,255,255,0.06);display:flex;flex-direction:column;flex-shrink:0;position:sticky;top:0;height:100vh;overflow:hidden;">

  <%# Logo %>
  <div style="padding:22px 20px 16px;">
    <%= link_to root_path do %>
      <%= image_tag "playverto.svg", style:"height:20px;width:auto;", alt:"Playverto" %>
    <% end %>
  </div>

  <div style="height:1px;background:rgba(255,255,255,0.07);margin:0 16px 10px;"></div>

  <%# Primary nav %>
  <nav style="padding:0 10px;display:flex;flex-direction:column;gap:2px;">

    <%# Dashboard %>
    <% is_db = active_key == "dashboard" %>
    <a href="<%= root_path %>"
       style="display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:10px;border-left:2px solid <%= is_db ? '#01EACB' : 'transparent' %>;background:<%= is_db ? 'rgba(1,234,203,0.12)' : 'transparent' %>;color:<%= is_db ? '#fff' : 'rgba(255,255,255,0.45)' %>;font-family:'ABeeZee',sans-serif;font-size:13px;text-decoration:none;transition:background 0.15s,color 0.15s;"
       onmouseover="if(this.style.borderLeftColor!=='rgb(0, 169, 80)'){this.style.background='rgba(255,255,255,0.05)';this.style.color='rgba(255,255,255,0.8)'}"
       onmouseout="if(this.style.borderLeftColor!=='rgb(0, 169, 80)'){this.style.background='transparent';this.style.color='rgba(255,255,255,0.45)'}">
      <svg width="15" height="15" viewBox="0 0 15 15" fill="none" style="flex-shrink:0;opacity:0.8;">
        <rect x="1" y="1" width="5.5" height="5.5" rx="1.3" fill="currentColor"/>
        <rect x="8.5" y="1" width="5.5" height="5.5" rx="1.3" fill="currentColor"/>
        <rect x="1" y="8.5" width="5.5" height="5.5" rx="1.3" fill="currentColor"/>
        <rect x="8.5" y="8.5" width="5.5" height="5.5" rx="1.3" fill="currentColor"/>
      </svg>
      Dashboard
    </a>

    <%# Create Verto %>
    <% is_create = active_key == "create" %>
    <a href="<%= new_survey_path %>"
       style="display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:10px;border-left:2px solid <%= is_create ? '#01EACB' : 'transparent' %>;background:<%= is_create ? 'rgba(1,234,203,0.12)' : 'transparent' %>;color:<%= is_create ? '#fff' : 'rgba(255,255,255,0.45)' %>;font-family:'ABeeZee',sans-serif;font-size:13px;text-decoration:none;transition:background 0.15s,color 0.15s;"
       onmouseover="if(this.style.borderLeftColor!=='rgb(0, 169, 80)'){this.style.background='rgba(255,255,255,0.05)';this.style.color='rgba(255,255,255,0.8)'}"
       onmouseout="if(this.style.borderLeftColor!=='rgb(0, 169, 80)'){this.style.background='transparent';this.style.color='rgba(255,255,255,0.45)'}">
      <svg width="15" height="15" viewBox="0 0 15 15" fill="none" style="flex-shrink:0;opacity:0.8;">
        <circle cx="7.5" cy="7.5" r="6.5" stroke="currentColor" stroke-width="1.4"/>
        <path d="M7.5 4.5v6M4.5 7.5h6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      </svg>
      Create Verto
    </a>

    <%# Results — only shown when a survey context is provided %>
    <% if ctx_survey %>
      <% is_results = active_key == "results" %>
      <div style="height:1px;background:rgba(255,255,255,0.06);margin:8px 2px;"></div>
      <a href="<%= survey_results_path(ctx_survey) %>"
         style="display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:10px;border-left:2px solid <%= is_results ? '#01EACB' : 'transparent' %>;background:<%= is_results ? 'rgba(1,234,203,0.12)' : 'transparent' %>;color:<%= is_results ? '#fff' : 'rgba(255,255,255,0.45)' %>;font-family:'ABeeZee',sans-serif;font-size:13px;text-decoration:none;transition:background 0.15s,color 0.15s;"
         onmouseover="if(this.style.borderLeftColor!=='rgb(0, 169, 80)'){this.style.background='rgba(255,255,255,0.05)';this.style.color='rgba(255,255,255,0.8)'}"
         onmouseout="if(this.style.borderLeftColor!=='rgb(0, 169, 80)'){this.style.background='transparent';this.style.color='rgba(255,255,255,0.45)'}">
        <svg width="15" height="15" viewBox="0 0 15 15" fill="none" style="flex-shrink:0;opacity:0.8;">
          <rect x="1" y="9" width="3" height="5" rx="0.8" fill="currentColor"/>
          <rect x="6" y="6" width="3" height="8" rx="0.8" fill="currentColor"/>
          <rect x="11" y="3" width="3" height="11" rx="0.8" fill="currentColor"/>
        </svg>
        Results
      </a>
    <% end %>

  </nav>

  <%# Spacer %>
  <div style="flex:1;"></div>

  <%# Admin: Members link %>
  <% if current_membership&.admin? %>
    <div style="padding:0 10px 4px;">
      <a href="<%= organisation_memberships_path(current_organisation) %>"
         style="display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:10px;color:rgba(255,255,255,0.35);font-family:'ABeeZee',sans-serif;font-size:12px;text-decoration:none;transition:color 0.15s;"
         onmouseover="this.style.color='rgba(255,255,255,0.7)'"
         onmouseout="this.style.color='rgba(255,255,255,0.35)'">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="flex-shrink:0;">
          <circle cx="7" cy="4.5" r="2.5" stroke="currentColor" stroke-width="1.3"/>
          <path d="M1.5 12c0-3 2.5-4.5 5.5-4.5s5.5 1.5 5.5 4.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
        </svg>
        Members
      </a>
    </div>
  <% end %>

  <%# Org + user footer %>
  <div style="height:1px;background:rgba(255,255,255,0.06);margin:0 14px 12px;"></div>
  <div style="padding:0 14px 18px;display:flex;flex-direction:column;gap:10px;">

    <%# Org switcher %>
    <% if defined?(current_organisation) && current_organisation %>
      <div style="font-family:'Alata',sans-serif;font-size:11px;letter-spacing:0.06em;color:rgba(255,255,255,0.35);text-transform:uppercase;padding:0 2px;"><%= current_organisation.name %></div>
      <% if Current.user.organisations.many? %>
        <% Current.user.organisations.each do |org| %>
          <% next if org == current_organisation %>
          <%= button_to org.name, switch_organisation_path, method: :post,
                params: { organisation_id: org.id },
                style: "display:block;width:100%;text-align:left;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:8px;padding:7px 10px;color:rgba(255,255,255,0.5);font-family:'ABeeZee',sans-serif;font-size:12px;cursor:pointer;" %>
        <% end %>
      <% end %>
    <% end %>

    <%# User + logout %>
    <% if defined?(Current) && Current.user %>
      <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;">
        <span style="font-family:'ABeeZee',sans-serif;font-size:12px;color:rgba(255,255,255,0.4);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= Current.user.name.presence || Current.user.email_address %></span>
        <%= button_to "Sign out", session_path, method: :delete,
              style: "flex-shrink:0;background:none;border:1px solid rgba(255,255,255,0.12);border-radius:6px;padding:4px 9px;color:rgba(255,255,255,0.35);font-family:'ABeeZee',sans-serif;font-size:11px;cursor:pointer;white-space:nowrap;" %>
      </div>
    <% end %>
  </div>

</aside>
