<!DOCTYPE html>
<html lang="<%= I18n.locale %>" dir="<%= SupportedLocales.dir(I18n.locale) %>">
  <head>
    <%= render "layouts/head" %>
  </head>
  <body style="height:100dvh;min-height:100vh;overflow:hidden;background:#272D4A;color:#F7F7F7;font-family:'ABeeZee',sans-serif;">
    <% if Current.user %>
      <div data-controller="command-palette">
        <%= render "shared/bottom_bar" %>
        <%= render "shared/command_palette" %>
      </div>
      <div style="position: fixed; top: 56px; left: 0; right: 0; bottom: 0; overflow: auto;">
        <%= yield %>
      </div>
    <% else %>
      <%# Unauthenticated chrome-less pages (login, register, password). The
          player has its own content-language switcher in its nav. %>
      <% unless controller_name == "player" %>
        <div class="lang-switcher-fixed"><%= render "shared/locale_switcher" %></div>
      <% end %>
      <%= yield %>
    <% end %>
  </body>
</html>
