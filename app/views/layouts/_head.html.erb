<title><%= content_for(:title) || "Playverto Verto Studio" %></title>
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="mobile-web-app-capable" content="yes">
<meta name="theme-color" content="#1C2034">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<%= csrf_meta_tags %>
<%= csp_meta_tag %>

<%# Microsoft Clarity analytics (production only) %>
<% if Rails.env.production? %>
  <script type="text/javascript">
    (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
    })(window, document, "clarity", "script", "wyq1mb82dv");
  </script>
<% end %>

<%= yield :head %>

<link rel="manifest" href="<%= pwa_manifest_path %>">
<%= favicon_link_tag "favicon.svg", type: "image/svg+xml" %>
<%= favicon_link_tag "favicon.svg", rel: "apple-touch-icon", type: "image/svg+xml" %>
<%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
<%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
<%= render "layouts/i18n_js" %>
<%= javascript_importmap_tags %>
