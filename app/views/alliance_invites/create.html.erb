<% content_for :title, "Partner invite — Playverto" %>
<div style="display:flex;min-height:100vh;background:#1C2034;">
  <%= render "shared/sidebar", active: "partners" %>

  <div style="flex:1;display:flex;flex-direction:column;align-items:flex-start;padding:60px 48px;overflow-y:auto;">
    <div style="width:100%;max-width:520px;">
      <div style="display:inline-flex;align-items:center;gap:8px;background:rgba(1,234,203,0.15);border:1px solid rgba(1,234,203,0.3);border-radius:20px;padding:6px 14px;margin-bottom:28px;">
        <span style="font-family:'Alata',sans-serif;font-size:12px;color:#01EACB;letter-spacing:0.06em;">Partner invite created</span>
      </div>
      <h1 style="font-family:'Alata',sans-serif;font-size:22px;color:#F7F7F7;margin:0 0 8px;">Share this link</h1>
      <p style="font-family:'ABeeZee',sans-serif;font-size:13px;color:rgba(255,255,255,0.4);margin:0 0 28px;line-height:1.6;">
        Send this link to <strong style="color:rgba(255,255,255,0.7);"><%= @invite.email_address %></strong>.
        They'll join as a partner organisation when they accept. The link expires in 14 days.
      </p>

      <% invite_url = invite_url(@invite.token) %>
      <div style="background:#161B2E;border:1px solid rgba(255,255,255,0.1);border-radius:10px;padding:16px 18px;display:flex;align-items:center;gap:12px;margin-bottom:32px;">
        <span style="flex:1;font-family:'ABeeZee',sans-serif;font-size:13px;color:rgba(255,255,255,0.6);word-break:break-all;line-height:1.5;"><%= invite_url %></span>
        <button type="button"
                onclick="navigator.clipboard.writeText('<%= invite_url %>').then(()=>{this.textContent='Copied!';this.style.color='#01EACB';setTimeout(()=>{this.textContent='Copy';this.style.color=''},2000)})"
                style="flex-shrink:0;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.12);border-radius:7px;padding:7px 14px;color:rgba(255,255,255,0.6);font-family:'Alata',sans-serif;font-size:12px;cursor:pointer;">Copy</button>
      </div>

      <%= link_to "Back to partners", alliances_path,
            style: "border:1px solid rgba(255,255,255,0.12);border-radius:8px;padding:11px 22px;color:rgba(255,255,255,0.45);font-family:'Alata',sans-serif;font-size:13px;text-decoration:none;" %>
    </div>
  </div>
</div>
