<% content_for :title, "Shared Vertos — Playverto" %>
<div style="display:flex;min-height:100vh;background:#1C2034;">
  <%= render "shared/sidebar", active: "alliance_vertos" %>

  <div style="flex:1;display:flex;flex-direction:column;padding:60px 48px;overflow-y:auto;">
    <div style="width:100%;max-width:840px;">

      <div style="margin-bottom:32px;">
        <h1 style="font-family:'Alata',sans-serif;font-size:22px;color:#F7F7F7;margin:0 0 6px;">Shared with you</h1>
        <p style="font-family:'ABeeZee',sans-serif;font-size:13px;color:rgba(255,255,255,0.4);margin:0;">
          Vertos partner organisations have shared with you. Each has your unique distribution link.
        </p>
      </div>

      <% if @shares.empty? %>
        <div style="border:1px dashed rgba(255,255,255,0.12);border-radius:12px;padding:48px 24px;text-align:center;color:rgba(255,255,255,0.45);font-family:'ABeeZee',sans-serif;font-size:14px;">
          No Vertos shared with you yet.
        </div>
      <% else %>
        <div style="display:flex;flex-direction:column;gap:12px;">
          <% @shares.each do |share| %>
            <% s = share.survey %>
            <%= link_to alliance_verto_path(share),
                  style: "display:block;background:#161B2E;border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:18px 20px;text-decoration:none;" do %>
              <div style="font-family:'ABeeZee',sans-serif;font-size:12px;color:rgba(255,255,255,0.4);margin-bottom:4px;">From <%= s.organisation.name %></div>
              <div style="font-family:'Alata',sans-serif;font-size:16px;color:#F7F7F7;"><%= s.title.presence || "Untitled Verto" %></div>
              <% if s.description.present? %>
                <div style="font-family:'ABeeZee',sans-serif;font-size:13px;color:rgba(255,255,255,0.5);margin-top:6px;"><%= s.description %></div>
              <% end %>
            <% end %>
          <% end %>
        </div>
      <% end %>

    </div>
  </div>
</div>
