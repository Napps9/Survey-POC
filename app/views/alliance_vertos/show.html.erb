<% content_for :title, "#{@survey.title} — Shared Verto" %>
<%
  cards = Array(@survey.cards)

  render_counts = ->(counts, total, accent) do
    return "" if counts.blank?
    rows = counts.map do |label, count|
      pct = total.to_i.positive? ? (count.to_f / total * 100).round : 0
      <<~HTML
        <div style="display:flex;align-items:center;gap:8px;font-family:'ABeeZee',sans-serif;font-size: var(--text-base);color:rgba(255,255,255,0.7);">
          <span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">#{ERB::Util.h(label)}</span>
          <div style="position:relative;flex-shrink:0;width:60px;height:5px;background:rgba(255,255,255,0.06);border-radius:3px;overflow:hidden;">
            <div style="position:absolute;inset:0 auto 0 0;width:#{pct}%;background:#{accent};"></div>
          </div>
          <span style="flex-shrink:0;min-width:40px;text-align:right;color:#{accent};font-variant-numeric:tabular-nums;">#{count} · #{pct}%</span>
        </div>
      HTML
    end
    rows.join.html_safe
  end

  render_section = ->(label, total, row, accent) do
    if row.nil? || total.to_i.zero?
      <<~HTML.html_safe
        <div>
          <div style="font-family:'Alata',sans-serif;font-size: var(--text-xs);letter-spacing:0.08em;color:rgba(255,255,255,0.35);text-transform:uppercase;margin-bottom:4px;">#{label}</div>
          <div style="font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.3);">No data</div>
        </div>
      HTML
    else
      body = if row[:counts]&.any?
        render_counts.call(row[:counts], row[:total], accent)
      elsif row[:texts]&.any?
        row[:texts].first(3).map { |t| %(<div style="font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.55);background:rgba(255,255,255,0.03);border-radius:5px;padding:5px 8px;line-height:1.35;">"#{ERB::Util.h(t)}"</div>) }.join.html_safe
      else
        ""
      end
      meta = "#{row[:total]} answered"
      meta += " · avg #{row[:avg]}" if row[:avg]
      <<~HTML.html_safe
        <div>
          <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:6px;">
            <div style="font-family:'Alata',sans-serif;font-size: var(--text-xs);letter-spacing:0.08em;color:#{accent};text-transform:uppercase;">#{label}</div>
            <div style="font-family:'ABeeZee',sans-serif;font-size: var(--text-xs);color:rgba(255,255,255,0.35);">#{meta}</div>
          </div>
          <div style="display:flex;flex-direction:column;gap:4px;">#{body}</div>
        </div>
      HTML
    end
  end

  render_comparison = ->(mine, agg) do
    return "" if mine.nil? || agg.nil?
    return "" if mine[:counts].blank? || agg[:counts].blank?
    labels = (mine[:counts].keys + agg[:counts].keys).uniq
    mine_total = mine[:total].to_i
    agg_total  = agg[:total].to_i
    rows = labels.map do |label|
      m_count = mine[:counts][label].to_i
      a_count = agg[:counts][label].to_i
      m_pct = mine_total.positive? ? (m_count.to_f / mine_total * 100).round : 0
      a_pct = agg_total.positive?  ? (a_count.to_f / agg_total  * 100).round : 0
      <<~HTML
        <div style="display:flex;align-items:center;gap:8px;font-family:'ABeeZee',sans-serif;font-size: var(--text-base);color:rgba(255,255,255,0.7);">
          <span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">#{ERB::Util.h(label)}</span>
          <span style="flex-shrink:0;color:#01EACB;font-variant-numeric:tabular-nums;width:42px;text-align:right;">#{m_pct}%</span>
          <span style="flex-shrink:0;color:rgba(255,255,255,0.3);">vs</span>
          <span style="flex-shrink:0;color:#FF1E6F;font-variant-numeric:tabular-nums;width:42px;text-align:right;">#{a_pct}%</span>
        </div>
      HTML
    end
    rows.join.html_safe
  end
%>
<div style="display:flex;height:100%;background:#1C2034;">
  <div style="flex:1;display:flex;flex-direction:column;overflow-y:auto;padding:40px 36px;">
    <div style="width:100%;max-width:1240px;margin:0 auto;">

      <div style="margin-bottom:20px;">
        <div style="font-family:'ABeeZee',sans-serif;font-size: var(--text-base);color:rgba(255,255,255,0.4);margin-bottom:4px;">From <%= @survey.organisation.name %></div>
        <h1 style="font-family:'Alata',sans-serif;font-size: var(--text-4xl);color:#F7F7F7;margin:0 0 6px;"><%= @survey.title %></h1>
        <% if @survey.description.present? %>
          <p style="font-family:'ABeeZee',sans-serif;font-size: var(--text-lg);color:rgba(255,255,255,0.5);margin:0;line-height:1.55;"><%= @survey.description %></p>
        <% end %>
      </div>

      <%# Share link %>
      <% url = play_survey_url(@share.share_token) %>
      <div style="background:#161B2E;border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:14px 16px;margin-bottom:18px;display:flex;align-items:center;gap:12px;">
        <div style="font-family:'Alata',sans-serif;font-size: var(--text-xs);letter-spacing:0.08em;color:rgba(255,255,255,0.4);text-transform:uppercase;flex-shrink:0;">Share link</div>
        <span style="flex:1;font-family:'ABeeZee',sans-serif;font-size: var(--text-base);color:rgba(255,255,255,0.6);word-break:break-all;"><%= url %></span>
        <button type="button"
                onclick="navigator.clipboard.writeText('<%= url %>').then(()=>{this.textContent='Copied!';this.style.color='#01EACB';setTimeout(()=>{this.textContent='Copy';this.style.color=''},1500)})"
                style="background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.12);border-radius:6px;padding:6px 12px;color:rgba(255,255,255,0.6);font-family:'Alata',sans-serif;font-size: var(--text-sm);cursor:pointer;flex-shrink:0;">Copy</button>
      </div>

      <%# Totals strip %>
      <div style="display:flex;gap:10px;margin-bottom:22px;font-family:'ABeeZee',sans-serif;font-size: var(--text-base);">
        <div style="background:rgba(1,234,203,0.08);border:1px solid rgba(1,234,203,0.25);border-radius:8px;padding:7px 12px;color:#01EACB;">
          <strong style="font-family:'Alata',sans-serif;"><%= @mine_total %></strong> from your link
        </div>
        <div style="background:rgba(255,30,111,0.08);border:1px solid rgba(255,30,111,0.25);border-radius:8px;padding:7px 12px;color:#FF1E6F;">
          <strong style="font-family:'Alata',sans-serif;"><%= @aggregate_total %></strong> across all partners
        </div>
      </div>

      <%# Card-by-card: Verto preview + side-by-side results %>
      <div style="display:flex;flex-direction:column;gap:20px;">
        <%
          total_q = cards.count { |c| c["type"] != "welcome_card" }
          q_idx = 0
        %>
        <% cards.each_with_index do |card, idx| %>
          <%
            is_q     = card["type"].to_s != "welcome_card"
            q_idx   += 1 if is_q
            progress = total_q > 0 ? ((q_idx.to_f / total_q) * 100).round : 5
            progress = 5 unless is_q
            mine_row = @mine_results[idx]
            agg_row  = @aggregate_results[idx]
          %>

          <div style="display:grid;grid-template-columns:minmax(0,1fr) 340px;gap:16px;align-items:start;">

            <%# Verto card preview %>
            <div style="background:#0F1326;border:1px solid rgba(255,255,255,0.06);border-radius:14px;padding:14px;">
              <div style="font-family:'Alata',sans-serif;font-size: var(--text-xs);letter-spacing:0.08em;color:rgba(255,255,255,0.35);text-transform:uppercase;margin-bottom:8px;">Card <%= idx + 1 %></div>
              <div style="zoom:0.72;">
                <%= render "surveys/preview_card", card: card, progress: progress %>
              </div>
            </div>

            <%# Results panel: Mine + Aggregate + Comparison %>
            <div style="background:#161B2E;border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:14px 16px;display:flex;flex-direction:column;gap:14px;align-self:start;">
              <%= render_section.call("My results", @mine_total, mine_row, "#01EACB") %>
              <div style="height:1px;background:rgba(255,255,255,0.06);"></div>
              <%= render_section.call("Aggregate", @aggregate_total, agg_row, "#FF1E6F") %>
              <%
                comp_html = render_comparison.call(mine_row, agg_row)
              %>
              <% if comp_html.present? %>
                <div style="height:1px;background:rgba(255,255,255,0.06);"></div>
                <div>
                  <div style="font-family:'Alata',sans-serif;font-size: var(--text-xs);letter-spacing:0.08em;color:rgba(255,255,255,0.6);text-transform:uppercase;margin-bottom:6px;">Comparison <span style="color:rgba(255,255,255,0.3);text-transform:none;letter-spacing:0;">· you vs all</span></div>
                  <div style="display:flex;flex-direction:column;gap:4px;"><%= comp_html %></div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

    </div>
  </div>
</div>
