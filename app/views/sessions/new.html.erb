<% content_for :title, "Sign In — Playverto" %>

<div style="min-height:100vh;background:#272D4A;display:flex;align-items:center;justify-content:center;padding:24px;">
  <div style="width:100%;max-width:400px;">
    <div style="text-align:center;margin-bottom:40px;">
      <%= image_tag "playverto.svg", style: "height:40px;margin:0 auto 16px;display:block;" rescue nil %>
      <h1 style="font-family:'Alata',sans-serif;font-size:24px;color:#F7F7F7;letter-spacing:0.05em;margin:0 0 6px;">Sign in to Playverto</h1>
      <p style="font-family:'ABeeZee',sans-serif;font-size:13px;color:rgba(255,255,255,0.35);margin:0;">New here? <%= link_to "Create an account", new_registration_path, style: "color:#01EACB;text-decoration:none;" %></p>
    </div>

    <% if alert = flash[:alert] %>
      <div style="background:rgba(216,0,39,0.15);border:1px solid rgba(216,0,39,0.4);border-radius:8px;padding:12px 16px;margin-bottom:20px;color:#ff6b6b;font-size:14px;font-family:'ABeeZee',sans-serif;">
        <%= alert %>
      </div>
    <% end %>

    <% if notice = flash[:notice] %>
      <div style="background:rgba(1,234,203,0.15);border:1px solid rgba(1,234,203,0.4);border-radius:8px;padding:12px 16px;margin-bottom:20px;color:#01EACB;font-size:14px;font-family:'ABeeZee',sans-serif;">
        <%= notice %>
      </div>
    <% end %>

    <%= form_with url: session_url do |form| %>
      <div style="margin-bottom:20px;">
        <label style="display:block;font-family:'Alata',sans-serif;font-size:12px;letter-spacing:0.08em;color:rgba(247,247,247,0.6);margin-bottom:8px;text-transform:uppercase;">Email address</label>
        <%= form.email_field :email_address,
              required: true, autofocus: true, autocomplete: "username",
              placeholder: "you@example.com", value: params[:email_address],
              style: "width:100%;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.15);border-radius:8px;padding:12px 16px;color:#F7F7F7;font-family:'ABeeZee',sans-serif;font-size:15px;box-sizing:border-box;outline:none;" %>
      </div>

      <div style="margin-bottom:32px;">
        <label style="display:block;font-family:'Alata',sans-serif;font-size:12px;letter-spacing:0.08em;color:rgba(247,247,247,0.6);margin-bottom:8px;text-transform:uppercase;">Password</label>
        <%= form.password_field :password,
              required: true, autocomplete: "current-password",
              placeholder: "••••••••", maxlength: 72,
              style: "width:100%;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.15);border-radius:8px;padding:12px 16px;color:#F7F7F7;font-family:'ABeeZee',sans-serif;font-size:15px;box-sizing:border-box;outline:none;" %>
      </div>

      <%= form.submit "Sign in →",
            style: "width:100%;background:#01EACB;border:none;border-radius:8px;padding:14px;color:#fff;font-family:'Alata',sans-serif;font-size:15px;letter-spacing:0.05em;cursor:pointer;" %>
    <% end %>
  </div>
</div>
