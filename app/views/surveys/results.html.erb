<%
  meta = defined?(ApplicationHelper::CARD_TYPE_META) ? ApplicationHelper::CARD_TYPE_META : {}
%>

<div style="min-height:100vh;background:#0F1117;display:flex;flex-direction:column;">

  <%# Nav %>
  <nav style="display:flex;align-items:center;justify-content:space-between;padding:16px 32px;border-bottom:1px solid rgba(255,255,255,0.08);flex-shrink:0;">
    <span style="font-family:'Alata',sans-serif;font-size:16px;color:white;font-weight:600;">Playverto</span>
    <span style="font-family:'ABeeZee',sans-serif;font-size:14px;color:rgba(255,255,255,0.55);">
      Results — <%= @survey.theme %>
    </span>
    <%= link_to "← Back to Editor", survey_path(@survey),
          style: "font-family:'ABeeZee',sans-serif;font-size:13px;color:rgba(255,255,255,0.5);text-decoration:none;padding:8px 16px;border-radius:12px;border:1px solid rgba(255,255,255,0.15);transition:all 0.15s;",
          onmouseover: "this.style.color='white';this.style.borderColor='rgba(255,255,255,0.35)'",
          onmouseout:  "this.style.color='rgba(255,255,255,0.5)';this.style.borderColor='rgba(255,255,255,0.15)'" %>
  </nav>

  <%# Summary strip %>
  <div style="padding:20px 32px;border-bottom:1px solid rgba(255,255,255,0.06);flex-shrink:0;display:flex;align-items:center;gap:24px;">
    <div>
      <span style="font-family:'Alata',sans-serif;font-size:32px;color:#00A950;line-height:1;"><%= @total %></span>
      <span style="font-family:'ABeeZee',sans-serif;font-size:13px;color:rgba(255,255,255,0.45);margin-left:8px;">response<%= @total == 1 ? "" : "s" %></span>
    </div>
    <% if @survey.published_at %>
      <div style="font-family:'ABeeZee',sans-serif;font-size:12px;color:rgba(255,255,255,0.35);">
        Published <%= @survey.published_at.strftime("%b %-d, %Y") %>
      </div>
    <% end %>
    <div style="font-family:'ABeeZee',sans-serif;font-size:12px;color:rgba(255,255,255,0.35);">
      <%= @aggregated.size %> card<%= @aggregated.size == 1 ? "" : "s" %>
    </div>
  </div>

  <%# Results feed %>
  <div style="flex:1;overflow-y:auto;padding:32px;">
    <div style="max-width:960px;margin:0 auto;display:flex;flex-direction:column;gap:20px;">

      <% @aggregated.each_with_index do |result, idx| %>
        <% type      = result[:type]
           card_data = result[:card]
           total_ans = result[:total]
           card_meta = card_type_meta(type) %>

        <div class="split-card" style="min-height:auto;">

          <%# Left panel %>
          <div class="split-left" style="width:200px;min-width:200px;padding:24px 20px;justify-content:flex-start;gap:12px;">
            <span class="sb-badge <%= card_meta[:badge_css] %>" style="font-size:10px;"><%= card_meta[:badge] %></span>
            <div style="font-family:'ABeeZee',sans-serif;font-size:11px;color:rgba(255,255,255,0.35);margin-top:4px;">
              Card <%= idx + 1 %>
            </div>
            <div style="margin-top:auto;font-family:'Alata',sans-serif;font-size:24px;color:white;line-height:1;">
              <%= total_ans %>
              <div style="font-family:'ABeeZee',sans-serif;font-size:10px;color:rgba(255,255,255,0.4);margin-top:2px;">
                answer<%= total_ans == 1 ? "" : "s" %>
              </div>
            </div>
          </div>

          <%# Right panel %>
          <div class="split-right" style="padding:24px 28px;">
            <div style="font-family:'ABeeZee',sans-serif;font-size:11px;color:rgba(0,0,0,0.4);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:8px;">
              <%= card_meta[:q_label] %>
            </div>
            <div style="font-family:'Alata',sans-serif;font-size:16px;color:#111;margin-bottom:20px;line-height:1.4;">
              <%= card_data["text"] %>
            </div>

            <% if total_ans == 0 %>
              <div style="font-family:'ABeeZee',sans-serif;font-size:13px;color:rgba(0,0,0,0.3);font-style:italic;">No responses yet</div>

            <% elsif type == "welcome_card" %>
              <div style="display:flex;align-items:baseline;gap:8px;">
                <span class="result-stat-number"><%= @total %></span>
                <span style="font-family:'ABeeZee',sans-serif;font-size:13px;color:rgba(0,0,0,0.5);">respondent<%= @total == 1 ? "" : "s" %> started</span>
              </div>

            <% elsif %w[multiple_choice yes_no select_one_grid select_many select_many_grid].include?(type) %>
              <% counts = result[:counts]
                 grand  = counts.values.sum.to_f
                 grand  = 1.0 if grand == 0 %>
              <% counts.sort_by { |_, v| -v }.each do |label, count| %>
                <div class="result-bar-row">
                  <span class="result-bar-label"><%= label %></span>
                  <div class="result-bar-track">
                    <div class="result-bar-fill" style="width:<%= ((count / grand) * 100).round %>%;"></div>
                  </div>
                  <span class="result-bar-pct"><%= count %> (<%= ((count / grand) * 100).round %>%)</span>
                </div>
              <% end %>

            <% elsif type == "range" %>
              <% counts = result[:counts]
                 labels = Array(card_data["options"])
                 grand  = counts.values.sum.to_f
                 grand  = 1.0 if grand == 0
                 n      = [labels.size, 2].max %>
              <% n.times do |i| %>
                <% count = counts[i].to_i
                   label = labels[i] || "Step #{i + 1}" %>
                <div class="result-bar-row">
                  <span class="result-bar-label"><%= label %></span>
                  <div class="result-bar-track">
                    <div class="result-bar-fill" style="width:<%= grand > 0 ? ((count / grand) * 100).round : 0 %>%;"></div>
                  </div>
                  <span class="result-bar-pct"><%= count %> (<%= grand > 0 ? ((count / grand) * 100).round : 0 %>%)</span>
                </div>
              <% end %>

            <% elsif type == "rating" %>
              <% counts = result[:counts]
                 avg    = result[:avg]
                 grand  = counts.values.sum.to_f
                 grand  = 1.0 if grand == 0 %>
              <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px;">
                <% filled = avg.round %>
                <div style="font-size:24px;letter-spacing:2px;">
                  <% 5.times do |i| %>
                    <span style="color:<%= i < filled ? '#FFCC00' : 'rgba(0,0,0,0.15)' %>"><%= i < filled ? "★" : "☆" %></span>
                  <% end %>
                </div>
                <span class="result-stat-number" style="font-size:28px;"><%= avg %></span>
                <span style="font-family:'ABeeZee',sans-serif;font-size:13px;color:rgba(0,0,0,0.4);">avg rating</span>
              </div>
              <% (1..5).each do |star| %>
                <% count = counts[star].to_i %>
                <div class="result-bar-row">
                  <span class="result-bar-label" style="min-width:60px;"><%= "★" * star %></span>
                  <div class="result-bar-track">
                    <div class="result-bar-fill" style="width:<%= ((count / grand) * 100).round %>%;"></div>
                  </div>
                  <span class="result-bar-pct"><%= count %> (<%= ((count / grand) * 100).round %>%)</span>
                </div>
              <% end %>

            <% elsif type == "tap_card" %>
              <% counts = result[:counts] %>
              <% counts.each do |label, dir_counts| %>
                <% yes_c = dir_counts["yes"].to_i
                   no_c  = dir_counts["no"].to_i
                   tot   = (yes_c + no_c).to_f
                   tot   = 1.0 if tot == 0 %>
                <div style="margin-bottom:14px;">
                  <div style="font-family:'ABeeZee',sans-serif;font-size:12px;color:rgba(0,0,0,0.6);margin-bottom:6px;"><%= label %></div>
                  <div class="result-bar-row" style="margin-bottom:4px;">
                    <span class="result-bar-label" style="color:#00A950;min-width:40px;">Yes</span>
                    <div class="result-bar-track">
                      <div class="result-bar-fill" style="width:<%= ((yes_c / tot) * 100).round %>%;"></div>
                    </div>
                    <span class="result-bar-pct"><%= yes_c %> (<%= ((yes_c / tot) * 100).round %>%)</span>
                  </div>
                  <div class="result-bar-row">
                    <span class="result-bar-label" style="color:#D80027;min-width:40px;">No</span>
                    <div class="result-bar-track">
                      <div class="result-bar-fill result-bar-fill-no" style="width:<%= ((no_c / tot) * 100).round %>%;"></div>
                    </div>
                    <span class="result-bar-pct"><%= no_c %> (<%= ((no_c / tot) * 100).round %>%)</span>
                  </div>
                </div>
              <% end %>

            <% elsif type == "open_ended" %>
              <% texts = result[:texts].first(20) %>
              <% texts.each do |text| %>
                <div class="result-text-row"><%= text %></div>
              <% end %>
              <% if result[:texts].size > 20 %>
                <div style="font-family:'ABeeZee',sans-serif;font-size:11px;color:rgba(0,0,0,0.35);margin-top:8px;">
                  + <%= result[:texts].size - 20 %> more response<%= result[:texts].size - 20 == 1 ? "" : "s" %>
                </div>
              <% end %>

            <% elsif type == "static_page" %>
              <% completed = result[:completed]
                 total_r   = @total
                 pct       = total_r > 0 ? ((completed.to_f / total_r) * 100).round : 0 %>
              <div style="display:flex;align-items:baseline;gap:12px;">
                <span class="result-stat-number"><%= completed %></span>
                <span style="font-family:'ABeeZee',sans-serif;font-size:13px;color:rgba(0,0,0,0.5);">
                  of <%= total_r %> completed (<%= pct %>%)
                </span>
              </div>

            <% end %>
          </div>
        </div>
      <% end %>

    </div>
  </div>

</div>
