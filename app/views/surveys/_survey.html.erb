<%
  type_eyebrow = {
    "multiple_choice"  => "Choose one",
    "select_many"      => "Choose all that apply",
    "select_one_grid"  => "Choose one",
    "select_many_grid" => "Choose all that apply",
    "tap_card"         => "Swipe to respond",
    "range"            => "Drag the slider",
    "rating"           => "Drag the slider",
    "yes_no"           => "Choose one",
    "open_ended"       => "Type your answer",
    "welcome_card"     => "Welcome",
    "static_page"      => "Activity"
  }

  # Pre-compute progress fill % for the left-panel bar (visual only).
  total_q = Array(survey["cards"]).count { |c| !%w[welcome_card static_page].include?(c["type"]) }
  q_index = 0
%>

<%= turbo_frame_tag "survey" do %>
  <article class="bg-navy-800 p-6"
           data-controller="survey-editor"
           data-survey-editor-id-value="<%= survey['id'] %>"
           data-survey-editor-url-value="<%= survey['id'] ? survey_path(survey['id']) : '' %>">

    <%# Survey-level header %>
    <div class="max-w-[900px] mx-auto mb-8">
      <div class="text-green-500 text-xs tracking-widest uppercase font-bold mb-2"
           style="font-family:'Alata',sans-serif">Verto Survey</div>
      <h2 class="text-3xl text-white outline-none mb-2" contenteditable="true"
          data-survey-editor-target="title"
          data-action="input->survey-editor#edit"><%= survey["title"] %></h2>
      <p class="text-white/60 outline-none" contenteditable="true"
         data-survey-editor-target="surveyDescription"
         data-action="input->survey-editor#edit"><%= survey["description"] %></p>

      <div class="mt-4 flex items-center justify-between gap-3 bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-xs">
        <div class="flex gap-6 text-white/70">
          <div><span class="text-green-500 uppercase tracking-widest font-bold mr-2" style="font-family:'Alata',sans-serif">Theme</span><%= survey["theme"] %></div>
          <div><span class="text-green-500 uppercase tracking-widest font-bold mr-2" style="font-family:'Alata',sans-serif">Audience</span><%= survey["audience_age"] %></div>
          <div><span class="text-green-500 uppercase tracking-widest font-bold mr-2" style="font-family:'Alata',sans-serif">Insight</span><%= survey["key_insight"] %></div>
        </div>
        <div data-survey-editor-target="summary"></div>
      </div>
    </div>

    <ol class="space-y-6">
      <% Array(survey["cards"]).each_with_index do |c, idx| %>
        <% type = c["type"] %>
        <% eyebrow = type_eyebrow[type] || type.to_s.tr('_', ' ') %>
        <% is_question = !%w[welcome_card static_page].include?(type) %>
        <% q_index += 1 if is_question %>
        <% progress = total_q.zero? ? 0 : ((q_index.to_f / total_q) * 100).round %>

        <li class="max-w-[900px] mx-auto"
            data-survey-editor-target="card"
            data-card-type="<%= type %>">

          <%# Editor chrome (above split-card) %>
          <div class="edit-chrome">
            <div class="flex items-center gap-2">
              <span class="type-tag"><%= type.to_s.tr('_', ' ') %></span>
              <span class="text-white/40">Card <%= idx + 1 %></span>
            </div>
            <div class="flex gap-3">
              <button type="button"
                      class="text-white/40 hover:text-red-500 leading-none"
                      data-action="click->survey-editor#deleteCard"
                      title="Delete card">×</button>
            </div>
          </div>

          <%# Verto split-card %>
          <div class="split-card">
            <%# ── LEFT PANEL ── %>
            <% if %w[tap_card open_ended].include?(type) %>
              <div class="split-left split-left-dark">
                <div class="absolute inset-0 flex items-center justify-center">
                  <div class="text-white/20 text-6xl"><%= type == "tap_card" ? "↔" : "✎" %></div>
                </div>
                <div class="panel-progress" style="background:rgba(255,255,255,0.15)">
                  <div class="panel-progress-fill" style="width:<%= progress %>%"></div>
                </div>
                <div class="panel-tagline">Build the change</div>
              </div>
            <% else %>
              <div class="split-left">
                <%# Placeholder gradient until brand imagery lands %>
                <div class="split-left-img"
                     style="background: linear-gradient(135deg, #01EACB 0%, #1C2034 70%);"></div>
                <div class="split-left-overlay"></div>
                <div class="panel-progress">
                  <div class="panel-progress-fill" style="width:<%= progress %>%"></div>
                </div>
                <div class="panel-tagline">Build the change</div>
              </div>
            <% end %>

            <%# ── RIGHT PANEL ── %>
            <div class="split-right">

              <% if is_question %>
                <div class="q-eyebrow"><%= eyebrow %></div>
              <% end %>

              <% if type == "static_page" %>
                <div class="activity-tag">Activity</div>
              <% end %>

              <div class="<%= type == 'static_page' ? 'activity-title' : 'q-title' %>"
                   contenteditable="true"
                   data-role="text"
                   data-action="input->survey-editor#edit"><%= c["text"] %></div>

              <% if c["description"].present? %>
                <div class="<%= type == 'static_page' ? 'activity-desc' : 'q-subtitle' %>"
                     contenteditable="true"
                     data-role="description"
                     data-action="input->survey-editor#edit"><%= c["description"] %></div>
              <% end %>

              <%# ── Type-specific component ── %>
              <div class="mt-2">
              <%- case type
                  when "multiple_choice", "select_many", "yes_no" -%>
                <%# Pick list. yes_no uses fixed Yes/No items. %>
                <% items = type == "yes_no" ? %w[Yes No] : Array(c["options"]) %>
                <% multi = (type == "select_many") %>
                <ul class="pick-list"
                    data-controller="picker"
                    data-picker-mode-value="<%= multi ? 'multi' : 'single' %>"
                    data-role="option-list">
                  <% items.each do |opt| %>
                    <li class="pick-item"
                        data-picker-target="item"
                        data-action="click->picker#pick"
                        data-selected="false">
                      <span class="<%= multi ? 'pick-square' : 'pick-dot' %>" data-role="indicator">✓</span>
                      <span class="pick-text"
                            <% if type != "yes_no" %>contenteditable="true"<% end %>
                            data-role="<%= type == 'yes_no' ? 'option-fixed' : 'option' %>"
                            data-action="input->survey-editor#edit"><%= opt %></span>
                      <% if type != "yes_no" %>
                        <button type="button"
                                class="text-black/30 hover:text-red-500 text-xs"
                                data-action="click->survey-editor#removeOption">remove</button>
                      <% end %>
                    </li>
                  <% end %>
                </ul>

              <% when "select_one_grid", "select_many_grid" %>
                <% n = Array(c["options"]).size %>
                <% cols = n >= 5 ? 3 : 2 %>
                <% multi = (type == "select_many_grid") %>
                <ul class="choice-grid choice-grid-<%= cols %>"
                    data-controller="picker"
                    data-picker-mode-value="<%= multi ? 'multi' : 'single' %>"
                    data-role="option-list">
                  <% Array(c["options"]).each_with_index do |opt, i| %>
                    <li class="choice-card"
                        data-picker-target="item"
                        data-action="click->picker#pick"
                        data-selected="false"
                        data-role="option-row">
                      <div class="choice-card-bg choice-bg-<%= (i % 6) + 1 %>"></div>
                      <div class="choice-overlay"></div>
                      <div class="choice-tick">✓</div>
                      <div class="choice-label"
                           contenteditable="true"
                           data-role="option"
                           data-action="input->survey-editor#edit"><%= opt %></div>
                      <button type="button"
                              class="absolute top-1 left-1 text-white/60 hover:text-red-500 text-xs leading-none bg-black/40 rounded-full w-5 h-5 flex items-center justify-center"
                              data-action="click->survey-editor#removeOption"
                              title="remove">×</button>
                    </li>
                  <% end %>
                </ul>

              <% when "tap_card" %>
                <%# Rotate / Swipe stack %>
                <div class="rotate-wrap"
                     data-controller="tap-stack"
                     data-role="option-list">
                  <div class="rotate-card-stack">
                    <% Array(c["options"]).each_with_index do |opt, i| %>
                      <div class="rotate-card"
                           data-tap-stack-target="card"
                           data-role="option-row"
                           style="background: linear-gradient(135deg, <%= ['#d4edda','#d1ecf1','#fff3cd','#f8d7da','#e2d9f3'][i % 5] %>, <%= ['#a8d5b5','#9fd5df','#ffd88a','#f5a8b0','#c3aee8'][i % 5] %>);">
                        <span contenteditable="true"
                              class="outline-none"
                              data-role="option"
                              data-action="input->survey-editor#edit"><%= opt %></span>
                      </div>
                    <% end %>
                  </div>
                  <div class="swipe-indicator">
                    <span style="color:#D80027;font-weight:700">← No</span>
                    <span class="mx-3">drag card to answer</span>
                    <span style="color:#01EACB;font-weight:700">Yes →</span>
                  </div>
                  <div class="rotate-actions">
                    <button type="button"
                            class="rotate-action-btn rotate-action-no"
                            data-action="click->tap-stack#pick"
                            data-tap-stack-direction="left"
                            title="No">✕</button>
                    <button type="button"
                            class="rotate-action-btn rotate-action-yes"
                            data-action="click->tap-stack#pick"
                            data-tap-stack-direction="right"
                            title="Yes">✓</button>
                  </div>
                  <div class="text-xs text-black/40 flex items-center gap-3">
                    <span data-tap-stack-target="counter"></span>
                    <button type="button"
                            class="hover:text-green-500"
                            data-action="click->tap-stack#reset">↺ Reset stack</button>
                  </div>
                </div>

              <% when "range", "rating" %>
                <% labels = Array(c["options"]) %>
                <% n = [labels.size, 2].max %>
                <div class="slider-wrap"
                     data-controller="slider"
                     data-slider-steps-value="<%= n %>"
                     data-role="option-list">
                  <div class="slider-track-wrap">
                    <div class="slider-tooltip" data-slider-target="tooltip" style="left:50%;">
                      <span class="slider-tooltip-text" data-slider-target="tooltipText"></span>
                    </div>
                    <div class="slider-track"
                         data-slider-target="track"
                         data-action="pointerdown->slider#start">
                      <% n.times do |i| %>
                        <div class="s-dot" data-slider-target="dot" style="left:<%= (i.to_f / (n - 1) * 100).round(2) %>%"></div>
                      <% end %>
                      <div class="slider-thumb" data-slider-target="thumb" style="left:50%;">
                        <div class="s-line"></div><div class="s-line"></div><div class="s-line"></div>
                      </div>
                    </div>
                  </div>
                  <div class="slider-labels">
                    <% labels.each_with_index do |opt, i| %>
                      <span class="slider-label-text"
                            data-slider-target="label"
                            data-role="option-row">
                        <span contenteditable="true"
                              class="outline-none"
                              data-role="option"
                              data-action="input->survey-editor#edit"><%= opt %></span>
                        <button type="button"
                                class="text-black/30 hover:text-red-500 ml-1"
                                data-action="click->survey-editor#removeOption">×</button>
                      </span>
                    <% end %>
                  </div>
                </div>

              <% when "open_ended" %>
                <div class="freeform-wrap"
                     data-controller="freeform"
                     data-freeform-max-value="200">
                  <textarea class="freeform-textarea"
                            placeholder="Type answer…"
                            data-freeform-target="input"
                            data-action="input->freeform#update"></textarea>
                  <div class="freeform-counter" data-freeform-target="counter">0/200 Characters</div>
                </div>

              <% when "welcome_card" %>
                <%# Welcome uses just title + description; nothing extra. %>

              <% when "static_page" %>
                <%# Static page uses activity layout (already rendered above). %>

              <% end %>
              </div>

              <%# ── Add option footer (lives at bottom of right panel) ── %>
              <% if %w[multiple_choice select_many select_one_grid select_many_grid tap_card range rating].include?(type) %>
                <div class="mt-auto pt-4 flex items-center gap-3 text-xs">
                  <button type="button"
                          class="px-3 py-1 border border-black/15 rounded-full hover:border-green-500 text-black/60"
                          data-action="click->survey-editor#addOption">+ Add option</button>
                  <span data-role="option-status" class="text-black/50"></span>
                </div>
                <template data-role="option-template">
                  <li class="pick-item" data-picker-target="item" data-action="click->picker#pick" data-selected="false" data-role="option-row">
                    <span class="pick-dot" data-role="indicator">✓</span>
                    <span class="pick-text" contenteditable="true" data-role="option" data-action="input->survey-editor#edit">New option</span>
                    <button type="button" class="text-black/30 hover:text-red-500 text-xs" data-action="click->survey-editor#removeOption">remove</button>
                  </li>
                </template>
              <% end %>
            </div>
          </div>
        </li>
      <% end %>
    </ol>

    <div class="max-w-[900px] mx-auto mt-8 flex items-center justify-between flex-wrap gap-3">
      <%= link_to "← Generate another", root_path,
            class: "text-white/70 hover:text-green-500 text-sm" %>
      <div class="flex items-center gap-3">
        <span data-survey-editor-target="status" class="text-xs text-white/50"></span>
        <button type="button"
                class="bg-green-500 text-white tracking-widest px-5 py-2 rounded-2xl hover:bg-green-dark disabled:opacity-50 font-bold"
                style="font-family:'Alata',sans-serif"
                data-action="click->survey-editor#save"
                data-survey-editor-target="saveButton">Save changes</button>
        <% if survey["id"] %>
          <%= link_to "Permalink", survey_path(survey["id"]),
                class: "text-white/70 hover:text-green-500 text-sm" %>
        <% end %>
      </div>
    </div>
  </article>
<% end %>
