<%= turbo_frame_tag "survey" do %>
  <article class="border rounded-lg p-6 bg-white shadow-sm"
           data-controller="survey-editor"
           data-survey-editor-id-value="<%= survey['id'] %>"
           data-survey-editor-url-value="<%= survey['id'] ? survey_path(survey['id']) : '' %>">
    <h2 class="text-2xl font-semibold mb-1" contenteditable="true"
        data-survey-editor-target="title"
        data-action="input->survey-editor#edit"><%= survey["title"] %></h2>
    <p class="text-gray-600 mb-4" contenteditable="true"
       data-survey-editor-target="surveyDescription"
       data-action="input->survey-editor#edit"><%= survey["description"] %></p>

    <div class="flex items-center justify-between mb-4 bg-gray-50 p-3 rounded">
      <dl class="grid grid-cols-3 gap-2 text-xs text-gray-600 flex-1">
        <div><dt class="font-semibold">Theme</dt><dd><%= survey["theme"] %></dd></div>
        <div><dt class="font-semibold">Audience age</dt><dd><%= survey["audience_age"] %></dd></div>
        <div><dt class="font-semibold">Key insight</dt><dd><%= survey["key_insight"] %></dd></div>
      </dl>
      <div class="ml-4" data-survey-editor-target="summary"></div>
    </div>

    <p class="text-xs text-gray-500 mb-4">
      Click any text to edit. Limits: question 50–70 chars (max 100), option max 20 chars,
      questions 10–15. Warnings turn amber/red when you exceed targets.
    </p>

    <ol class="space-y-5">
      <% Array(survey["cards"]).each do |c| %>
        <% type = c["type"] %>
        <li class="relative border rounded p-3"
            data-survey-editor-target="card"
            data-card-type="<%= type %>">

          <button type="button"
                  class="absolute top-2 right-2 text-gray-400 hover:text-red-600 text-sm"
                  data-action="click->survey-editor#deleteCard"
                  title="Delete card">×</button>

          <div class="flex items-baseline gap-2 mb-1">
            <span class="text-xs uppercase tracking-wide text-gray-500"><%= type.to_s.tr('_', ' ') %></span>
            <span data-role="char-counter" class="text-xs text-gray-400"></span>
          </div>

          <div class="border-b-2 border-transparent">
            <div contenteditable="true"
                 class="font-medium outline-none"
                 data-role="text"
                 data-action="input->survey-editor#edit"><%= c["text"] %></div>
          </div>

          <% if c["description"].present? || %w[welcome_card static_page].include?(type) %>
            <div class="mt-1">
              <div contenteditable="true"
                   class="text-sm text-gray-600 outline-none border-b-2 border-transparent"
                   data-role="description"
                   data-action="input->survey-editor#edit"><%= c["description"] %></div>
              <div data-role="char-counter" class="text-xs text-gray-400"></div>
            </div>
          <% end %>

          <% if %w[multiple_choice select_many select_one_grid select_many_grid tap_card range rating].include?(type) %>
            <div class="mt-3 ml-2">
              <ul data-role="option-list" class="space-y-1">
                <% Array(c["options"]).each do |opt| %>
                  <li data-role="option-row" class="flex items-center gap-2">
                    <span class="text-gray-400">•</span>
                    <span contenteditable="true"
                          class="flex-1 outline-none border-b border-transparent focus:border-gray-300"
                          data-role="option"
                          data-action="input->survey-editor#edit"><%= opt %></span>
                    <button type="button"
                            class="text-gray-400 hover:text-red-600 disabled:opacity-30 disabled:hover:text-gray-400 text-xs"
                            data-action="click->survey-editor#removeOption">remove</button>
                  </li>
                <% end %>
              </ul>

              <template data-role="option-template">
                <li data-role="option-row" class="flex items-center gap-2">
                  <span class="text-gray-400">•</span>
                  <span contenteditable="true"
                        class="flex-1 outline-none border-b border-gray-300"
                        data-role="option"
                        data-action="input->survey-editor#edit">New option</span>
                  <button type="button"
                          class="text-gray-400 hover:text-red-600 text-xs"
                          data-action="click->survey-editor#removeOption">remove</button>
                </li>
              </template>

              <div class="mt-2 flex items-center gap-3">
                <button type="button"
                        class="text-xs px-2 py-1 border rounded hover:bg-gray-50 disabled:opacity-40"
                        data-action="click->survey-editor#addOption">+ Add option</button>
                <span data-role="option-status" class="text-xs text-gray-500"></span>
              </div>
            </div>

          <% elsif type == "yes_no" %>
            <div class="mt-2 ml-2 text-gray-500 text-sm">Yes / No (fixed)</div>
          <% elsif type == "open_ended" %>
            <div class="mt-2 ml-2 text-gray-500 text-sm italic">Free-text response</div>
          <% end %>
        </li>
      <% end %>
    </ol>

    <div class="mt-6 flex items-center justify-between">
      <%= link_to "Generate another", root_path,
            class: "text-indigo-600 hover:underline",
            data: { turbo_frame: "_top" } %>
      <div class="flex items-center gap-3">
        <span data-survey-editor-target="status" class="text-xs text-gray-500"></span>
        <button type="button"
                class="px-4 py-2 bg-emerald-600 text-white rounded hover:bg-emerald-700 disabled:opacity-50"
                data-action="click->survey-editor#save"
                data-survey-editor-target="saveButton">Save changes</button>
        <% if survey["id"] %>
          <%= link_to "Permalink", survey_path(survey["id"]),
                class: "text-indigo-600 hover:underline text-sm",
                data: { turbo_frame: "_top" } %>
        <% end %>
      </div>
    </div>
  </article>
<% end %>
