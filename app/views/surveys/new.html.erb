<% content_for :head do %>
  <style>body { overflow: auto !important; height: auto !important; background: #1C2034 !important; }</style>
<% end %>

<div data-controller="generating" style="display:flex;min-height:100vh;background:#1C2034;">

  <%= render "shared/sidebar", active: "create" %>

  <%# ── Generating overlay — hidden until form submits ── %>
  <div class="fixed inset-0 z-50 hidden flex-col overflow-hidden"
       style="background:#1C2034;"
       data-generating-target="overlay">

    <%# Floating brand-colour orbs %>
    <div class="gen-orbs">
      <div class="gen-orb gen-orb-1"></div>
      <div class="gen-orb gen-orb-2"></div>
      <div class="gen-orb gen-orb-3"></div>
      <div class="gen-orb gen-orb-4"></div>
    </div>

    <%# Nav %>
    <nav style="height:54px;background:rgba(28,32,52,0.6);backdrop-filter:blur(10px);border-bottom:1px solid rgba(255,255,255,0.08);flex-shrink:0;position:relative;z-index:1;"
         class="flex items-center justify-between px-9">
      <%= link_to root_path do %>
        <%= image_tag "playverto.svg", alt: "Playverto", class: "h-7 w-auto" %>
      <% end %>
      <span style="font-family:'ABeeZee',sans-serif;font-size:13px;color:rgba(255,255,255,0.45);">Create Verto</span>
      <span></span>
    </nav>

    <%# Body %>
    <div class="gen-stage flex-1 flex flex-col items-center justify-center gap-8 px-16 py-10">

      <div class="gen-shimmer"
           style="font-family:'Alata',sans-serif;font-size:11px;text-transform:uppercase;letter-spacing:0.22em;font-weight:700;">
        Building your Verto
      </div>

      <div class="text-center" style="max-width:680px;">
        <div class="gen-hero-theme" data-generating-target="heroTheme"></div>
        <div style="font-family:'ABeeZee',sans-serif;font-size:17px;color:rgba(255,255,255,0.38);letter-spacing:-0.2px;line-height:1.5;margin-top:6px;"
             data-generating-target="heroAge"></div>
      </div>

      <div class="flex gap-2.5 flex-wrap justify-center">
        <div class="gen-pill">
          <div class="gen-pill-dot" style="background:#01EACB;"></div>
          <span class="gen-pill-label">Audience</span>
          <span data-generating-target="pillAudience"></span>
        </div>
        <div class="gen-pill">
          <div class="gen-pill-dot" style="background:#FF1E6F;"></div>
          <span class="gen-pill-label">Tone</span>
          <span>Conversational</span>
        </div>
        <div class="gen-pill">
          <div class="gen-pill-dot" style="background:#0CA7FF;"></div>
          <span class="gen-pill-label">Cards</span>
          <span>10–15</span>
        </div>
      </div>

      <div class="gen-insight" data-generating-target="insightText"></div>

      <div class="gen-steps-row">
        <div class="gen-step" data-state="done" data-generating-target="step1">
          <div class="step-dot">✓</div>
          <span>Brief read</span>
        </div>
        <div class="gen-step" data-state="active" data-generating-target="step2">
          <div class="step-dot"></div>
          <span>Writing questions</span>
        </div>
        <div class="gen-step" data-state="pending" data-generating-target="step3">
          <div class="step-dot"></div>
          <span>Picking formats</span>
        </div>
        <div class="gen-step" data-state="pending" data-generating-target="step4">
          <div class="step-dot"></div>
          <span>Applying design</span>
        </div>
      </div>

    </div>

    <div class="gen-rainbow-bar"></div>
  </div>

  <%# ── Form area ── %>
  <div style="flex:1;display:flex;flex-direction:column;padding:48px 48px 60px;max-width:640px;">

    <% if flash[:alert] %>
      <div style="margin-bottom:20px;padding:12px 16px;border-radius:12px;background:rgba(255,30,111,0.1);color:#FF1E6F;border:1px solid rgba(255,30,111,0.3);font-family:'ABeeZee',sans-serif;font-size:13px;">
        <%= flash[:alert] %>
      </div>
    <% end %>

    <div style="margin-bottom:28px;">
      <div style="font-family:'ABeeZee',sans-serif;font-size:11px;color:rgba(255,255,255,0.3);letter-spacing:0.1em;text-transform:uppercase;margin-bottom:10px;">New Verto</div>
      <h1 style="font-family:'Alata',sans-serif;font-size:32px;color:#fff;margin:0 0 8px;line-height:1.1;">Create a Verto</h1>
      <p style="font-family:'ABeeZee',sans-serif;font-size:14px;color:rgba(255,255,255,0.45);margin:0;line-height:1.6;">
        Answer the four questions below — we'll turn your brief into a Verto that follows the Playverto rules.
      </p>
    </div>

    <%= form_with url: generate_survey_path, method: :post,
          data: { action: "submit->generating#show" } do |f| %>

      <div style="display:flex;flex-direction:column;gap:18px;">

        <div>
          <label style="font-family:'Alata',sans-serif;font-size:10px;color:#FF1E6F;letter-spacing:0.12em;text-transform:uppercase;display:block;margin-bottom:8px;">What's your Verto about? <span style="color:rgba(255,255,255,0.45);text-transform:none;font-family:'ABeeZee',sans-serif;font-size:11px;letter-spacing:0;">— the single overarching topic</span></label>
          <%= f.text_field :theme,
                placeholder: "e.g. Youth wellbeing · Climate action · Refugee education · Food security",
                style: "width:100%;background:#272D4A;border:1px solid rgba(255,255,255,0.1);border-radius:12px;padding:12px 16px;color:#fff;font-family:'ABeeZee',sans-serif;font-size:14px;outline:none;box-sizing:border-box;",
                onfocus: "this.style.borderColor='rgba(255,30,111,0.5)'",
                onblur:  "this.style.borderColor='rgba(255,255,255,0.1)'" %>
        </div>

        <div>
          <label style="font-family:'Alata',sans-serif;font-size:10px;color:#FF1E6F;letter-spacing:0.12em;text-transform:uppercase;display:block;margin-bottom:8px;">Who's answering — and what age are they?</label>
          <%= f.text_field :audience_age,
                placeholder: "e.g. 18–24 university students in Kenya · 35–55 frontline community-health workers",
                style: "width:100%;background:#272D4A;border:1px solid rgba(255,255,255,0.1);border-radius:12px;padding:12px 16px;color:#fff;font-family:'ABeeZee',sans-serif;font-size:14px;outline:none;box-sizing:border-box;",
                onfocus: "this.style.borderColor='rgba(255,30,111,0.5)'",
                onblur:  "this.style.borderColor='rgba(255,255,255,0.1)'" %>
        </div>

        <div>
          <label style="font-family:'Alata',sans-serif;font-size:10px;color:#FF1E6F;letter-spacing:0.12em;text-transform:uppercase;display:block;margin-bottom:8px;">What do you want to learn from them? <span style="color:rgba(255,255,255,0.45);text-transform:none;font-family:'ABeeZee',sans-serif;font-size:11px;letter-spacing:0;">— the insight that would change a decision</span></label>
          <%= f.text_area :key_insight, rows: 3,
                placeholder: "e.g. Why do volunteers drop off after month three?\ne.g. What's stopping people from accessing our food bank?\ne.g. Does our youth programme actually shift confidence — and where exactly?",
                style: "width:100%;background:#272D4A;border:1px solid rgba(255,255,255,0.1);border-radius:12px;padding:12px 16px;color:#fff;font-family:'ABeeZee',sans-serif;font-size:14px;outline:none;resize:vertical;box-sizing:border-box;line-height:1.55;",
                onfocus: "this.style.borderColor='rgba(255,30,111,0.5)'",
                onblur:  "this.style.borderColor='rgba(255,255,255,0.1)'" %>
        </div>

        <div>
          <label style="font-family:'Alata',sans-serif;font-size:10px;color:#FF1E6F;letter-spacing:0.12em;text-transform:uppercase;display:block;margin-bottom:8px;">Anything else we should know? <span style="color:rgba(255,255,255,0.45);text-transform:none;font-family:'ABeeZee',sans-serif;font-size:11px;letter-spacing:0;">— context, tone, must-asks</span></label>
          <%= f.text_area :notes, rows: 4,
                placeholder: "e.g. Audience has never used Playverto before, keep tone warm, not corporate.\ne.g. Must include a question about funding routes and barriers to grants.\ne.g. We'll run this during our impact summit, so respondents are bought-in.\ne.g. Avoid jargon — many respondents speak English as a second language.",
                style: "width:100%;background:#272D4A;border:1px solid rgba(255,255,255,0.1);border-radius:12px;padding:12px 16px;color:#fff;font-family:'ABeeZee',sans-serif;font-size:14px;outline:none;resize:vertical;box-sizing:border-box;line-height:1.55;",
                onfocus: "this.style.borderColor='rgba(255,30,111,0.5)'",
                onblur:  "this.style.borderColor='rgba(255,255,255,0.1)'" %>
        </div>

        <%= f.submit "Generate Verto →",
              style: "margin-top:8px;padding:13px 32px;border-radius:100px;background:#01EACB;color:#1C2034;font-family:'Alata',sans-serif;font-size:15px;letter-spacing:0.05em;border:none;cursor:pointer;transition:background 0.15s;",
              onmouseover: "this.style.background='#00C4AB'",
              onmouseout:  "this.style.background='#01EACB'",
              data: { turbo_submits_with: "Generating…" } %>

      </div>
    <% end %>

  </div>

</div>
