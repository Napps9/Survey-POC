<% content_for :head do %>
  <style>body { overflow: auto !important; height: auto !important; background: #1C2034 !important; }</style>
<% end %>

<div data-controller="generating" style="display:flex;min-height:100vh;background:#1C2034;">

  <%# ── Generating overlay — hidden until form submits ── %>
  <div class="fixed inset-0 z-50 hidden flex-col overflow-hidden"
       style="background:#1C2034;"
       data-generating-target="overlay">

    <%# Floating brand-colour orbs %>
    <div class="gen-orbs">
      <div class="gen-orb gen-orb-1"></div>
      <div class="gen-orb gen-orb-2"></div>
      <div class="gen-orb gen-orb-3"></div>
      <div class="gen-orb gen-orb-4"></div>
    </div>

    <%# Nav %>
    <nav style="height:54px;background:rgba(28,32,52,0.6);backdrop-filter:blur(10px);border-bottom:1px solid rgba(255,255,255,0.08);flex-shrink:0;position:relative;z-index:1;"
         class="flex items-center justify-between px-9">
      <%= link_to root_path do %>
        <%= image_tag "playverto.svg", alt: "Playverto", class: "h-7 w-auto" %>
      <% end %>
      <span style="font-family:'ABeeZee',sans-serif;font-size: var(--text-md);color:rgba(255,255,255,0.45);">Create Verto</span>
      <span></span>
    </nav>

    <%# Body %>
    <div class="gen-stage flex-1 flex flex-col items-center justify-center gap-8 px-16 py-10">

      <div class="gen-shimmer"
           style="font-family:'Alata',sans-serif;font-size: var(--text-sm);text-transform:uppercase;letter-spacing:0.22em;font-weight:700;">
        Building your Verto
      </div>

      <div class="text-center" style="max-width:680px;">
        <div class="gen-hero-theme" data-generating-target="heroTheme"></div>
        <div style="font-family:'ABeeZee',sans-serif;font-size: var(--text-2xl);color:rgba(255,255,255,0.38);letter-spacing:-0.2px;line-height:1.5;margin-top:6px;"
             data-generating-target="heroAge"></div>
      </div>

      <div class="flex gap-2.5 flex-wrap justify-center">
        <div class="gen-pill">
          <div class="gen-pill-dot" style="background:#01EACB;"></div>
          <span class="gen-pill-label">Audience</span>
          <span data-generating-target="pillAudience"></span>
        </div>
        <div class="gen-pill">
          <div class="gen-pill-dot" style="background:#FF1E6F;"></div>
          <span class="gen-pill-label">Tone</span>
          <span>Conversational</span>
        </div>
        <div class="gen-pill">
          <div class="gen-pill-dot" style="background:#0CA7FF;"></div>
          <span class="gen-pill-label">Cards</span>
          <span>10–15</span>
        </div>
      </div>

      <div class="gen-insight" data-generating-target="insightText"></div>

      <div class="gen-steps-row">
        <div class="gen-step" data-state="done" data-generating-target="step1">
          <div class="step-dot">✓</div>
          <span>Brief read</span>
        </div>
        <div class="gen-step" data-state="active" data-generating-target="step2">
          <div class="step-dot"></div>
          <span>Writing questions</span>
        </div>
        <div class="gen-step" data-state="pending" data-generating-target="step3">
          <div class="step-dot"></div>
          <span>Picking formats</span>
        </div>
        <div class="gen-step" data-state="pending" data-generating-target="step4">
          <div class="step-dot"></div>
          <span>Applying design</span>
        </div>
      </div>

    </div>

    <div class="gen-rainbow-bar"></div>
  </div>

  <%# ── Form area ── %>
  <div style="flex:1;display:flex;justify-content:center;overflow-y:auto;">
    <div style="max-width:680px;width:100%;padding:56px 32px 80px;">

    <% if flash[:alert] %>
      <div style="margin-bottom:20px;padding:12px 16px;border-radius:12px;background:rgba(255,30,111,0.1);color:#FF1E6F;border:1px solid rgba(255,30,111,0.3);font-family:'ABeeZee',sans-serif;font-size: var(--text-md);">
        <%= flash[:alert] %>
      </div>
    <% end %>

    <div style="margin-bottom:32px;text-align:center;">
      <div style="font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.3);letter-spacing:0.1em;text-transform:uppercase;margin-bottom:10px;">New Verto</div>
      <h1 style="font-family:'Alata',sans-serif;font-size: var(--text-5xl);color:#fff;margin:0 0 8px;line-height:1.1;">Create a Verto</h1>
      <p style="font-family:'ABeeZee',sans-serif;font-size: var(--text-lg);color:rgba(255,255,255,0.45);margin:0 auto;line-height:1.6;max-width:520px;">
        Answer the four questions below — we'll turn your brief into a Verto that follows the Playverto rules.
      </p>
    </div>

    <%= form_with url: generate_survey_path, method: :post,
          data: { action: "submit->generating#show" } do |f| %>

      <div style="display:flex;flex-direction:column;gap:16px;">

        <%
          fields = [
            { num: "01", color: "#FF1E6F" },
            { num: "02", color: "#01EACB" },
            { num: "03", color: "#0CA7FF" },
            { num: "04", color: "#615BF5" }
          ]
        %>

        <%# ── Field 01 · Theme ── %>
        <% f1 = fields[0] %>
        <div style="background:rgba(39,45,74,0.4);border:1px solid rgba(255,255,255,0.06);border-radius:14px;padding:18px 20px;">
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;">
            <span style="font-family:'Alata',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.85);letter-spacing:0.08em;padding-bottom:2px;border-bottom:1px solid <%= f1[:color] %>;"><%= f1[:num] %></span>
            <span style="width:6px;height:6px;border-radius:50%;background:<%= f1[:color] %>;flex-shrink:0;"></span>
            <label style="font-family:'Alata',sans-serif;font-size: var(--text-xs);color:<%= f1[:color] %>;letter-spacing:0.12em;text-transform:uppercase;">What's your Verto about? <span style="color:rgba(255,255,255,0.45);text-transform:none;font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);letter-spacing:0;">— the single overarching topic</span></label>
          </div>
          <%= f.text_field :theme,
                placeholder: "e.g. Youth wellbeing",
                style: "width:100%;background:#272D4A;border:1px solid rgba(255,255,255,0.1);border-radius:12px;padding:12px 16px;color:#fff;font-family:'ABeeZee',sans-serif;font-size: var(--text-lg);outline:none;box-sizing:border-box;",
                onfocus: "this.style.borderColor='#{f1[:color]}80'",
                onblur:  "this.style.borderColor='rgba(255,255,255,0.1)'" %>
          <div style="display:flex;flex-wrap:wrap;gap:6px;margin-top:10px;">
            <% ["Climate action", "Refugee education", "Food security"].each do |ex| %>
              <span style="display:inline-flex;align-items:center;gap:6px;padding:5px 12px;border-radius:100px;border:1px solid rgba(255,255,255,0.08);background:rgba(255,255,255,0.03);font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.5);">
                <span style="font-family:'Alata',sans-serif;font-size: var(--text-2xs);color:rgba(255,255,255,0.3);letter-spacing:0.05em;text-transform:uppercase;">e.g.</span>
                <%= ex %>
              </span>
            <% end %>
          </div>
        </div>

        <%# ── Field 02 · Audience ── %>
        <% f2 = fields[1] %>
        <div style="background:rgba(39,45,74,0.4);border:1px solid rgba(255,255,255,0.06);border-radius:14px;padding:18px 20px;">
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;">
            <span style="font-family:'Alata',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.85);letter-spacing:0.08em;padding-bottom:2px;border-bottom:1px solid <%= f2[:color] %>;"><%= f2[:num] %></span>
            <span style="width:6px;height:6px;border-radius:50%;background:<%= f2[:color] %>;flex-shrink:0;"></span>
            <label style="font-family:'Alata',sans-serif;font-size: var(--text-xs);color:<%= f2[:color] %>;letter-spacing:0.12em;text-transform:uppercase;">Who's answering — and what age are they?</label>
          </div>
          <%= f.text_field :audience_age,
                placeholder: "e.g. 18–24 university students in Kenya",
                style: "width:100%;background:#272D4A;border:1px solid rgba(255,255,255,0.1);border-radius:12px;padding:12px 16px;color:#fff;font-family:'ABeeZee',sans-serif;font-size: var(--text-lg);outline:none;box-sizing:border-box;",
                onfocus: "this.style.borderColor='#{f2[:color]}80'",
                onblur:  "this.style.borderColor='rgba(255,255,255,0.1)'" %>
          <div style="display:flex;flex-wrap:wrap;gap:6px;margin-top:10px;">
            <% ["35–55 frontline community-health workers"].each do |ex| %>
              <span style="display:inline-flex;align-items:center;gap:6px;padding:5px 12px;border-radius:100px;border:1px solid rgba(255,255,255,0.08);background:rgba(255,255,255,0.03);font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.5);">
                <span style="font-family:'Alata',sans-serif;font-size: var(--text-2xs);color:rgba(255,255,255,0.3);letter-spacing:0.05em;text-transform:uppercase;">e.g.</span>
                <%= ex %>
              </span>
            <% end %>
          </div>
        </div>

        <%# ── Field 03 · Key insight ── %>
        <% f3 = fields[2] %>
        <div style="background:rgba(39,45,74,0.4);border:1px solid rgba(255,255,255,0.06);border-radius:14px;padding:18px 20px;">
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;">
            <span style="font-family:'Alata',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.85);letter-spacing:0.08em;padding-bottom:2px;border-bottom:1px solid <%= f3[:color] %>;"><%= f3[:num] %></span>
            <span style="width:6px;height:6px;border-radius:50%;background:<%= f3[:color] %>;flex-shrink:0;"></span>
            <label style="font-family:'Alata',sans-serif;font-size: var(--text-xs);color:<%= f3[:color] %>;letter-spacing:0.12em;text-transform:uppercase;">What do you want to learn from them? <span style="color:rgba(255,255,255,0.45);text-transform:none;font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);letter-spacing:0;">— the insight that would change a decision</span></label>
          </div>
          <%= f.text_area :key_insight, rows: 3,
                placeholder: "e.g. Why do volunteers drop off after month three?",
                style: "width:100%;background:#272D4A;border:1px solid rgba(255,255,255,0.1);border-radius:12px;padding:12px 16px;color:#fff;font-family:'ABeeZee',sans-serif;font-size: var(--text-lg);outline:none;resize:vertical;box-sizing:border-box;line-height:1.55;",
                onfocus: "this.style.borderColor='#{f3[:color]}80'",
                onblur:  "this.style.borderColor='rgba(255,255,255,0.1)'" %>
          <div style="display:flex;flex-wrap:wrap;gap:6px;margin-top:10px;">
            <% ["What's stopping people from accessing our food bank?", "Does our youth programme actually shift confidence — and where exactly?"].each do |ex| %>
              <span style="display:inline-flex;align-items:center;gap:6px;padding:5px 12px;border-radius:100px;border:1px solid rgba(255,255,255,0.08);background:rgba(255,255,255,0.03);font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.5);">
                <span style="font-family:'Alata',sans-serif;font-size: var(--text-2xs);color:rgba(255,255,255,0.3);letter-spacing:0.05em;text-transform:uppercase;">e.g.</span>
                <%= ex %>
              </span>
            <% end %>
          </div>
        </div>

        <%# ── Field 04 · Notes ── %>
        <% f4 = fields[3] %>
        <div style="background:rgba(39,45,74,0.4);border:1px solid rgba(255,255,255,0.06);border-radius:14px;padding:18px 20px;">
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;">
            <span style="font-family:'Alata',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.85);letter-spacing:0.08em;padding-bottom:2px;border-bottom:1px solid <%= f4[:color] %>;"><%= f4[:num] %></span>
            <span style="width:6px;height:6px;border-radius:50%;background:<%= f4[:color] %>;flex-shrink:0;"></span>
            <label style="font-family:'Alata',sans-serif;font-size: var(--text-xs);color:<%= f4[:color] %>;letter-spacing:0.12em;text-transform:uppercase;">Anything else we should know? <span style="color:rgba(255,255,255,0.45);text-transform:none;font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);letter-spacing:0;">— context, tone, must-asks</span></label>
            <span style="margin-left:auto;font-family:'Alata',sans-serif;font-size: var(--text-2xs);color:<%= f4[:color] %>;letter-spacing:0.14em;text-transform:uppercase;padding:3px 10px;border-radius:100px;background:<%= f4[:color] %>1A;border:1px solid <%= f4[:color] %>40;flex-shrink:0;">Optional</span>
          </div>
          <%= f.text_area :notes, rows: 4,
                placeholder: "e.g. Audience has never used Playverto before, keep tone warm, not corporate.",
                style: "width:100%;background:#272D4A;border:1px solid rgba(255,255,255,0.1);border-radius:12px;padding:12px 16px;color:#fff;font-family:'ABeeZee',sans-serif;font-size: var(--text-lg);outline:none;resize:vertical;box-sizing:border-box;line-height:1.55;",
                onfocus: "this.style.borderColor='#{f4[:color]}80'",
                onblur:  "this.style.borderColor='rgba(255,255,255,0.1)'" %>
          <div style="display:flex;flex-wrap:wrap;gap:6px;margin-top:10px;">
            <% ["Must include a question about funding routes and barriers to grants.", "We'll run this during our impact summit, so respondents are bought-in.", "Avoid jargon — many respondents speak English as a second language."].each do |ex| %>
              <span style="display:inline-flex;align-items:center;gap:6px;padding:5px 12px;border-radius:100px;border:1px solid rgba(255,255,255,0.08);background:rgba(255,255,255,0.03);font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.5);">
                <span style="font-family:'Alata',sans-serif;font-size: var(--text-2xs);color:rgba(255,255,255,0.3);letter-spacing:0.05em;text-transform:uppercase;">e.g.</span>
                <%= ex %>
              </span>
            <% end %>
          </div>
        </div>

        <div style="margin-top:4px;padding:16px;border-radius:12px;background:#272D4A;border:1px solid rgba(255,255,255,0.1);">
          <label style="display:flex;align-items:flex-start;gap:12px;cursor:pointer;">
            <%= f.check_box :show_results_comparison,
                  { checked: false,
                    style: "margin-top:3px;width:18px;height:18px;accent-color:#01EACB;cursor:pointer;flex-shrink:0;" },
                  "1", "0" %>
            <span>
              <span style="display:block;font-family:'Alata',sans-serif;font-size: var(--text-md);color:#fff;letter-spacing:0.02em;">
                Let respondents compare their answers
              </span>
              <span style="display:block;font-family:'ABeeZee',sans-serif;font-size: var(--text-base);color:rgba(255,255,255,0.5);margin-top:4px;line-height:1.5;">
                After they finish, show a CTA on the thank-you page that reveals how their answers stack up against everyone else's.
              </span>
            </span>
          </label>
        </div>

        <%= f.submit "Generate Verto →",
              style: "margin-top:8px;padding:13px 32px;border-radius:100px;background:#01EACB;color:#1C2034;font-family:'Alata',sans-serif;font-size: var(--text-xl);letter-spacing:0.05em;border:none;cursor:pointer;transition:background 0.15s;",
              onmouseover: "this.style.background='#00C4AB'",
              onmouseout:  "this.style.background='#01EACB'",
              data: { turbo_submits_with: "Generating…" } %>

      </div>
    <% end %>

    </div>
  </div>

</div>
