<div data-controller="generating" style="height:100%;display:flex;flex-direction:column;background:#1C2034;">

  <%# ── Generating overlay — hidden until form submits ── %>
  <div class="fixed inset-0 z-50 hidden flex-col overflow-hidden"
       style="background:#1C2034;"
       data-generating-target="overlay">

    <%# Floating brand-colour orbs %>
    <div class="gen-orbs">
      <div class="gen-orb gen-orb-1"></div>
      <div class="gen-orb gen-orb-2"></div>
      <div class="gen-orb gen-orb-3"></div>
      <div class="gen-orb gen-orb-4"></div>
    </div>

    <%# Nav %>
    <nav style="height:54px;background:rgba(28,32,52,0.6);backdrop-filter:blur(10px);border-bottom:1px solid rgba(255,255,255,0.08);flex-shrink:0;position:relative;z-index:1;"
         class="flex items-center justify-between px-9">
      <%= link_to root_path do %>
        <%= image_tag "playverto.svg", alt: "Playverto", class: "h-7 w-auto" %>
      <% end %>
      <span style="font-family:'ABeeZee',sans-serif;font-size: var(--text-md);color:rgba(255,255,255,0.45);">Create Verto</span>
      <span></span>
    </nav>

    <%# Body %>
    <div class="gen-stage flex-1 flex flex-col items-center justify-center gap-8 px-16 py-10">

      <div class="gen-shimmer"
           style="font-family:'Alata',sans-serif;font-size: var(--text-sm);text-transform:uppercase;letter-spacing:0.22em;font-weight:700;">
        Building your Verto
      </div>

      <div class="text-center" style="max-width:680px;">
        <div class="gen-hero-theme" data-generating-target="heroTheme"></div>
        <div style="font-family:'ABeeZee',sans-serif;font-size: var(--text-2xl);color:rgba(255,255,255,0.38);letter-spacing:-0.2px;line-height:1.5;margin-top:6px;"
             data-generating-target="heroAge"></div>
      </div>

      <div class="flex gap-2.5 flex-wrap justify-center">
        <div class="gen-pill">
          <div class="gen-pill-dot" style="background:#01EACB;"></div>
          <span class="gen-pill-label">Audience</span>
          <span data-generating-target="pillAudience"></span>
        </div>
        <div class="gen-pill">
          <div class="gen-pill-dot" style="background:#FF1E6F;"></div>
          <span class="gen-pill-label">Tone</span>
          <span>Conversational</span>
        </div>
        <div class="gen-pill">
          <div class="gen-pill-dot" style="background:#0CA7FF;"></div>
          <span class="gen-pill-label">Cards</span>
          <span>10–15</span>
        </div>
      </div>

      <div class="gen-insight" data-generating-target="insightText"></div>

      <div class="gen-steps-row">
        <div class="gen-step" data-state="done" data-generating-target="step1">
          <div class="step-dot">✓</div>
          <span>Brief read</span>
        </div>
        <div class="gen-step" data-state="active" data-generating-target="step2">
          <div class="step-dot"></div>
          <span>Writing questions</span>
        </div>
        <div class="gen-step" data-state="pending" data-generating-target="step3">
          <div class="step-dot"></div>
          <span>Picking formats</span>
        </div>
        <div class="gen-step" data-state="pending" data-generating-target="step4">
          <div class="step-dot"></div>
          <span>Applying design</span>
        </div>
      </div>

    </div>

    <div class="gen-rainbow-bar"></div>
  </div>

  <%# ── Wizard form ── %>
  <% if flash[:alert] %>
    <div style="margin:16px 24px 0;padding:12px 16px;border-radius:12px;background:rgba(255,30,111,0.1);color:#FF1E6F;border:1px solid rgba(255,30,111,0.3);font-family:'ABeeZee',sans-serif;font-size: var(--text-md);">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <%= form_with url: generate_survey_path, method: :post,
        data: { controller: "create-wizard",
                action: "submit->generating#show" },
        style: "display:flex;flex-direction:column;flex:1;min-height:0;" do |f| %>

    <%
      # Light-theme styles for inputs/chips inside the white card right-panel
      light_input_style = "width:100%;background:#fafbfc;border:1px solid rgba(0,0,0,0.12);border-radius:12px;padding:12px 16px;color:#000;font-family:'ABeeZee',sans-serif;font-size: var(--text-lg);outline:none;box-sizing:border-box;"
      light_textarea_style = "#{light_input_style};resize:vertical;line-height:1.55;"
      chip_style = "display:inline-flex;align-items:center;gap:6px;padding:5px 12px;border-radius:100px;border:1px solid rgba(0,0,0,0.08);background:rgba(0,0,0,0.025);font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(0,0,0,0.55);"
      chip_eg_style = "font-family:'Alata',sans-serif;font-size: var(--text-2xs);color:rgba(0,0,0,0.35);letter-spacing:0.05em;text-transform:uppercase;"
    %>

    <%# Card stage %>
    <div style="flex:1;display:flex;align-items:center;justify-content:center;padding:24px 16px;overflow:auto;min-height:0;">

      <%# ── Card 1 · Welcome ── %>
      <section class="preview-card active" data-create-wizard-target="card">
        <div class="split-card">
          <%= render "shared/split_left", card: { "type" => "welcome_card" }, progress: 5 %>
          <div class="split-right" style="text-align:left;justify-content:center;gap:12px;">
            <div class="q-eyebrow" style="color:#01EACB;">New Verto</div>
            <div style="font-family:'Alata',sans-serif;font-size:30px;line-height:1.15;color:#1C2034;">Let's build your Verto.</div>
            <p class="q-subtitle" style="margin:0;">Answer the four questions ahead — we'll turn your brief into a Verto that follows the Playverto rules.</p>
            <p style="font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(0,0,0,0.4);margin:0;">Press <strong style="color:rgba(0,0,0,0.6);">Next</strong> when you're ready.</p>
          </div>
        </div>
      </section>

      <%# ── Card 2 · Q01 Theme ── %>
      <section class="preview-card" data-create-wizard-target="card">
        <div class="split-card">
          <%= render "shared/split_left", card: { "type" => "multiple_choice" }, progress: 25 %>
          <div class="split-right" style="text-align:left;justify-content:center;gap:14px;">
            <div class="q-eyebrow" style="color:#FF1E6F;">Step 01 · About your Verto</div>
            <div class="q-title">What's your Verto about?</div>
            <p class="q-subtitle" style="margin:0;">The single overarching topic.</p>
            <%= f.text_field :theme,
                  required: true,
                  data: { required: "true" },
                  placeholder: "e.g. Youth wellbeing",
                  style: light_input_style,
                  onfocus: "this.style.borderColor='#FF1E6F'",
                  onblur:  "this.style.borderColor='rgba(0,0,0,0.12)'" %>
            <div style="display:flex;flex-wrap:wrap;gap:6px;">
              <% ["Climate action", "Refugee education", "Food security"].each do |ex| %>
                <span style="<%= chip_style %>">
                  <span style="<%= chip_eg_style %>">e.g.</span>
                  <%= ex %>
                </span>
              <% end %>
            </div>
          </div>
        </div>
      </section>

      <%# ── Card 3 · Q02 Audience ── %>
      <section class="preview-card" data-create-wizard-target="card">
        <div class="split-card">
          <%= render "shared/split_left", card: { "type" => "select_one_grid" }, progress: 50 %>
          <div class="split-right" style="text-align:left;justify-content:center;gap:14px;">
            <div class="q-eyebrow" style="color:#01EACB;">Step 02 · Who's answering</div>
            <div class="q-title">Who's answering — and what age are they?</div>
            <p class="q-subtitle" style="margin:0;">Be specific. Lifestyle, role, region all help.</p>
            <%= f.text_field :audience_age,
                  required: true,
                  data: { required: "true" },
                  placeholder: "e.g. 18–24 university students in Kenya",
                  style: light_input_style,
                  onfocus: "this.style.borderColor='#01EACB'",
                  onblur:  "this.style.borderColor='rgba(0,0,0,0.12)'" %>
            <div style="display:flex;flex-wrap:wrap;gap:6px;">
              <span style="<%= chip_style %>">
                <span style="<%= chip_eg_style %>">e.g.</span>
                35–55 frontline community-health workers
              </span>
            </div>
          </div>
        </div>
      </section>

      <%# ── Card 4 · Q03 Key insight ── %>
      <section class="preview-card" data-create-wizard-target="card">
        <div class="split-card">
          <%= render "shared/split_left", card: { "type" => "open_ended" }, progress: 75 %>
          <div class="split-right" style="text-align:left;justify-content:center;gap:14px;">
            <div class="q-eyebrow" style="color:#0CA7FF;">Step 03 · The learning goal</div>
            <div class="q-title">What do you want to learn from them?</div>
            <p class="q-subtitle" style="margin:0;">The insight that would change a decision.</p>
            <%= f.text_area :key_insight, rows: 3,
                  required: true,
                  data: { required: "true" },
                  placeholder: "e.g. Why do volunteers drop off after month three?",
                  style: light_textarea_style,
                  onfocus: "this.style.borderColor='#0CA7FF'",
                  onblur:  "this.style.borderColor='rgba(0,0,0,0.12)'" %>
            <div style="display:flex;flex-wrap:wrap;gap:6px;">
              <% ["What's stopping people from accessing our food bank?", "Does our youth programme actually shift confidence — and where exactly?"].each do |ex| %>
                <span style="<%= chip_style %>">
                  <span style="<%= chip_eg_style %>">e.g.</span>
                  <%= ex %>
                </span>
              <% end %>
            </div>
          </div>
        </div>
      </section>

      <%# ── Card 5 · Q04 Notes (optional) ── %>
      <section class="preview-card" data-create-wizard-target="card">
        <div class="split-card">
          <%= render "shared/split_left", card: { "type" => "tap_card" }, progress: 100 %>
          <div class="split-right" style="text-align:left;justify-content:center;gap:12px;">
            <div style="display:flex;align-items:center;justify-content:space-between;gap:10px;">
              <div class="q-eyebrow" style="color:#615BF5;">Step 04 · Context</div>
              <span style="font-family:'Alata',sans-serif;font-size: var(--text-2xs);color:#615BF5;letter-spacing:0.14em;text-transform:uppercase;padding:3px 10px;border-radius:100px;background:rgba(97,91,245,0.1);border:1px solid rgba(97,91,245,0.25);">Optional</span>
            </div>
            <div class="q-title">Anything else we should know?</div>
            <p class="q-subtitle" style="margin:0;">Context, tone, must-asks.</p>
            <%= f.text_area :notes, rows: 3,
                  placeholder: "e.g. Audience has never used Playverto before, keep tone warm, not corporate.",
                  style: light_textarea_style,
                  onfocus: "this.style.borderColor='#615BF5'",
                  onblur:  "this.style.borderColor='rgba(0,0,0,0.12)'" %>
            <div style="display:flex;flex-wrap:wrap;gap:6px;">
              <% ["Must include a question about funding routes and barriers to grants.", "Avoid jargon — many respondents speak English as a second language."].each do |ex| %>
                <span style="<%= chip_style %>">
                  <span style="<%= chip_eg_style %>">e.g.</span>
                  <%= ex %>
                </span>
              <% end %>
            </div>
            <label style="display:flex;align-items:flex-start;gap:10px;cursor:pointer;margin-top:4px;padding:10px 12px;border-radius:10px;background:rgba(0,0,0,0.03);border:1px solid rgba(0,0,0,0.06);">
              <%= f.check_box :show_results_comparison,
                    { checked: false,
                      style: "margin-top:2px;width:16px;height:16px;accent-color:#01EACB;cursor:pointer;flex-shrink:0;" },
                    "1", "0" %>
              <span>
                <span style="display:block;font-family:'Alata',sans-serif;font-size: var(--text-base);color:#1C2034;letter-spacing:0.02em;">
                  Let respondents compare their answers
                </span>
                <span style="display:block;font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(0,0,0,0.5);margin-top:2px;line-height:1.4;">
                  Show a CTA on the thank-you page that reveals how their answers stack up against everyone else's.
                </span>
              </span>
            </label>
          </div>
        </div>
      </section>

    </div>

    <%# Footer %>
    <div class="preview-footer">
      <button type="button" class="preview-btn preview-btn-back invisible"
              data-create-wizard-target="back"
              data-action="click->create-wizard#back">← Back</button>

      <span class="preview-progress-text" data-create-wizard-target="counter">Step 1 of 5</span>

      <button type="button" class="preview-btn preview-btn-next"
              data-create-wizard-target="next"
              data-action="click->create-wizard#next">Next →</button>

      <%= f.submit "Generate Verto →",
            class: "preview-btn preview-btn-finish hidden",
            data: { create_wizard_target: "finish", turbo_submits_with: "Generating…" } %>
    </div>

  <% end %>

</div>
