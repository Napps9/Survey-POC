<div data-controller="generating" style="height:100%;display:flex;flex-direction:column;background:#1C2034;">

  <%# ── Generating overlay — hidden until form submits ── %>
  <div class="fixed inset-0 z-50 hidden flex-col overflow-hidden"
       style="background:#1C2034;"
       data-generating-target="overlay">

    <%# Floating brand-colour orbs %>
    <div class="gen-orbs">
      <div class="gen-orb gen-orb-1"></div>
      <div class="gen-orb gen-orb-2"></div>
      <div class="gen-orb gen-orb-3"></div>
      <div class="gen-orb gen-orb-4"></div>
    </div>

    <%# Nav %>
    <nav style="height:54px;background:rgba(28,32,52,0.6);backdrop-filter:blur(10px);border-bottom:1px solid rgba(255,255,255,0.08);flex-shrink:0;position:relative;z-index:1;"
         class="flex items-center justify-between px-9">
      <%= link_to root_path do %>
        <%= image_tag "playverto.svg", alt: "Playverto", class: "h-7 w-auto" %>
      <% end %>
      <span style="font-family:'ABeeZee',sans-serif;font-size: var(--text-md);color:rgba(255,255,255,0.45);"><%= t("wizard.create_verto") %></span>
      <span></span>
    </nav>

    <%# Body %>
    <div class="gen-stage flex-1 flex flex-col items-center justify-center gap-8 px-16 py-10">

      <div class="gen-shimmer"
           style="font-family:'Alata',sans-serif;font-size: var(--text-sm);text-transform:uppercase;letter-spacing:0.22em;font-weight:700;">
        <%= t("wizard.building") %>
      </div>

      <div class="text-center" style="max-width:min(1040px,92vw);">
        <div class="gen-hero-theme" data-generating-target="heroTheme"></div>
        <div style="font-family:'ABeeZee',sans-serif;font-size: var(--text-2xl);color:rgba(255,255,255,0.38);letter-spacing:-0.2px;line-height:1.5;margin-top:6px;"
             data-generating-target="heroAge"></div>
      </div>

      <div class="flex gap-2.5 flex-wrap justify-center">
        <div class="gen-pill">
          <div class="gen-pill-dot" style="background:#01EACB;"></div>
          <span class="gen-pill-label"><%= t("wizard.pill_audience") %></span>
          <span data-generating-target="pillAudience"></span>
        </div>
        <div class="gen-pill">
          <div class="gen-pill-dot" style="background:#FF1E6F;"></div>
          <span class="gen-pill-label"><%= t("wizard.pill_tone") %></span>
          <span><%= t("wizard.pill_tone_value") %></span>
        </div>
        <div class="gen-pill">
          <div class="gen-pill-dot" style="background:#0CA7FF;"></div>
          <span class="gen-pill-label"><%= t("wizard.pill_cards") %></span>
          <span>10–15</span>
        </div>
      </div>

      <div class="gen-insight" data-generating-target="insightText"></div>

      <div class="gen-steps-row">
        <div class="gen-step" data-state="done" data-generating-target="step1">
          <div class="step-dot">✓</div>
          <span><%= t("wizard.gen_brief_read") %></span>
        </div>
        <div class="gen-step" data-state="active" data-generating-target="step2">
          <div class="step-dot"></div>
          <span><%= t("wizard.gen_writing") %></span>
        </div>
        <div class="gen-step" data-state="pending" data-generating-target="step3">
          <div class="step-dot"></div>
          <span><%= t("wizard.gen_formats") %></span>
        </div>
        <div class="gen-step" data-state="pending" data-generating-target="step4">
          <div class="step-dot"></div>
          <span><%= t("wizard.gen_design") %></span>
        </div>
      </div>

    </div>
  </div>

  <%# ── Wizard form ── %>
  <% if flash[:alert] %>
    <div style="margin:16px 24px 0;padding:12px 16px;border-radius:12px;background:rgba(255,30,111,0.1);color:#FF1E6F;border:1px solid rgba(255,30,111,0.3);font-family:'ABeeZee',sans-serif;font-size: var(--text-md);">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <%= form_with url: generate_survey_path, method: :post,
        html: { style: "display:flex;flex-direction:column;flex:1;min-height:0;" },
        data: { controller: "create-wizard",
                action: "submit->generating#show" } do |f| %>

    <%
      # Light-theme styles for inputs inside the white card right-panel
      light_input_style    = "width:100%;background:#fafbfc;border:1px solid rgba(0,0,0,0.12);border-radius:12px;padding:14px 18px;color:#000;font-family:'ABeeZee',sans-serif;font-size: var(--text-lg);outline:none;box-sizing:border-box;"
      light_textarea_style = "#{light_input_style};resize:vertical;line-height:1.55;"

      # Dark-theme styles for the instructions/examples left panel
      left_pad_style  = "position:absolute;inset:0;display:flex;flex-direction:column;justify-content:center;padding:80px 36px 48px;gap:18px;text-align:left;"
      eyebrow_style   = "font-family:'Alata',sans-serif;font-size: var(--text-2xs);letter-spacing:0.16em;text-transform:uppercase;font-weight:700;"
      instr_lead      = "font-family:'Alata',sans-serif;font-size: var(--text-xl);color:#fff;line-height:1.3;letter-spacing:-0.01em;"
      instr_body      = "font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.55);line-height:1.55;"
      ex_label_style  = "font-family:'Alata',sans-serif;font-size: var(--text-2xs);color:rgba(255,255,255,0.4);letter-spacing:0.14em;text-transform:uppercase;font-weight:700;"
      ex_item_style   = "font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.78);padding:9px 14px;border-radius:10px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);line-height:1.4;"
    %>

    <%# Card stage %>
    <div style="flex:1;display:flex;align-items:center;justify-content:center;padding:24px 16px;overflow:auto;min-height:0;">

      <%# ── Card 1 · Welcome ── %>
      <section class="preview-card active" data-create-wizard-target="card">
        <div class="split-card">
          <div class="split-left">
            <div class="panel-progress"><div class="panel-progress-fill" style="width:5%;"></div></div>
            <div style="<%= left_pad_style %>">
              <div style="<%= eyebrow_style %>color:#01EACB;"><%= t("wizard.welcome_eyebrow") %></div>
              <div style="<%= instr_lead %>"><%= t("wizard.welcome_lead") %></div>
              <div style="display:flex;flex-direction:column;gap:8px;margin-top:6px;">
                <% [ "#FF1E6F", "#01EACB", "#0CA7FF", "#01EACB", "#FFFA77", "#615BF5" ].each_with_index do |accent, i| %>
                  <div style="display:flex;align-items:center;gap:12px;padding:9px 14px;border-radius:10px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);">
                    <span style="font-family:'Alata',sans-serif;font-size: var(--text-xs);color:<%= accent %>;letter-spacing:0.08em;font-weight:700;"><%= format('%02d', i + 1) %></span>
                    <span style="font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.75);"><%= t("wizard.welcome_steps")[i] %></span>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
          <div class="split-right" style="justify-content:center;gap:14px;text-align:left;">
            <div class="q-eyebrow" style="color:#01EACB;"><%= t("wizard.welcome_badge") %></div>
            <div style="font-family:'Alata',sans-serif;font-size:30px;line-height:1.15;color:#1C2034;"><%= t("wizard.welcome_title") %></div>
            <p class="q-subtitle" style="margin:0;"><%= t("wizard.welcome_sub") %></p>
            <p style="font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(0,0,0,0.4);margin:0;"><%= t("wizard.welcome_ready_html") %></p>
          </div>
        </div>
      </section>

      <%# ── Card 2 · Q01 Theme ── %>
      <section class="preview-card" data-create-wizard-target="card">
        <div class="split-card">
          <div class="split-left">
            <div class="panel-progress"><div class="panel-progress-fill" style="width:25%;"></div></div>
            <div style="<%= left_pad_style %>">
              <div style="<%= eyebrow_style %>color:#FF1E6F;"><%= t("wizard.s1_eyebrow") %></div>
              <div style="<%= instr_lead %>"><%= t("wizard.s1_lead") %></div>
              <div style="<%= instr_body %>"><%= t("wizard.s1_body") %></div>
              <div style="display:flex;flex-direction:column;gap:10px;margin-top:6px;">
                <div style="<%= ex_label_style %>"><%= t("wizard.examples") %></div>
                <div style="display:flex;flex-direction:column;gap:6px;">
                  <% t("wizard.s1_examples").each do |ex| %>
                    <div style="<%= ex_item_style %>"><%= ex %></div>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
          <div class="split-right" style="justify-content:center;gap:16px;text-align:left;">
            <div class="q-eyebrow wizard-mobile-eyebrow" style="color:#FF1E6F;"><%= t("wizard.s1_eyebrow") %></div>
            <div class="q-title" style="font-size:28px;line-height:1.2;"><%= t("wizard.s1_title") %></div>
            <%= f.text_field :theme,
                  required: true,
                  data: { required: "true" },
                  placeholder: t("wizard.s1_placeholder"),
                  style: light_input_style,
                  onfocus: "this.style.borderColor='#FF1E6F'",
                  onblur:  "this.style.borderColor='rgba(0,0,0,0.12)'" %>
            <div class="wizard-mobile-hint">
              <p class="wizard-mobile-hint-lead"><%= t("wizard.s1_lead") %></p>
              <p class="wizard-mobile-hint-body"><%= t("wizard.s1_hint_body") %></p>
            </div>
          </div>
        </div>
      </section>

      <%# ── Card 3 · Q02 Audience ── %>
      <section class="preview-card" data-create-wizard-target="card">
        <div class="split-card">
          <div class="split-left">
            <div class="panel-progress"><div class="panel-progress-fill" style="width:50%;"></div></div>
            <div style="<%= left_pad_style %>">
              <div style="<%= eyebrow_style %>color:#01EACB;"><%= t("wizard.s2_eyebrow") %></div>
              <div style="<%= instr_lead %>"><%= t("wizard.s2_lead") %></div>
              <div style="<%= instr_body %>"><%= t("wizard.s2_body") %></div>
              <div style="display:flex;flex-direction:column;gap:10px;margin-top:6px;">
                <div style="<%= ex_label_style %>"><%= t("wizard.examples") %></div>
                <div style="display:flex;flex-direction:column;gap:6px;">
                  <% t("wizard.s2_examples").each do |ex| %>
                    <div style="<%= ex_item_style %>"><%= ex %></div>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
          <div class="split-right" style="justify-content:center;gap:16px;text-align:left;">
            <div class="q-eyebrow wizard-mobile-eyebrow" style="color:#01EACB;"><%= t("wizard.s2_eyebrow") %></div>
            <div class="q-title" style="font-size:28px;line-height:1.2;"><%= t("wizard.s2_title") %></div>
            <%= f.text_field :audience_age,
                  required: true,
                  data: { required: "true" },
                  placeholder: t("wizard.s2_placeholder"),
                  style: light_input_style,
                  onfocus: "this.style.borderColor='#01EACB'",
                  onblur:  "this.style.borderColor='rgba(0,0,0,0.12)'" %>
            <div class="wizard-mobile-hint">
              <p class="wizard-mobile-hint-lead"><%= t("wizard.s2_lead") %></p>
              <p class="wizard-mobile-hint-body"><%= t("wizard.s2_hint_body") %></p>
            </div>
          </div>
        </div>
      </section>

      <%# ── Card 4 · Q03 Key insight ── %>
      <section class="preview-card" data-create-wizard-target="card">
        <div class="split-card">
          <div class="split-left">
            <div class="panel-progress"><div class="panel-progress-fill" style="width:75%;"></div></div>
            <div style="<%= left_pad_style %>">
              <div style="<%= eyebrow_style %>color:#0CA7FF;"><%= t("wizard.s3_eyebrow") %></div>
              <div style="<%= instr_lead %>"><%= t("wizard.s3_lead") %></div>
              <div style="<%= instr_body %>"><%= t("wizard.s3_body") %></div>
              <div style="display:flex;flex-direction:column;gap:10px;margin-top:6px;">
                <div style="<%= ex_label_style %>"><%= t("wizard.examples") %></div>
                <div style="display:flex;flex-direction:column;gap:6px;">
                  <% t("wizard.s3_examples").each do |ex| %>
                    <div style="<%= ex_item_style %>"><%= ex %></div>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
          <div class="split-right" style="justify-content:center;gap:16px;text-align:left;">
            <div class="q-eyebrow wizard-mobile-eyebrow" style="color:#0CA7FF;"><%= t("wizard.s3_eyebrow") %></div>
            <div class="q-title" style="font-size:28px;line-height:1.2;"><%= t("wizard.s3_title") %></div>
            <%= f.text_area :key_insight, rows: 4,
                  required: true,
                  data: { required: "true" },
                  placeholder: t("wizard.s3_placeholder"),
                  style: light_textarea_style,
                  onfocus: "this.style.borderColor='#0CA7FF'",
                  onblur:  "this.style.borderColor='rgba(0,0,0,0.12)'" %>
            <div class="wizard-mobile-hint">
              <p class="wizard-mobile-hint-lead"><%= t("wizard.s3_lead") %></p>
              <p class="wizard-mobile-hint-body"><%= t("wizard.s3_hint_body") %></p>
            </div>
          </div>
        </div>
      </section>

      <%# ── Card 5 · Languages ── %>
      <section class="preview-card" data-create-wizard-target="card"
               data-controller="language-picker">
        <div class="split-card">
          <div class="split-left">
            <div class="panel-progress"><div class="panel-progress-fill" style="width:83%;"></div></div>
            <div style="<%= left_pad_style %>">
              <div style="<%= eyebrow_style %>color:#01EACB;"><%= t("wizard.s4_eyebrow") %></div>
              <div style="<%= instr_lead %>"><%= t("wizard.s4_lead") %></div>
              <div style="<%= instr_body %>"><%= t("wizard.s4_body") %></div>
              <div style="<%= ex_label_style %>margin-top:8px;"><span data-language-picker-target="summary"></span></div>
            </div>
          </div>
          <div class="split-right" style="justify-content:center;gap:16px;text-align:left;">
            <div class="q-eyebrow wizard-mobile-eyebrow" style="color:#01EACB;"><%= t("wizard.s4_eyebrow") %></div>
            <div class="q-title" style="font-size:28px;line-height:1.2;"><%= t("wizard.s4_title") %></div>

            <label style="display:flex;flex-direction:column;gap:6px;font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(0,0,0,0.55);">
              <%= t("wizard.s4_primary_label") %>
              <select name="default_locale"
                      data-language-picker-target="primary"
                      data-action="change->language-picker#syncPrimary"
                      style="<%= light_input_style %>">
                <% SupportedLocales.all.each do |loc| %>
                  <option value="<%= loc.code %>" <%= "selected" if loc.code == I18n.locale.to_s %>><%= loc.flag %> <%= loc.native_name %></option>
                <% end %>
              </select>
            </label>

            <div style="display:flex;flex-wrap:wrap;gap:8px;max-height:210px;overflow:auto;padding:2px;">
              <% SupportedLocales.all.each do |loc| %>
                <label class="lang-chip">
                  <input type="checkbox" name="locales[]" value="<%= loc.code %>"
                         data-language-picker-target="option"
                         data-action="change->language-picker#toggle"
                         <%= "checked" if loc.code == I18n.locale.to_s %> />
                  <span><%= loc.flag %> <%= loc.native_name %></span>
                </label>
              <% end %>
            </div>
          </div>
        </div>
      </section>

      <%# ── Card 6 · Q04 Notes (optional) ── %>
      <section class="preview-card" data-create-wizard-target="card">
        <div class="split-card">
          <div class="split-left">
            <div class="panel-progress"><div class="panel-progress-fill" style="width:86%;"></div></div>
            <div style="<%= left_pad_style %>">
              <div style="display:flex;align-items:center;gap:10px;">
                <div style="<%= eyebrow_style %>color:#615BF5;"><%= t("wizard.s6_eyebrow") %></div>
                <span style="font-family:'Alata',sans-serif;font-size: var(--text-2xs);color:#615BF5;letter-spacing:0.14em;text-transform:uppercase;font-weight:700;padding:3px 9px;border-radius:100px;background:rgba(97,91,245,0.14);border:1px solid rgba(97,91,245,0.3);"><%= t("wizard.optional") %></span>
              </div>
              <div style="<%= instr_lead %>"><%= t("wizard.s6_lead") %></div>
              <div style="<%= instr_body %>"><%= t("wizard.s6_body") %></div>
              <div style="display:flex;flex-direction:column;gap:10px;margin-top:6px;">
                <div style="<%= ex_label_style %>"><%= t("wizard.examples") %></div>
                <div style="display:flex;flex-direction:column;gap:6px;">
                  <% t("wizard.s6_examples").each do |ex| %>
                    <div style="<%= ex_item_style %>"><%= ex %></div>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
          <div class="split-right" style="justify-content:center;gap:14px;text-align:left;">
            <div class="q-eyebrow wizard-mobile-eyebrow" style="color:#615BF5;"><%= t("wizard.s6_eyebrow") %> · <%= t("wizard.optional") %></div>
            <div class="q-title" style="font-size:28px;line-height:1.2;"><%= t("wizard.s6_title") %></div>
            <%= f.text_area :notes, rows: 4,
                  placeholder: t("wizard.s6_placeholder"),
                  style: light_textarea_style,
                  onfocus: "this.style.borderColor='#615BF5'",
                  onblur:  "this.style.borderColor='rgba(0,0,0,0.12)'" %>
            <div class="wizard-mobile-hint">
              <p class="wizard-mobile-hint-lead"><%= t("wizard.s6_lead") %></p>
              <p class="wizard-mobile-hint-body"><%= t("wizard.s6_body") %></p>
            </div>
            <label style="display:flex;align-items:flex-start;gap:10px;cursor:pointer;margin-top:4px;padding:12px 14px;border-radius:12px;background:rgba(0,0,0,0.03);border:1px solid rgba(0,0,0,0.06);">
              <%= f.check_box :show_results_comparison,
                    { checked: false,
                      style: "margin-top:2px;width:16px;height:16px;accent-color:#01EACB;cursor:pointer;flex-shrink:0;" },
                    "1", "0" %>
              <span>
                <span style="display:block;font-family:'Alata',sans-serif;font-size: var(--text-base);color:#1C2034;letter-spacing:0.02em;">
                  <%= t("wizard.s6_compare_label") %>
                </span>
                <span style="display:block;font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(0,0,0,0.5);margin-top:2px;line-height:1.4;">
                  <%= t("wizard.s6_compare_desc") %>
                </span>
              </span>
            </label>
          </div>
        </div>
      </section>

      <%# ── Card 7 · Final touches: Brand colours + Populate vs Blank ── %>
      <%
        org_pal = current_organisation.brand_palette
        brand_roles = [
          ["primary", t("wizard.brand_primary"), t("wizard.brand_primary_desc")],
          ["cta",     t("wizard.brand_cta"),     t("wizard.brand_cta_desc")],
          ["bg",      t("wizard.brand_bg"),      t("wizard.brand_bg_desc")]
        ]
        section_label_style = "font-family:'Alata',sans-serif;font-size:11px;letter-spacing:0.18em;text-transform:uppercase;color:rgba(0,0,0,0.42);font-weight:700;"
      %>
      <section class="preview-card" data-create-wizard-target="card"
               data-controller="brand-palette">
        <div class="split-card">
          <div class="split-left">
            <div class="panel-progress"><div class="panel-progress-fill" style="width:100%;"></div></div>
            <div style="<%= left_pad_style %>gap:14px;">
              <div style="<%= eyebrow_style %>color:#FFFA77;"><%= t("wizard.s5_eyebrow") %></div>
              <div style="<%= instr_lead %>"><%= t("wizard.s5_lead") %></div>
              <div style="<%= instr_body %>"><%= t("wizard.s5_body") %></div>

              <%# Live mock — updates as colours are picked. Uses brand vars so
                  it falls back to Playverto's look for the default palette. %>
              <div data-brand-palette-target="preview"
                   style="margin-top:4px;border-radius:16px;padding:16px;display:flex;flex-direction:column;gap:11px;background:var(--brand-bg,#1C2034);box-shadow:0 10px 30px rgba(0,0,0,0.28);">
                <div style="font-family:'Alata',sans-serif;font-size:10px;letter-spacing:0.14em;text-transform:uppercase;color:var(--brand-primary,#01EACB);"><%= t("wizard.s5_live_preview") %></div>
                <div style="background:#fff;border-radius:12px;padding:13px 14px;display:flex;flex-direction:column;gap:8px;">
                  <div style="font-family:'Alata',sans-serif;font-size:9px;letter-spacing:0.1em;text-transform:uppercase;color:var(--brand-primary,#01EACB);"><%= t("wizard.s5_quick_poll") %></div>
                  <div style="font-family:'ABeeZee',sans-serif;font-size:14px;color:#111;line-height:1.3;"><%= t("wizard.s5_mock_q") %></div>
                  <div style="display:flex;align-items:center;gap:8px;padding:6px 9px;border-radius:8px;background:var(--brand-primary-soft,rgba(1,234,203,0.12));">
                    <span style="width:14px;height:14px;border-radius:50%;background:var(--brand-primary,#01EACB);flex-shrink:0;"></span>
                    <span style="font-family:'ABeeZee',sans-serif;font-size:12px;color:#111;"><%= t("wizard.s5_mock_opt") %></span>
                  </div>
                </div>
                <button type="button" tabindex="-1"
                        style="background:var(--brand-cta,#01EACB);color:var(--brand-cta-text,#1C2034);border:none;border-radius:100px;padding:9px;font-family:'ABeeZee',sans-serif;font-size:13px;cursor:default;"><%= t("wizard.next") %></button>
              </div>
            </div>
          </div>
          <div class="split-right" style="justify-content:center;gap:12px;text-align:left;">
            <div class="q-eyebrow wizard-mobile-eyebrow" style="color:#FFFA77;"><%= t("wizard.s5_eyebrow") %></div>
            <div class="q-title" style="font-size:24px;line-height:1.2;"><%= t("wizard.s5_title") %></div>

            <%# Section: How to start? — two side-by-side choice cards %>
            <div style="display:flex;flex-direction:column;gap:6px;">
              <div style="<%= section_label_style %>"><%= t("wizard.section_how_to_start") %></div>
              <div style="display:flex;gap:8px;">
                <% [
                  ["1", t("wizard.s7_populate_label"), t("wizard.s7_populate_desc"), t("wizard.s7_recommended")],
                  ["0", t("wizard.s7_blank_label"),    t("wizard.s7_blank_desc"),    nil]
                ].each_with_index do |(val, label, desc, badge), i| %>
                  <% selected = (i == 0) %>
                  <label class="populate-choice" style="flex:1;min-width:0;display:flex;flex-direction:column;gap:6px;cursor:pointer;padding:11px 12px;border-radius:12px;background:<%= selected ? 'rgba(255,30,111,0.04)' : '#fafbfc' %>;border:2px solid <%= selected ? '#FF1E6F' : 'rgba(0,0,0,0.08)' %>;transition:border-color 0.15s,background 0.15s;">
                    <input type="radio" name="populate_content" value="<%= val %>"
                           <%= "checked" if selected %>
                           style="position:absolute;width:1px;height:1px;opacity:0;pointer-events:none;"
                           onchange="this.closest('.preview-card').querySelectorAll('.populate-choice').forEach(el=>{el.style.borderColor='rgba(0,0,0,0.08)';el.style.background='#fafbfc';});this.closest('.populate-choice').style.borderColor='#FF1E6F';this.closest('.populate-choice').style.background='rgba(255,30,111,0.04)';" />
                    <span style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;">
                      <span style="font-family:'Alata',sans-serif;font-size:14px;color:#1C2034;letter-spacing:0.02em;line-height:1.2;"><%= label %></span>
                      <% if badge %>
                        <span style="font-family:'Alata',sans-serif;font-size:9px;color:#FF1E6F;letter-spacing:0.12em;text-transform:uppercase;font-weight:700;padding:1px 6px;border-radius:100px;background:rgba(255,30,111,0.1);border:1px solid rgba(255,30,111,0.25);"><%= badge %></span>
                      <% end %>
                    </span>
                    <span style="font-family:'ABeeZee',sans-serif;font-size:11px;color:rgba(0,0,0,0.55);line-height:1.4;"><%= desc %></span>
                  </label>
                <% end %>
              </div>
            </div>

            <%# Section: Brand colours %>
            <div style="display:flex;flex-direction:column;gap:6px;">
              <div style="<%= section_label_style %>"><%= t("wizard.section_brand_colours") %></div>
              <div style="display:flex;flex-direction:column;gap:8px;">
                <% brand_roles.each do |role, label, desc| %>
                  <div style="display:flex;align-items:center;gap:10px;">
                    <input type="color" name="brand_palette[<%= role %>]" value="<%= org_pal[role] %>"
                           data-brand-palette-target="colorInput" data-brand-role="<%= role %>"
                           data-action="input->brand-palette#onColor"
                           aria-label="<%= label %> colour"
                           style="width:34px;height:34px;border:1px solid rgba(0,0,0,0.12);border-radius:8px;background:none;cursor:pointer;padding:0;flex-shrink:0;" />
                    <div style="flex:1;min-width:0;">
                      <div style="font-family:'Alata',sans-serif;font-size:13px;color:#1C2034;line-height:1.2;"><%= label.html_safe %></div>
                      <div style="font-family:'ABeeZee',sans-serif;font-size:11px;color:rgba(0,0,0,0.45);line-height:1.3;"><%= desc.html_safe %></div>
                    </div>
                    <input type="text" value="<%= org_pal[role] %>"
                           data-brand-palette-target="hexInput" data-brand-role="<%= role %>"
                           data-action="input->brand-palette#onHex"
                           maxlength="7" spellcheck="false"
                           style="width:78px;background:#fafbfc;border:1px solid rgba(0,0,0,0.12);border-radius:8px;padding:7px 8px;color:#000;font-family:'ABeeZee',sans-serif;font-size:13px;outline:none;text-transform:uppercase;" />
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </section>

    </div>

    <%# Footer %>
    <div class="preview-footer">
      <button type="button" class="preview-btn preview-btn-back invisible"
              data-create-wizard-target="back"
              data-action="click->create-wizard#back"><%= t("wizard.back") %></button>

      <span class="preview-progress-text" data-create-wizard-target="counter"><%= t("wizard.step_counter", n: 1, total: 7) %></span>

      <button type="button" class="preview-btn preview-btn-next"
              data-create-wizard-target="next"
              data-action="click->create-wizard#next"><%= t("wizard.next") %></button>

      <%= f.submit t("wizard.generate"),
            class: "preview-btn preview-btn-finish hidden",
            data: { create_wizard_target: "finish", turbo_submits_with: t("wizard.generating") } %>
    </div>

  <% end %>

</div>
