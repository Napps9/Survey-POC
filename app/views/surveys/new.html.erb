<div data-controller="generating" style="height:100%;display:flex;flex-direction:column;background:#1C2034;">

  <%# ── Generating overlay — hidden until form submits ── %>
  <div class="fixed inset-0 z-50 hidden flex-col overflow-hidden"
       style="background:#1C2034;"
       data-generating-target="overlay">

    <%# Floating brand-colour orbs %>
    <div class="gen-orbs">
      <div class="gen-orb gen-orb-1"></div>
      <div class="gen-orb gen-orb-2"></div>
      <div class="gen-orb gen-orb-3"></div>
      <div class="gen-orb gen-orb-4"></div>
    </div>

    <%# Nav %>
    <nav style="height:54px;background:rgba(28,32,52,0.6);backdrop-filter:blur(10px);border-bottom:1px solid rgba(255,255,255,0.08);flex-shrink:0;position:relative;z-index:1;"
         class="flex items-center justify-between px-9">
      <%= link_to root_path do %>
        <%= image_tag "playverto.svg", alt: "Playverto", class: "h-7 w-auto" %>
      <% end %>
      <span style="font-family:'ABeeZee',sans-serif;font-size: var(--text-md);color:rgba(255,255,255,0.45);">Create Verto</span>
      <span></span>
    </nav>

    <%# Body %>
    <div class="gen-stage flex-1 flex flex-col items-center justify-center gap-8 px-16 py-10">

      <div class="gen-shimmer"
           style="font-family:'Alata',sans-serif;font-size: var(--text-sm);text-transform:uppercase;letter-spacing:0.22em;font-weight:700;">
        Building your Verto
      </div>

      <div class="text-center" style="max-width:680px;">
        <div class="gen-hero-theme" data-generating-target="heroTheme"></div>
        <div style="font-family:'ABeeZee',sans-serif;font-size: var(--text-2xl);color:rgba(255,255,255,0.38);letter-spacing:-0.2px;line-height:1.5;margin-top:6px;"
             data-generating-target="heroAge"></div>
      </div>

      <div class="flex gap-2.5 flex-wrap justify-center">
        <div class="gen-pill">
          <div class="gen-pill-dot" style="background:#01EACB;"></div>
          <span class="gen-pill-label">Audience</span>
          <span data-generating-target="pillAudience"></span>
        </div>
        <div class="gen-pill">
          <div class="gen-pill-dot" style="background:#FF1E6F;"></div>
          <span class="gen-pill-label">Tone</span>
          <span>Conversational</span>
        </div>
        <div class="gen-pill">
          <div class="gen-pill-dot" style="background:#0CA7FF;"></div>
          <span class="gen-pill-label">Cards</span>
          <span>10–15</span>
        </div>
      </div>

      <div class="gen-insight" data-generating-target="insightText"></div>

      <div class="gen-steps-row">
        <div class="gen-step" data-state="done" data-generating-target="step1">
          <div class="step-dot">✓</div>
          <span>Brief read</span>
        </div>
        <div class="gen-step" data-state="active" data-generating-target="step2">
          <div class="step-dot"></div>
          <span>Writing questions</span>
        </div>
        <div class="gen-step" data-state="pending" data-generating-target="step3">
          <div class="step-dot"></div>
          <span>Picking formats</span>
        </div>
        <div class="gen-step" data-state="pending" data-generating-target="step4">
          <div class="step-dot"></div>
          <span>Applying design</span>
        </div>
      </div>

    </div>

    <div class="gen-rainbow-bar"></div>
  </div>

  <%# ── Wizard form ── %>
  <% if flash[:alert] %>
    <div style="margin:16px 24px 0;padding:12px 16px;border-radius:12px;background:rgba(255,30,111,0.1);color:#FF1E6F;border:1px solid rgba(255,30,111,0.3);font-family:'ABeeZee',sans-serif;font-size: var(--text-md);">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <%= form_with url: generate_survey_path, method: :post,
        data: { controller: "create-wizard",
                action: "submit->generating#show" },
        style: "display:flex;flex-direction:column;flex:1;min-height:0;" do |f| %>

    <%
      # Light-theme styles for inputs inside the white card right-panel
      light_input_style    = "width:100%;background:#fafbfc;border:1px solid rgba(0,0,0,0.12);border-radius:12px;padding:14px 18px;color:#000;font-family:'ABeeZee',sans-serif;font-size: var(--text-lg);outline:none;box-sizing:border-box;"
      light_textarea_style = "#{light_input_style};resize:vertical;line-height:1.55;"

      # Dark-theme styles for the instructions/examples left panel
      left_pad_style  = "position:absolute;inset:0;display:flex;flex-direction:column;justify-content:center;padding:80px 36px 48px;gap:18px;text-align:left;"
      eyebrow_style   = "font-family:'Alata',sans-serif;font-size: var(--text-2xs);letter-spacing:0.16em;text-transform:uppercase;font-weight:700;"
      instr_lead      = "font-family:'Alata',sans-serif;font-size: var(--text-xl);color:#fff;line-height:1.3;letter-spacing:-0.01em;"
      instr_body      = "font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.55);line-height:1.55;"
      ex_label_style  = "font-family:'Alata',sans-serif;font-size: var(--text-2xs);color:rgba(255,255,255,0.4);letter-spacing:0.14em;text-transform:uppercase;font-weight:700;"
      ex_item_style   = "font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.78);padding:9px 14px;border-radius:10px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);line-height:1.4;"
    %>

    <%# Card stage %>
    <div style="flex:1;display:flex;align-items:center;justify-content:center;padding:24px 16px;overflow:auto;min-height:0;">

      <%# ── Card 1 · Welcome ── %>
      <section class="preview-card active" data-create-wizard-target="card">
        <div class="split-card">
          <div class="split-left">
            <div class="panel-progress"><div class="panel-progress-fill" style="width:5%;"></div></div>
            <div class="panel-tagline">Build the change</div>
            <div style="<%= left_pad_style %>">
              <div style="<%= eyebrow_style %>color:#01EACB;">What's coming up</div>
              <div style="<%= instr_lead %>">Four quick questions and we'll draft your Verto.</div>
              <div style="display:flex;flex-direction:column;gap:8px;margin-top:6px;">
                <% [
                     ["01", "About your Verto",       "#FF1E6F"],
                     ["02", "Who's answering",         "#01EACB"],
                     ["03", "What you want to learn",  "#0CA7FF"],
                     ["04", "Context (optional)",      "#615BF5"],
                   ].each do |num, label, accent| %>
                  <div style="display:flex;align-items:center;gap:12px;padding:9px 14px;border-radius:10px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);">
                    <span style="font-family:'Alata',sans-serif;font-size: var(--text-xs);color:<%= accent %>;letter-spacing:0.08em;font-weight:700;"><%= num %></span>
                    <span style="font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.75);"><%= label %></span>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
          <div class="split-right" style="justify-content:center;gap:14px;text-align:left;">
            <div class="q-eyebrow" style="color:#01EACB;">New Verto</div>
            <div style="font-family:'Alata',sans-serif;font-size:30px;line-height:1.15;color:#1C2034;">Let's build your Verto.</div>
            <p class="q-subtitle" style="margin:0;">We'll turn your brief into a Verto that follows the Playverto rules.</p>
            <p style="font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(0,0,0,0.4);margin:0;">Press <strong style="color:rgba(0,0,0,0.6);">Next</strong> when you're ready.</p>
          </div>
        </div>
      </section>

      <%# ── Card 2 · Q01 Theme ── %>
      <section class="preview-card" data-create-wizard-target="card">
        <div class="split-card">
          <div class="split-left">
            <div class="panel-progress"><div class="panel-progress-fill" style="width:25%;"></div></div>
            <div class="panel-tagline">Build the change</div>
            <div style="<%= left_pad_style %>">
              <div style="<%= eyebrow_style %>color:#FF1E6F;">Step 01 · About your Verto</div>
              <div style="<%= instr_lead %>">The single overarching topic.</div>
              <div style="<%= instr_body %>">Keep it broad — you'll narrow the angle in the next steps. One or two words is usually plenty.</div>
              <div style="display:flex;flex-direction:column;gap:10px;margin-top:6px;">
                <div style="<%= ex_label_style %>">Examples</div>
                <div style="display:flex;flex-direction:column;gap:6px;">
                  <% [ "Climate action", "Refugee education", "Food security" ].each do |ex| %>
                    <div style="<%= ex_item_style %>"><%= ex %></div>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
          <div class="split-right" style="justify-content:center;gap:16px;text-align:left;">
            <div class="q-eyebrow wizard-mobile-eyebrow" style="color:#FF1E6F;">Step 01 · About your Verto</div>
            <div class="q-title" style="font-size:28px;line-height:1.2;">What's your Verto about?</div>
            <%= f.text_field :theme,
                  required: true,
                  data: { required: "true" },
                  placeholder: "e.g. Youth wellbeing",
                  style: light_input_style,
                  onfocus: "this.style.borderColor='#FF1E6F'",
                  onblur:  "this.style.borderColor='rgba(0,0,0,0.12)'" %>
            <div class="wizard-mobile-hint">
              <p class="wizard-mobile-hint-lead">The single overarching topic.</p>
              <p class="wizard-mobile-hint-body">Keep it broad — you'll narrow the angle in the next steps.</p>
            </div>
          </div>
        </div>
      </section>

      <%# ── Card 3 · Q02 Audience ── %>
      <section class="preview-card" data-create-wizard-target="card">
        <div class="split-card">
          <div class="split-left">
            <div class="panel-progress"><div class="panel-progress-fill" style="width:50%;"></div></div>
            <div class="panel-tagline">Build the change</div>
            <div style="<%= left_pad_style %>">
              <div style="<%= eyebrow_style %>color:#01EACB;">Step 02 · Who's answering</div>
              <div style="<%= instr_lead %>">Be specific.</div>
              <div style="<%= instr_body %>">Lifestyle, role, region, language — anything that shapes how this group thinks. The more concrete, the better the questions we can write.</div>
              <div style="display:flex;flex-direction:column;gap:10px;margin-top:6px;">
                <div style="<%= ex_label_style %>">Examples</div>
                <div style="display:flex;flex-direction:column;gap:6px;">
                  <% [
                       "18–24 university students in Kenya",
                       "35–55 frontline community-health workers",
                       "Parents of school-age kids in rural NSW",
                     ].each do |ex| %>
                    <div style="<%= ex_item_style %>"><%= ex %></div>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
          <div class="split-right" style="justify-content:center;gap:16px;text-align:left;">
            <div class="q-eyebrow wizard-mobile-eyebrow" style="color:#01EACB;">Step 02 · Who's answering</div>
            <div class="q-title" style="font-size:28px;line-height:1.2;">Who's answering — and what age are they?</div>
            <%= f.text_field :audience_age,
                  required: true,
                  data: { required: "true" },
                  placeholder: "e.g. 18–24 university students in Kenya",
                  style: light_input_style,
                  onfocus: "this.style.borderColor='#01EACB'",
                  onblur:  "this.style.borderColor='rgba(0,0,0,0.12)'" %>
            <div class="wizard-mobile-hint">
              <p class="wizard-mobile-hint-lead">Be specific.</p>
              <p class="wizard-mobile-hint-body">Lifestyle, role, region, language — anything that shapes how this group thinks.</p>
            </div>
          </div>
        </div>
      </section>

      <%# ── Card 4 · Q03 Key insight ── %>
      <section class="preview-card" data-create-wizard-target="card">
        <div class="split-card">
          <div class="split-left">
            <div class="panel-progress"><div class="panel-progress-fill" style="width:75%;"></div></div>
            <div class="panel-tagline">Build the change</div>
            <div style="<%= left_pad_style %>">
              <div style="<%= eyebrow_style %>color:#0CA7FF;">Step 03 · The learning goal</div>
              <div style="<%= instr_lead %>">The insight that would change a decision.</div>
              <div style="<%= instr_body %>">Skip the things you already know. Aim for the one thing that, if you learned it, would shift what you do next.</div>
              <div style="display:flex;flex-direction:column;gap:10px;margin-top:6px;">
                <div style="<%= ex_label_style %>">Examples</div>
                <div style="display:flex;flex-direction:column;gap:6px;">
                  <% [
                       "Why do volunteers drop off after month three?",
                       "What's stopping people from accessing our food bank?",
                       "Does our youth programme actually shift confidence — and where exactly?",
                     ].each do |ex| %>
                    <div style="<%= ex_item_style %>"><%= ex %></div>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
          <div class="split-right" style="justify-content:center;gap:16px;text-align:left;">
            <div class="q-eyebrow wizard-mobile-eyebrow" style="color:#0CA7FF;">Step 03 · The learning goal</div>
            <div class="q-title" style="font-size:28px;line-height:1.2;">What do you want to learn from them?</div>
            <%= f.text_area :key_insight, rows: 4,
                  required: true,
                  data: { required: "true" },
                  placeholder: "e.g. Why do volunteers drop off after month three?",
                  style: light_textarea_style,
                  onfocus: "this.style.borderColor='#0CA7FF'",
                  onblur:  "this.style.borderColor='rgba(0,0,0,0.12)'" %>
            <div class="wizard-mobile-hint">
              <p class="wizard-mobile-hint-lead">The insight that would change a decision.</p>
              <p class="wizard-mobile-hint-body">Skip what you already know — aim for the one thing that would shift what you do next.</p>
            </div>
          </div>
        </div>
      </section>

      <%# ── Card 5 · Q04 Notes (optional) ── %>
      <section class="preview-card" data-create-wizard-target="card">
        <div class="split-card">
          <div class="split-left">
            <div class="panel-progress"><div class="panel-progress-fill" style="width:100%;"></div></div>
            <div class="panel-tagline">Build the change</div>
            <div style="<%= left_pad_style %>">
              <div style="display:flex;align-items:center;gap:10px;">
                <div style="<%= eyebrow_style %>color:#615BF5;">Step 04 · Context</div>
                <span style="font-family:'Alata',sans-serif;font-size: var(--text-2xs);color:#615BF5;letter-spacing:0.14em;text-transform:uppercase;font-weight:700;padding:3px 9px;border-radius:100px;background:rgba(97,91,245,0.14);border:1px solid rgba(97,91,245,0.3);">Optional</span>
              </div>
              <div style="<%= instr_lead %>">Anything else we should bake in?</div>
              <div style="<%= instr_body %>">Tone, must-asks, things to avoid, audience quirks. Skip if there's nothing extra.</div>
              <div style="display:flex;flex-direction:column;gap:10px;margin-top:6px;">
                <div style="<%= ex_label_style %>">Examples</div>
                <div style="display:flex;flex-direction:column;gap:6px;">
                  <% [
                       "Must include a question about funding routes and barriers to grants.",
                       "Avoid jargon — many respondents speak English as a second language.",
                       "Keep tone warm, not corporate.",
                     ].each do |ex| %>
                    <div style="<%= ex_item_style %>"><%= ex %></div>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
          <div class="split-right" style="justify-content:center;gap:14px;text-align:left;">
            <div class="q-eyebrow wizard-mobile-eyebrow" style="color:#615BF5;">Step 04 · Context · Optional</div>
            <div class="q-title" style="font-size:28px;line-height:1.2;">Anything else we should know?</div>
            <%= f.text_area :notes, rows: 4,
                  placeholder: "e.g. Audience has never used Playverto before, keep tone warm, not corporate.",
                  style: light_textarea_style,
                  onfocus: "this.style.borderColor='#615BF5'",
                  onblur:  "this.style.borderColor='rgba(0,0,0,0.12)'" %>
            <div class="wizard-mobile-hint">
              <p class="wizard-mobile-hint-lead">Anything else we should bake in?</p>
              <p class="wizard-mobile-hint-body">Tone, must-asks, things to avoid, audience quirks. Skip if there's nothing extra.</p>
            </div>
            <label style="display:flex;align-items:flex-start;gap:10px;cursor:pointer;margin-top:4px;padding:12px 14px;border-radius:12px;background:rgba(0,0,0,0.03);border:1px solid rgba(0,0,0,0.06);">
              <%= f.check_box :show_results_comparison,
                    { checked: false,
                      style: "margin-top:2px;width:16px;height:16px;accent-color:#01EACB;cursor:pointer;flex-shrink:0;" },
                    "1", "0" %>
              <span>
                <span style="display:block;font-family:'Alata',sans-serif;font-size: var(--text-base);color:#1C2034;letter-spacing:0.02em;">
                  Let respondents compare their answers
                </span>
                <span style="display:block;font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(0,0,0,0.5);margin-top:2px;line-height:1.4;">
                  Show a CTA on the thank-you page that reveals how their answers stack up against everyone else's.
                </span>
              </span>
            </label>
          </div>
        </div>
      </section>

    </div>

    <%# Footer %>
    <div class="preview-footer">
      <button type="button" class="preview-btn preview-btn-back invisible"
              data-create-wizard-target="back"
              data-action="click->create-wizard#back">← Back</button>

      <span class="preview-progress-text" data-create-wizard-target="counter">Step 1 of 5</span>

      <button type="button" class="preview-btn preview-btn-next"
              data-create-wizard-target="next"
              data-action="click->create-wizard#next">Next →</button>

      <%= f.submit "Generate Verto →",
            class: "preview-btn preview-btn-finish hidden",
            data: { create_wizard_target: "finish", turbo_submits_with: "Generating…" } %>
    </div>

  <% end %>

</div>
