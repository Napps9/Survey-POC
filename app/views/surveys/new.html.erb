<div class="max-w-2xl mx-auto p-6">
  <h1 class="text-3xl font-bold mb-2">AI Survey Generator</h1>
  <p class="text-gray-600 mb-6">
    Describe what you want to learn, and Claude will draft a survey for you.
  </p>

  <% if flash[:alert] %>
    <div class="mb-4 p-3 rounded bg-red-50 text-red-800 border border-red-200">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <%= form_with url: generate_survey_path, method: :post,
                data: { turbo_frame: "survey" }, class: "space-y-3" do |f| %>
    <%= f.text_area :prompt,
          rows: 4,
          placeholder: "e.g. Survey for new SaaS users about their onboarding experience",
          class: "w-full rounded border-gray-300 p-3 shadow-sm focus:ring focus:ring-indigo-200" %>
    <%= f.submit "Generate survey",
          class: "px-4 py-2 bg-indigo-600 text-white rounded hover:bg-indigo-700 cursor-pointer",
          data: { turbo_submits_with: "Generating…" } %>
  <% end %>

  <%= turbo_frame_tag "survey", class: "block mt-8" %>
</div>
