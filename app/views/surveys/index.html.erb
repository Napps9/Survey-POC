<% content_for :head do %>
  <style>body { overflow: auto !important; height: auto !important; }</style>
<% end %>
<%
  published = @surveys.select { |s| s.publish_token.present? }
  drafts    = @surveys.reject { |s| s.publish_token.present? }
  archived  = @archived_surveys || []

  total_responses_completed = Current.organisation.surveys.kept.joins(:responses).where(responses: { status: "completed" }).count rescue @total_responses
  completion_rate = @total_responses.to_i.positive? ? ((total_responses_completed.to_f / @total_responses) * 100).round : nil
%>

<div style="display:flex;min-height:100vh;background:#1C2034;">
  <div style="flex:1;display:flex;flex-direction:column;min-width:0;">

    <%# ── Hero ── %>
    <div style="position:relative;overflow:hidden;padding:48px 36px 44px;border-bottom:1px solid rgba(255,255,255,0.05);flex-shrink:0;">
      <div class="gen-orbs" style="opacity:0.35;">
        <div class="gen-orb gen-orb-1"></div>
        <div class="gen-orb gen-orb-2"></div>
        <div class="gen-orb gen-orb-3"></div>
        <div class="gen-orb gen-orb-4"></div>
      </div>

      <div style="position:relative;z-index:1;max-width:1100px;margin:0 auto;text-align:center;">
        <div style="display:inline-flex;align-items:center;gap:8px;margin-bottom:14px;">
          <span style="width:8px;height:8px;border-radius:50%;background:#01EACB;box-shadow:0 0 12px rgba(1,234,203,0.7);"></span>
          <span style="font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.45);letter-spacing:0.12em;text-transform:uppercase;">Welcome back</span>
        </div>
        <h1 style="font-family:'Alata',sans-serif;font-size:clamp(40px,5vw,56px);line-height:1.05;margin:0 0 14px;letter-spacing:-0.01em;">
          <span style="color:#fff;">Your </span><span class="gen-shimmer">Vertos</span>
        </h1>
        <p style="font-family:'ABeeZee',sans-serif;font-size: var(--text-lg);color:rgba(255,255,255,0.5);margin:0 auto 34px;max-width:540px;line-height:1.55;">
          Spin up Vertos, share them with your alliance, and watch the insights roll in.
        </p>

        <%# Stats — centred in page %>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:14px;max-width:880px;margin:0 auto;">
          <%
            stats = [
              { value: @surveys.size.to_s,         label: "Verto#{"s" if @surveys.size != 1}",            accent: "#01EACB", grad: "linear-gradient(135deg,rgba(1,234,203,0.18),rgba(1,234,203,0.04))" },
              { value: published.size.to_s,        label: "Live",                                          accent: "#FF1E6F", grad: "linear-gradient(135deg,rgba(255,30,111,0.18),rgba(255,30,111,0.04))" },
              { value: drafts.size.to_s,           label: "Draft#{"s" if drafts.size != 1}",               accent: "#0CA7FF", grad: "linear-gradient(135deg,rgba(12,167,255,0.18),rgba(12,167,255,0.04))" },
              { value: @total_responses.to_s,      label: "Response#{"s" if @total_responses != 1}",       accent: "#615BF5", grad: "linear-gradient(135deg,rgba(97,91,245,0.18),rgba(97,91,245,0.04))" },
              { value: completion_rate ? "#{completion_rate}%" : "—", label: "Completion",                  accent: "#FFFA77", grad: "linear-gradient(135deg,rgba(255,250,119,0.18),rgba(255,250,119,0.04))" },
            ]
          %>
          <% stats.each do |s| %>
            <div style="background:<%= s[:grad] %>;border:1px solid rgba(255,255,255,0.08);border-radius:18px;padding:18px 16px;text-align:center;backdrop-filter:blur(8px);">
              <div style="font-family:'Alata',sans-serif;font-size:36px;color:<%= s[:accent] %>;line-height:1;letter-spacing:-0.01em;"><%= s[:value] %></div>
              <div style="font-family:'ABeeZee',sans-serif;font-size: var(--text-2xs);color:rgba(255,255,255,0.5);margin-top:8px;letter-spacing:0.12em;text-transform:uppercase;"><%= s[:label] %></div>
            </div>
          <% end %>
        </div>

        <% if @surveys.any? %>
          <div style="margin-top:28px;">
            <%= link_to new_survey_path,
                  style: "display:inline-flex;align-items:center;gap:8px;background:#01EACB;border-radius:100px;padding:12px 24px;color:#1C2034;font-family:'Alata',sans-serif;font-size: var(--text-md);letter-spacing:0.04em;text-decoration:none;box-shadow:0 10px 28px rgba(1,234,203,0.25);" do %>
              <span style="font-size:18px;line-height:1;">+</span> Create a new Verto
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── Body ── %>
    <div style="flex:1;padding:32px 36px 60px;max-width:1320px;width:100%;margin:0 auto;box-sizing:border-box;">

      <% if flash[:notice] %>
        <div style="background:rgba(1,234,203,0.1);border:1px solid rgba(1,234,203,0.3);border-radius:10px;padding:11px 16px;margin-bottom:20px;color:#01EACB;font-family:'ABeeZee',sans-serif;font-size: var(--text-md);"><%= flash[:notice] %></div>
      <% end %>

      <% if @surveys.empty? && archived.empty? %>
        <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;padding:80px 32px;text-align:center;gap:20px;">
          <div>
            <div style="font-family:'Alata',sans-serif;font-size: var(--text-3xl);color:#fff;margin-bottom:8px;">No Vertos yet</div>
            <div style="font-family:'ABeeZee',sans-serif;font-size: var(--text-md);color:rgba(255,255,255,0.4);max-width:320px;line-height:1.6;">
              Create your first Verto and start collecting insights from your audience.
            </div>
          </div>
          <%= link_to "Create your first Verto →", new_survey_path,
                style: "padding:12px 26px;border-radius:100px;background:#01EACB;color:#1C2034;font-family:'ABeeZee',sans-serif;font-size: var(--text-md);text-decoration:none;" %>
        </div>

      <% else %>

        <%# ── Live section ── %>
        <% if published.any? %>
          <div style="margin-bottom:32px;">
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;">
              <span style="width:6px;height:6px;border-radius:50%;background:#FF1E6F;box-shadow:0 0 10px rgba(255,30,111,0.7);"></span>
              <span style="font-family:'Alata',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.5);letter-spacing:0.12em;text-transform:uppercase;">Live</span>
              <div style="flex:1;height:1px;background:rgba(255,255,255,0.06);"></div>
              <span style="font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.25);"><%= published.size %></span>
            </div>
            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:14px;">
              <% published.each do |survey| %>
                <%= render "surveys/dashboard_card", survey: survey %>
              <% end %>
            </div>
          </div>
        <% end %>

        <%# ── Drafts section ── %>
        <% if drafts.any? %>
          <div style="margin-bottom:32px;">
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;">
              <span style="width:6px;height:6px;border-radius:50%;background:#0CA7FF;box-shadow:0 0 10px rgba(12,167,255,0.6);"></span>
              <span style="font-family:'Alata',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.5);letter-spacing:0.12em;text-transform:uppercase;">Drafts</span>
              <div style="flex:1;height:1px;background:rgba(255,255,255,0.06);"></div>
              <span style="font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.25);"><%= drafts.size %></span>
            </div>
            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:14px;">
              <% drafts.each do |survey| %>
                <%= render "surveys/dashboard_card", survey: survey %>
              <% end %>
            </div>
          </div>
        <% end %>

        <%# ── Archived section ── %>
        <% if archived.any? %>
          <div>
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;">
              <span style="width:6px;height:6px;border-radius:50%;background:rgba(255,255,255,0.3);"></span>
              <span style="font-family:'Alata',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.35);letter-spacing:0.12em;text-transform:uppercase;">Archived</span>
              <div style="flex:1;height:1px;background:rgba(255,255,255,0.06);"></div>
              <span style="font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.25);"><%= archived.size %></span>
            </div>
            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:14px;">
              <% archived.each do |survey| %>
                <%= render "surveys/dashboard_card", survey: survey, archived: true %>
              <% end %>
            </div>
          </div>
        <% end %>

      <% end %>
    </div>

  </div>
</div>
