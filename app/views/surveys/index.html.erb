<% content_for :head do %>
  <style>body { overflow: auto !important; height: auto !important; }</style>
<% end %>
<%
  published = @surveys.select { |s| s.publish_token.present? }
  drafts    = @surveys.reject { |s| s.publish_token.present? }
%>

<div style="display:flex;min-height:100vh;background:#1C2034;">

  <%= render "shared/sidebar", active: "dashboard" %>

  <%# ── Main content ── %>
  <div style="flex:1;display:flex;flex-direction:column;min-width:0;">

    <%# ── Hero ── %>
    <div style="position:relative;overflow:hidden;padding:48px 36px 40px;border-bottom:1px solid rgba(255,255,255,0.05);flex-shrink:0;">
      <div class="gen-orbs" style="opacity:0.3;">
        <div class="gen-orb gen-orb-1"></div>
        <div class="gen-orb gen-orb-2"></div>
        <div class="gen-orb gen-orb-3"></div>
        <div class="gen-orb gen-orb-4"></div>
      </div>

      <div style="position:relative;z-index:1;">
        <div style="display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:24px;">

          <div>
            <div style="font-family:'ABeeZee',sans-serif;font-size:11px;color:rgba(255,255,255,0.3);letter-spacing:0.12em;text-transform:uppercase;margin-bottom:10px;">Welcome back</div>
            <h1 style="font-family:'Alata',sans-serif;font-size:38px;color:#fff;line-height:1.1;margin:0 0 8px;">
              Your Vertos
            </h1>
            <p style="font-family:'ABeeZee',sans-serif;font-size:14px;color:rgba(255,255,255,0.4);margin:0;max-width:400px;line-height:1.6;">
              Create engaging Vertos, share them with your audience,<br>and uncover insights — all in one place.
            </p>
          </div>

          <%# Stats strip %>
          <div style="display:flex;gap:1px;border-radius:14px;overflow:hidden;border:1px solid rgba(255,255,255,0.08);flex-shrink:0;">
            <% [
                 ["#{@surveys.size}",      "Verto#{"s" if @surveys.size != 1}",      "#272D4A"],
                 ["#{published.size}",     "Published",                               "#1a3d2a"],
                 ["#{drafts.size}",        "Draft#{"s" if drafts.size != 1}",         "#272D4A"],
                 ["#{@total_responses}",   "Response#{"s" if @total_responses != 1}", "#1a3d2a"],
               ].each do |num, label, bg| %>
              <div style="background:<%= bg %>;padding:16px 22px;text-align:center;">
                <div style="font-family:'Alata',sans-serif;font-size:26px;color:#01EACB;line-height:1;"><%= num %></div>
                <div style="font-family:'ABeeZee',sans-serif;font-size:10px;color:rgba(255,255,255,0.3);margin-top:3px;white-space:nowrap;"><%= label %></div>
              </div>
            <% end %>
          </div>

        </div>
      </div>
    </div>

    <%# ── Body ── %>
    <div style="flex:1;padding:28px 36px 60px;">

      <% if @surveys.empty? %>
        <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;padding:80px 32px;text-align:center;gap:20px;">
          <div>
            <div style="font-family:'Alata',sans-serif;font-size:22px;color:#fff;margin-bottom:8px;">No Vertos yet</div>
            <div style="font-family:'ABeeZee',sans-serif;font-size:13px;color:rgba(255,255,255,0.35);max-width:300px;line-height:1.6;">
              Create your first Verto and start collecting insights from your audience.
            </div>
          </div>
          <%= link_to "Create your first Verto →", new_survey_path,
                style: "padding:11px 26px;border-radius:100px;background:#01EACB;color:#1C2034;font-family:'ABeeZee',sans-serif;font-size:13px;text-decoration:none;" %>
        </div>

      <% else %>

        <%# ── Published section ── %>
        <% if published.any? %>
          <div style="margin-bottom:28px;">
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;">
              <span style="font-family:'Alata',sans-serif;font-size:11px;color:rgba(255,255,255,0.3);letter-spacing:0.1em;text-transform:uppercase;">Published</span>
              <div style="flex:1;height:1px;background:rgba(255,255,255,0.06);"></div>
              <span style="font-family:'ABeeZee',sans-serif;font-size:11px;color:rgba(255,255,255,0.2);"><%= published.size %></span>
            </div>
            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(270px,1fr));gap:12px;">
              <% published.each do |survey| %>
                <%= render "surveys/dashboard_card", survey: survey %>
              <% end %>
            </div>
          </div>
        <% end %>

        <%# ── Drafts section ── %>
        <% if drafts.any? %>
          <div>
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;">
              <span style="font-family:'Alata',sans-serif;font-size:11px;color:rgba(255,255,255,0.3);letter-spacing:0.1em;text-transform:uppercase;">Drafts</span>
              <div style="flex:1;height:1px;background:rgba(255,255,255,0.06);"></div>
              <span style="font-family:'ABeeZee',sans-serif;font-size:11px;color:rgba(255,255,255,0.2);"><%= drafts.size %></span>
            </div>
            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(270px,1fr));gap:12px;">
              <% drafts.each do |survey| %>
                <%= render "surveys/dashboard_card", survey: survey %>
              <% end %>
            </div>
          </div>
        <% end %>

      <% end %>
    </div>

  </div>
</div>
