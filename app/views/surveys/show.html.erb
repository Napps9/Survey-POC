<%
  cards   = Array(@survey.cards)
  total_q = cards.count { |c| c["type"] != "welcome_card" }
  q_idx   = 0
  est_min = [(total_q * 30 / 60.0).ceil, 1].max

  # Placeholder grid colours for left panel (6 cells, 2 cols × 3 rows)
  grid_colours = %w[choice-bg-1 choice-bg-2 choice-bg-3 choice-bg-4 choice-bg-5 choice-bg-6]
%>

<%# Single source of truth for card-type metadata, read by
    type_panel_controller at boot. Same data drives the Ruby helpers
    above. %>
<script id="card-types" type="application/json"><%= CardTypes.to_json.html_safe %></script>

<div class="results-rainbow flex flex-col h-screen"
     data-controller="type-panel preview-verto survey-editor media-picker"
     data-survey-editor-url-value="<%= survey_path(@survey) %>"
     data-survey-editor-title-value="<%= @survey.title %>"
     data-survey-editor-description-value="<%= @survey.description %>"
     data-action="type-panel:changed->survey-editor#markDirty card-editor:changed->survey-editor#markDirty input->survey-editor#markDirty">

  <%# Nav %>
  <nav style="height:54px;background:#1C2034;border-bottom:1px solid rgba(255,255,255,0.08);flex-shrink:0;"
       class="flex items-center justify-between px-9">
    <%= link_to root_path do %>
      <%= image_tag "playverto.svg", alt: "Playverto", class: "h-7 w-auto" %>
    <% end %>
    <span style="font-family:'ABeeZee',sans-serif;font-size:13px;color:rgba(255,255,255,0.45);">Editor</span>
    <%= link_to "← Dashboard", root_path,
          style: "font-family:'ABeeZee',sans-serif;font-size:12px;color:rgba(255,255,255,0.35);text-decoration:none;padding:6px 14px;border-radius:10px;border:1px solid rgba(255,255,255,0.1);transition:all 0.15s;",
          onmouseover: "this.style.color='rgba(255,255,255,0.7)';this.style.borderColor='rgba(255,255,255,0.25)'",
          onmouseout:  "this.style.color='rgba(255,255,255,0.35)';this.style.borderColor='rgba(255,255,255,0.1)'" %>
  </nav>

  <%# Main grid: cards feed | type panel %>
  <div class="flex-1 overflow-hidden" style="display:grid;grid-template-columns:1fr 444px;">

    <%# ── LEFT: Cards column ── %>
    <div class="flex flex-col overflow-hidden">

      <%# Brief strip %>
      <div class="brief-strip">
        <span style="color:rgba(255,255,255,0.85);font-weight:600;"><%= @survey.theme %></span>
        <span style="color:rgba(255,255,255,0.3);">·</span>
        <span style="color:rgba(255,255,255,0.85);font-weight:600;"><%= @survey.audience_age %></span>
        <span style="color:rgba(255,255,255,0.3);">·</span>
        <span style="color:rgba(255,255,255,0.35);font-size:11px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:340px;">
          <%= @survey.key_insight %>
        </span>
        <div class="brief-q-count"><%= total_q %> questions</div>
      </div>

      <%# Cards feed — stacked, full-width split-cards %>
      <div class="flex-1 overflow-y-auto p-5 flex flex-col gap-5"
           style="scrollbar-width:thin;scrollbar-color:rgba(255,255,255,0.08) transparent;">

        <% cards.each_with_index do |card, idx| %>
          <%
            type     = card["type"].to_s
            meta     = card_type_meta(type)
            is_q     = type != "welcome_card"
            q_idx   += 1 if is_q
            progress = total_q > 0 ? ((q_idx.to_f / total_q) * 100).round : 5
            progress = 5 if !is_q
            eyebrow  = CardTypes.eyebrow(type).presence || type.tr('_', ' ')
          %>

          <div class="survey-card-wrap"
               data-type-panel-target="card"
               data-survey-editor-target="card"
               data-card-type="<%= type %>"
               data-card-num="<%= idx + 1 %>"
               data-card-image="<%= card['image'].to_s %>"
               data-card-options="<%= Array(card['options']).to_json %>"
               data-action="click->type-panel#selectCard">

            <%# Chrome row above card %>
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;padding:0 4px;">
              <span class="s-badge <%= meta[:badge_css] %>"><%= meta[:badge] %></span>
              <span style="font-size:11px;color:rgba(255,255,255,0.3);">Card <%= idx + 1 %></span>
              <button type="button"
                      style="margin-left:auto;background:none;border:none;cursor:pointer;color:rgba(255,255,255,0.25);font-size:18px;padding:2px 6px;border-radius:4px;line-height:1;transition:color 0.2s;"
                      onmouseover="this.style.color='rgba(255,100,100,0.8)'"
                      onmouseout="this.style.color='rgba(255,255,255,0.25)'"
                      data-action="click->type-panel#deleteCard">×</button>
            </div>

            <%# Horizontal split-card %>
            <div class="split-card">
              <%= render "shared/split_left",     card: card, progress: progress, mode: :editor %>
              <%= render "shared/card_component", card: card, mode: :editor %>
            </div><%# /split-card %>
          </div><%# /survey-card-wrap %>
        <% end %>

      </div><%# /cards feed %>

      <%# Finalize bar %>
      <div class="finalize-bar">
        <div style="font-size:13px;color:rgba(255,255,255,0.45);">
          <strong style="color:#fff;" data-type-panel-target="cardCount"><%= cards.size %> cards</strong>
          &nbsp;·&nbsp; Estimated ~<%= est_min %> min<%= est_min != 1 ? "s" : "" %>
          &nbsp;·&nbsp; <span data-survey-editor-target="status" style="font-size:11px;"></span>
        </div>
        <div style="display:flex;gap:10px;align-items:center;">
          <button type="button"
                  style="padding:10px 22px;border-radius:16px;background:transparent;color:rgba(255,255,255,0.65);font-family:'ABeeZee',sans-serif;font-size:13px;border:1px solid rgba(255,255,255,0.15);cursor:pointer;transition:all 0.15s;"
                  onmouseover="this.style.color='#fff';this.style.borderColor='rgba(255,255,255,0.35)'"
                  onmouseout="this.style.color='rgba(255,255,255,0.65)';this.style.borderColor='rgba(255,255,255,0.15)'"
                  data-action="click->preview-verto#open">
            ▶ Preview Verto
          </button>
          <% if @survey.publish_token.present? %>
            <span style="font-family:'Alata',sans-serif;font-size:12px;color:#01EACB;">✓ Published</span>
            <input type="text" readonly
                   id="publish-url-<%= @survey.id %>"
                   value="<%= play_survey_url(@survey.publish_token) %>"
                   style="padding:8px 12px;border-radius:12px;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.15);color:rgba(255,255,255,0.7);font-family:'ABeeZee',sans-serif;font-size:11px;width:220px;outline:none;" />
            <button type="button"
                    onclick="navigator.clipboard.writeText(document.getElementById('publish-url-<%= @survey.id %>').value).then(()=>{this.textContent='Copied!';setTimeout(()=>this.textContent='Copy link',2000)})"
                    style="padding:8px 16px;border-radius:12px;background:transparent;color:rgba(255,255,255,0.65);font-family:'ABeeZee',sans-serif;font-size:12px;border:1px solid rgba(255,255,255,0.2);cursor:pointer;">
              Copy link
            </button>
            <%= link_to "View Results →", survey_results_path(@survey),
                  style: "padding:10px 22px;border-radius:16px;background:#01EACB;color:white;font-family:'ABeeZee',sans-serif;font-size:13px;text-decoration:none;transition:background 0.15s;",
                  onmouseover: "this.style.background='#00C4AB'",
                  onmouseout:  "this.style.background='#01EACB'" %>
          <% else %>
            <%= button_to "Publish Verto →", publish_survey_path(@survey),
                  method: :post,
                  style: "padding:10px 26px;border-radius:16px;background:#01EACB;color:white;font-family:'ABeeZee',sans-serif;font-size:13px;border:none;cursor:pointer;transition:background 0.15s;",
                  form: { style: "display:inline;" },
                  onmouseover: "this.style.background='#00C4AB'",
                  onmouseout:  "this.style.background='#01EACB'" %>
          <% end %>
        </div>
      </div>

    </div><%# /cards column %>

    <%# ── RIGHT: Answer type panel ── %>
    <div class="type-panel">

      <div class="type-panel-top">
        <div style="font-family:'Alata',sans-serif;font-size:11px;text-transform:uppercase;letter-spacing:0.1em;color:rgba(255,255,255,0.5);margin-bottom:5px;">
          Answer Type
        </div>
        <div style="font-family:'ABeeZee',sans-serif;font-size:14px;color:#FF1E6F;line-height:1.3;min-height:18px;"
             data-type-panel-target="panelCardName">Select a card to change its type</div>
        <div style="font-size:13px;color:rgba(255,255,255,0.6);margin-top:5px;line-height:1.45;"
             data-type-panel-target="panelHint">Click any card on the left.</div>
      </div>

      <div class="type-panel-empty" data-type-panel-target="panelEmpty">
        <div style="font-size:28px;opacity:0.25;">↖</div>
        <div style="font-size:14px;color:rgba(255,255,255,0.55);line-height:1.55;max-width:240px;">
          Select a question card to switch its answer format
        </div>
      </div>

      <div class="type-list" style="display:none;" data-type-panel-target="typeList">
        <% CardTypes.pickable.each do |key, t| %>
          <div class="type-opt"
               data-type="<%= key %>"
               data-type-panel-target="typeOpt"
               data-action="click->type-panel#setType">
            <div class="type-opt-preview">
              <%= mini_preview_html({ "type" => key, "options" => [] }) %>
            </div>
            <div class="type-opt-row">
              <div class="type-opt-icon"><%= t["picker_icon"] %></div>
              <div style="flex:1;min-width:0;">
                <div class="type-opt-name"><%= t["picker_name"] %></div>
                <div class="type-opt-desc"><%= t["picker_desc"] %></div>
              </div>
              <div class="type-opt-radio"></div>
            </div>
          </div>
        <% end %>
      </div>

      <div class="type-panel-footer" style="display:none;" data-type-panel-target="panelFooter">
        <button type="button"
                style="width:100%;padding:10px;border-radius:16px;background:#01EACB;color:white;font-family:'ABeeZee',sans-serif;font-size:13px;border:none;cursor:pointer;transition:background 0.15s;"
                onmouseover="this.style.background='#00C4AB'"
                onmouseout="this.style.background='#01EACB'"
                data-action="click->type-panel#applyType">Apply to this card</button>
        <button type="button"
                style="width:100%;padding:8px;border-radius:16px;background:transparent;color:rgba(255,255,255,0.4);font-family:'ABeeZee',sans-serif;font-size:12px;border:1px solid rgba(255,255,255,0.1);cursor:pointer;transition:all 0.15s;"
                onmouseover="this.style.color='#fff';this.style.borderColor='rgba(255,255,255,0.25)'"
                onmouseout="this.style.color='rgba(255,255,255,0.4)';this.style.borderColor='rgba(255,255,255,0.1)'"
                data-action="click->type-panel#applyAll">Apply to all cards</button>
      </div>

    </div><%# /type panel %>

  </div><%# /main grid %>

  <%# Toast %>
  <div class="toast-bar" data-type-panel-target="toast">
    <span style="display:inline-block;width:7px;height:7px;border-radius:50%;background:#01EACB;margin-right:7px;vertical-align:middle;"></span>
    <span data-type-panel-target="toastMsg"></span>
  </div>

  <%# ── Preview Verto overlay ── %>
  <div class="preview-overlay hidden"
       data-preview-verto-target="overlay">

    <%# Nav — respondents see the org's brand here, not Playverto's %>
    <nav class="preview-nav">
      <%= brand_logo_tag current_organisation, style: "height:24px;width:auto;max-width:160px;flex-shrink:0;" %>
      <span class="preview-nav-title">Preview Verto</span>
      <button type="button" class="preview-close-btn"
              data-action="click->preview-verto#close">✕ Close</button>
    </nav>

    <%# Card display area %>
    <div class="preview-body">

      <%# One preview-card div per survey card — only the active one is shown %>
      <%
        prev_q_idx = 0
        prev_total = cards.count { |c| c["type"] != "welcome_card" }
      %>
      <% cards.each_with_index do |pcard, pidx| %>
        <%
          ptype    = pcard["type"].to_s
          p_is_q   = ptype != "welcome_card"
          prev_q_idx += 1 if p_is_q
          pprogress = prev_total > 0 ? ((prev_q_idx.to_f / prev_total) * 100).round : 5
          pprogress = 5 unless p_is_q
        %>
        <div class="preview-card" data-preview-verto-target="card">
          <%= render "surveys/preview_card",
                card: pcard,
                progress: pprogress %>
        </div>
      <% end %>

      <%# Thank you screen — shown after Finish. "Powered by" is mentioned
          only once here, followed by the Playverto wordmark image. %>
      <div class="preview-thankyou" data-preview-verto-target="thankyou">
        <div class="preview-thankyou-emoji">🎉</div>
        <div class="preview-thankyou-title">Thank you!</div>
        <div class="preview-thankyou-sub">
          Your responses have been recorded.<br>Thanks for completing this Verto.
        </div>
        <div style="margin-top:14px;display:flex;align-items:center;justify-content:center;gap:8px;opacity:0.55;">
          <span style="font-family:'ABeeZee',sans-serif;font-size:11px;color:rgba(255,255,255,0.6);">Powered by</span>
          <%= image_tag "playverto.svg", alt: "", style: "height:14px;width:auto;" %>
        </div>
      </div>

    </div><%# /preview-body %>

    <%# Footer navigation %>
    <div class="preview-footer">
      <button type="button" class="preview-btn preview-btn-back"
              data-preview-verto-target="backBtn"
              data-action="click->preview-verto#back">← Back</button>

      <span class="preview-progress-text"
            data-preview-verto-target="progress"></span>

      <button type="button" class="preview-btn preview-btn-next"
              data-preview-verto-target="nextBtn"
              data-action="click->preview-verto#next">Next →</button>

      <button type="button" class="preview-btn preview-btn-finish hidden"
              data-preview-verto-target="finishBtn"
              data-action="click->preview-verto#finish">Finish ✓</button>

      <button type="button" class="preview-btn preview-btn-return hidden"
              data-preview-verto-target="returnBtn"
              data-action="click->preview-verto#returnToDesign">← Back to Design</button>
    </div>

  </div><%# /preview-overlay %>

  <%= render "surveys/media_modal" %>

</div><%# /results-rainbow %>
