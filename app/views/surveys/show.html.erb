<%
  cards   = Array(@survey.cards)
  total_q = cards.count { |c| c["type"] != "welcome_card" }
  q_idx   = 0
  est_min = [(total_q * 30 / 60.0).ceil, 1].max

  # Placeholder grid colours for left panel (6 cells, 2 cols × 3 rows)
  grid_colours = %w[choice-bg-1 choice-bg-2 choice-bg-3 choice-bg-4 choice-bg-5 choice-bg-6]
%>

<%# Single source of truth for card-type metadata, read by
    type_panel_controller at boot. Same data drives the Ruby helpers
    above. %>
<script id="card-types" type="application/json"><%= CardTypes.to_json.html_safe %></script>
<%# Lottie animation URLs for the NPS reactive scale, read by
    type_panel_controller when a card is switched to nps so the left-panel
    lottie-player can mount with the right asset paths. %>
<script id="nps-lottie-urls" type="application/json"><%= nps_lottie_urls.to_json.html_safe %></script>
<%# Full cards incl. per-language i18n — the editor's language tabs swap text
    from here without a server round-trip. %>
<script id="survey-cards-i18n" type="application/json"><%= Array(@survey.cards).to_json.html_safe %></script>

<div class="flex flex-col h-full"
     data-controller="type-panel preview-verto survey-editor media-picker publish-panel brand-palette add-question"
     data-survey-editor-url-value="<%= survey_path(@survey) %>"
     data-brand-palette-url-value="<%= survey_path(@survey) %>"
     data-media-picker-url-value="<%= survey_path(@survey) %>"
     data-add-question-generate-url-value="<%= generate_survey_card_path(@survey) %>"
     data-add-question-render-url-value="<%= render_survey_card_path(@survey) %>"
     data-survey-editor-title-value="<%= @survey.title %>"
     data-survey-editor-description-value="<%= @survey.description %>"
     data-survey-editor-default-locale-value="<%= @survey.default_locale %>"
     data-survey-editor-locales-value="<%= @survey.verto_locales.to_json %>"
     data-survey-editor-rtl-locales-value="<%= SupportedLocales.all.select(&:rtl?).map(&:code).to_json %>"
     data-action="type-panel:changed->survey-editor#markDirty card-editor:changed->survey-editor#markDirty input->survey-editor#markDirty type-panel:cardSelected->publish-panel#close">


  <%# Main grid: cards feed | type panel %>
  <div class="flex-1 overflow-hidden" style="display:grid;grid-template-columns:1fr 444px;">

    <%# ── LEFT: Cards column ── %>
    <div class="flex flex-col overflow-hidden">

      <% if @survey.publish_token.present? %>
        <div class="live-warning-overlay"
             data-controller="live-warning"
             data-action="click->live-warning#backdropClick">
          <div class="live-warning-modal">
            <div class="live-warning-head">
              <span class="live-warning-dot"></span>
              <strong><%= t("editor.live") %></strong>
              <button type="button" class="live-warning-close"
                      data-action="click->live-warning#dismiss" aria-label="Close">✕</button>
            </div>
            <div class="live-warning-body">
              <%= t("editor.live_warning") %>
            </div>
            <div class="live-warning-foot">
              <button type="button" class="live-warning-btn"
                      data-action="click->live-warning#dismiss"><%= t("editor.got_it") %></button>
            </div>
          </div>
        </div>
      <% end %>

      <%# Brief strip — also hosts the compact language switcher (right side) so
          the cards keep full height. Switching swaps the cards' language in
          place; structural edits stay locked to the primary language. %>
      <div class="brief-strip">
        <span style="color:rgba(255,255,255,0.85);font-weight:600;"><%= @survey.theme %></span>
        <span style="color:rgba(255,255,255,0.3);">·</span>
        <span style="color:rgba(255,255,255,0.85);font-weight:600;"><%= @survey.audience_age %></span>
        <span style="color:rgba(255,255,255,0.3);">·</span>
        <span style="color:rgba(255,255,255,0.55);font-size: var(--text-base);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:340px;">
          <%= @survey.key_insight %>
        </span>
        <div class="brief-q-count"><%= total_q %> <%= t("editor.questions") %></div>

        <% if @survey.multilingual? %>
          <% cur = SupportedLocales.find(@survey.default_locale) %>
          <div class="lang-dd" data-controller="locale-switcher">
            <button type="button" class="lang-dd-btn"
                    data-action="click->locale-switcher#toggle" aria-haspopup="true"
                    aria-label="<%= t("locale_switcher.label") %>">
              <span class="lang-dd-flag" data-survey-editor-target="localeFlag"><%= cur&.flag %></span>
              <span data-survey-editor-target="localeCode"><%= @survey.default_locale.upcase %></span>
              <svg class="lang-switcher-caret" width="10" height="6" viewBox="0 0 10 6" fill="none">
                <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="lang-dd-popover" data-locale-switcher-target="popover" hidden>
              <% @survey.verto_locales.each do |code| %>
                <% loc = SupportedLocales.find(code) %>
                <button type="button"
                        class="lang-dd-item<%= ' is-active' if code == @survey.default_locale %>"
                        data-survey-editor-target="tab"
                        data-locale="<%= code %>" data-flag="<%= loc&.flag %>" data-code="<%= code.upcase %>"
                        data-action="click->survey-editor#switchLocale click->locale-switcher#close">
                  <span class="lang-dd-item-flag"><%= loc&.flag %></span>
                  <span class="lang-dd-item-name"><%= loc&.native_name %></span>
                  <% if code == @survey.default_locale %><span class="lang-tab-primary"><%= t("editor.primary") %></span><% end %>
                  <span class="lang-dd-item-tick">✓</span>
                </button>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <%# Cards feed — stacked, full-width split-cards. The Verto's brand
          palette is scoped here so the cards render in brand colours while the
          surrounding editor chrome stays Playverto. %>
      <div class="flex-1 overflow-y-auto p-5 flex flex-col gap-5"
           data-brand-palette-target="preview"
           data-add-question-target="cardsFeed"
           data-survey-editor-target="feed"
           style="scrollbar-width:thin;scrollbar-color:rgba(255,255,255,0.08) transparent;background-color:var(--brand-bg,#272D4A);background-image:var(--brand-bg-image,none);background-size:cover;background-position:center;<%= verto_backdrop_style_attr(@survey) %>">

        <% cards.each_with_index do |card, idx| %>
          <%
            type   = card["type"].to_s
            is_q   = type != "welcome_card"
            q_idx += 1 if is_q
          %>
          <%= render "surveys/card_row", card: card, idx: idx, q_idx: q_idx, total_q: total_q,
                default_locale: @survey.default_locale %>
        <% end %>

        <%# "Add question" button — sits at bottom of the cards feed %>
        <div style="display:flex;justify-content:center;padding:4px 0 8px;">
          <button type="button"
                  class="aq-trigger-btn"
                  data-action="click->add-question#open">
            ＋ <%= t("editor.add_question") %>
          </button>
        </div>

      </div><%# /cards feed %>

      <%# Slim editor footer — survey facts on the left, single CTA on the right.
          All publish/share controls now live in the right-hand publish panel. %>
      <div class="finalize-bar">
        <div style="font-size: var(--text-md);color:rgba(255,255,255,0.65);display:flex;align-items:center;gap:14px;flex-wrap:wrap;">
          <span>
            <strong style="color:#fff;" data-type-panel-target="cardCount"><%= t("editor.cards", count: cards.size) %></strong>
            &nbsp;·&nbsp; <%= t("editor.estimated", count: est_min) %>
            &nbsp;·&nbsp; <span data-survey-editor-target="status" style="font-size: var(--text-sm);"></span>
          </span>
        </div>
        <div style="display:flex;gap:10px;align-items:center;">
          <%= button_to t("editor.shuffle"), shuffle_survey_assets_path(@survey),
                method: :post,
                form: { data: { turbo_confirm: t("editor.shuffle_confirm") } },
                title: t("editor.shuffle_title"),
                style: "padding:10px 22px;border-radius:16px;background:rgba(255,255,255,0.07);color:#fff;border:1px solid rgba(255,255,255,0.2);font-family:'ABeeZee',sans-serif;font-size: var(--text-md);cursor:pointer;transition:background 0.15s;",
                onmouseover: "this.style.background='rgba(255,255,255,0.12)'",
                onmouseout:  "this.style.background='rgba(255,255,255,0.07)'" %>
          <button type="button"
                  style="padding:10px 22px;border-radius:16px;background:rgba(255,255,255,0.07);color:#fff;border:1px solid rgba(255,255,255,0.2);font-family:'ABeeZee',sans-serif;font-size: var(--text-md);cursor:pointer;transition:background 0.15s;"
                  onmouseover="this.style.background='rgba(255,255,255,0.12)'"
                  onmouseout="this.style.background='rgba(255,255,255,0.07)'"
                  data-action="click->publish-panel#openDesign"><%= t("editor.design") %></button>
          <button type="button"
                  style="padding:10px 26px;border-radius:16px;background:#01EACB;color:#1C2034;font-family:'ABeeZee',sans-serif;font-size: var(--text-md);border:none;cursor:pointer;transition:background 0.15s;"
                  onmouseover="this.style.background='#00C4AB'"
                  onmouseout="this.style.background='#01EACB'"
                  data-action="click->publish-panel#open"><%= t("editor.publish_share") %></button>
        </div>
      </div>

    </div><%# /cards column %>

    <%# ── RIGHT: Answer type panel + Publish panel (toggled) ── %>
    <div class="right-column">
    <div class="type-panel" data-publish-panel-target="typeView">

      <div class="type-panel-top">
        <div style="font-family:'Alata',sans-serif;font-size: var(--text-sm);text-transform:uppercase;letter-spacing:0.1em;color:rgba(255,255,255,0.5);margin-bottom:5px;">
          <%= t("editor.answer_type") %>
        </div>
        <div style="font-family:'ABeeZee',sans-serif;font-size: var(--text-lg);color:#FF1E6F;line-height:1.3;min-height:18px;"
             data-type-panel-target="panelCardName"><%= t("editor.select_card") %></div>
        <div style="font-size: var(--text-md);color:rgba(255,255,255,0.75);margin-top:5px;line-height:1.45;"
             data-type-panel-target="panelHint"><%= t("editor.click_any") %></div>
      </div>

      <div class="type-panel-empty" data-type-panel-target="panelEmpty">
        <div style="font-size:28px;opacity:0.25;">↖</div>
        <div style="font-size: var(--text-lg);color:rgba(255,255,255,0.7);line-height:1.55;max-width:240px;">
          <%= t("editor.select_card_long") %>
        </div>
      </div>

      <div class="type-list" style="display:none;" data-type-panel-target="typeList">
        <% CardTypes.pickable.each do |key, t| %>
          <div class="type-opt-wrap">
            <div class="type-opt-rank"></div>
            <div class="type-opt"
                 data-type="<%= key %>"
                 data-type-panel-target="typeOpt"
                 data-action="click->type-panel#setType">
              <div class="type-opt-preview">
                <%= mini_preview_html({ "type" => key, "options" => [] }) %>
              </div>
              <div class="type-opt-row">
                <div class="type-opt-icon"><%= t["picker_icon"] %></div>
                <div style="flex:1;min-width:0;">
                  <div class="type-opt-name"><%= t["picker_name"] %></div>
                  <div class="type-opt-desc"><%= t["picker_desc"] %></div>
                </div>
                <div class="type-opt-radio"></div>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <div class="type-panel-footer" style="display:none;" data-type-panel-target="panelFooter">
        <button type="button"
                style="width:100%;padding:10px;border-radius:16px;background:#01EACB;color:#1C2034;font-family:'ABeeZee',sans-serif;font-size: var(--text-md);border:none;cursor:pointer;transition:background 0.15s;"
                onmouseover="this.style.background='#00C4AB'"
                onmouseout="this.style.background='#01EACB'"
                data-action="click->type-panel#applyType"><%= t("editor.apply_to_card") %></button>
        <button type="button"
                style="width:100%;padding:8px;border-radius:16px;background:transparent;color:rgba(255,255,255,0.65);font-family:'ABeeZee',sans-serif;font-size: var(--text-base);border:1px solid rgba(255,255,255,0.15);cursor:pointer;transition:all 0.15s;"
                onmouseover="this.style.color='#fff';this.style.borderColor='rgba(255,255,255,0.35)'"
                onmouseout="this.style.color='rgba(255,255,255,0.65)';this.style.borderColor='rgba(255,255,255,0.15)'"
                data-action="click->type-panel#openAllTypes"><%= t("editor.see_all_types") %></button>
      </div>

      <%# ── All question types modal ── %>
      <div class="all-types-overlay hidden"
           data-type-panel-target="allTypesModal"
           data-action="click->type-panel#closeAllTypes">
        <div class="all-types-modal" data-action="click->type-panel#stopPropagation">
          <div class="all-types-header">
            <div>
              <div style="font-family:'Alata',sans-serif;font-size: var(--text-sm);text-transform:uppercase;letter-spacing:0.1em;color:rgba(255,255,255,0.5);margin-bottom:4px;">
                <%= t("editor.all_types") %>
              </div>
              <div style="font-family:'ABeeZee',sans-serif;font-size: var(--text-xl);color:#fff;line-height:1.3;">
                <%= t("editor.ranked_for") %> <span data-type-panel-target="modalCardName" style="color:#FF1E6F;"><%= t("editor.this_card") %></span>
              </div>
            </div>
            <button type="button" class="all-types-close"
                    data-action="click->type-panel#closeAllTypes">✕</button>
          </div>
          <div class="all-types-grid" data-type-panel-target="allTypesList">
            <% CardTypes.pickable.each do |key, t| %>
              <div class="type-opt all-type-opt"
                   data-type="<%= key %>"
                   data-type-panel-target="allTypeOpt"
                   data-action="click->type-panel#applyTypeFromAll">
                <div class="type-opt-preview">
                  <%= mini_preview_html({ "type" => key, "options" => [] }) %>
                </div>
                <div class="type-opt-row">
                  <div class="type-opt-icon"><%= t["picker_icon"] %></div>
                  <div style="flex:1;min-width:0;">
                    <div class="type-opt-name"><%= t["picker_name"] %></div>
                    <div class="type-opt-desc"><%= t["picker_desc"] %></div>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>

    </div><%# /type panel %>

    <%# ── Publish & share panel (toggles in place of the answer-type panel) ── %>
    <div class="type-panel publish-panel hidden" data-publish-panel-target="publishView">

      <div class="type-panel-top">
        <button type="button" class="publish-panel-back"
                data-action="click->publish-panel#close">← Answer type</button>
        <div style="font-family:'Alata',sans-serif;font-size: var(--text-sm);text-transform:uppercase;letter-spacing:0.1em;color:rgba(255,255,255,0.5);margin-bottom:5px;margin-top:8px;">
          Publish &amp; share
        </div>
        <div style="font-family:'ABeeZee',sans-serif;font-size: var(--text-lg);color:#fff;line-height:1.3;">
          Preview, publish and distribute this Verto.
        </div>
      </div>

      <div class="publish-panel-body">

        <%# Preview %>
        <button type="button" class="publish-block-btn"
                data-action="click->preview-verto#open">▶ Preview Verto</button>

        <%# Publish status / link %>
        <div class="publish-block">
          <div class="publish-block-title">Status</div>
          <% if @survey.publish_token.present? %>
            <div style="font-family:'Alata',sans-serif;font-size: var(--text-md);color:#01EACB;margin-bottom:8px;">✓ Published</div>
            <input type="text" readonly
                   id="publish-url-<%= @survey.id %>"
                   value="<%= play_survey_url(@survey.publish_token) %>"
                   style="width:100%;padding:8px 12px;border-radius:10px;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.15);color:rgba(255,255,255,0.78);font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);outline:none;" />
            <div style="display:flex;gap:8px;margin-top:8px;">
              <button type="button"
                      onclick="navigator.clipboard.writeText(document.getElementById('publish-url-<%= @survey.id %>').value).then(()=>{this.textContent='Copied!';setTimeout(()=>this.textContent='Copy link',2000)})"
                      style="flex:1;padding:8px;border-radius:10px;background:transparent;color:rgba(255,255,255,0.78);font-family:'ABeeZee',sans-serif;font-size: var(--text-base);border:1px solid rgba(255,255,255,0.2);cursor:pointer;">Copy link</button>
              <%= link_to "View Results →", survey_results_path(@survey),
                    style: "flex:1;text-align:center;padding:8px;border-radius:10px;background:#01EACB;color:#1C2034;font-family:'ABeeZee',sans-serif;font-size: var(--text-base);text-decoration:none;" %>
            </div>
          <% else %>
            <div style="font-family:'Alata',sans-serif;font-size: var(--text-md);color:rgba(255,255,255,0.6);margin-bottom:10px;">Draft — not yet published</div>
            <%= button_to "Publish Verto →", publish_survey_path(@survey),
                  method: :post,
                  style: "width:100%;padding:10px;border-radius:12px;background:#01EACB;color:#1C2034;font-family:'ABeeZee',sans-serif;font-size: var(--text-md);border:none;cursor:pointer;",
                  form: { style: "margin:0;" } %>
          <% end %>
        </div>

        <%# Results comparison toggle %>
        <div class="publish-block">
          <div class="publish-block-title">Respondent view</div>
          <%= form_with url: survey_settings_path(@survey), method: :post, local: true,
                style: "margin:0;" do %>
            <input type="hidden" name="show_results_comparison" value="0" />
            <label style="display:flex;align-items:flex-start;gap:10px;cursor:pointer;font-size: var(--text-base);color:rgba(255,255,255,0.78);line-height:1.4;">
              <input type="checkbox" name="show_results_comparison" value="1"
                     <%= "checked" if @survey.show_results_comparison? %>
                     onchange="this.form.requestSubmit()"
                     style="width:14px;height:14px;accent-color:#01EACB;cursor:pointer;margin-top:1px;flex-shrink:0;" />
              <span>Show results comparison to respondents after they finish.</span>
            </label>
          <% end %>
        </div>

        <%# Alliance share — add this Verto to an alliance and generate
            per-partner links. Each row in the alliance produces a unique token. %>
        <% if current_membership&.admin? %>
          <% all_alliances   = current_organisation.alliances.order(:name) %>
          <% shared_in       = AllianceVerto.where(survey_id: @survey.id, alliance_id: all_alliances.map(&:id)).pluck(:alliance_id).to_set %>
          <% available_allys = all_alliances.reject { |a| shared_in.include?(a.id) } %>
          <% in_alliances    = all_alliances.select { |a| shared_in.include?(a.id) } %>
          <div class="publish-block">
            <div class="publish-block-title">Share with an alliance</div>
            <div style="font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.55);margin-bottom:10px;line-height:1.45;">
              Add this Verto to an alliance. Each partner in the alliance gets their own unique share link, and you'll see each one's responses separately.
            </div>
            <% if all_alliances.empty? %>
              <%= link_to "Create an alliance →", new_alliance_path,
                    style: "display:inline-block;background:rgba(1,234,203,0.12);border:1px solid rgba(1,234,203,0.35);border-radius:10px;padding:7px 14px;color:#01EACB;font-family:'ABeeZee',sans-serif;font-size: var(--text-base);text-decoration:none;" %>
            <% elsif available_allys.empty? %>
              <span style="font-family:'ABeeZee',sans-serif;font-size: var(--text-base);color:rgba(255,255,255,0.4);">Already in every alliance you run.</span>
            <% else %>
              <%= form_with url: alliance_alliance_vertos_path(available_allys.first), method: :post,
                    data: { turbo: false },
                    html: { id: "add-to-alliance-form" },
                    style: "display:flex;flex-direction:column;gap:8px;margin:0;" do |f| %>
                <%= hidden_field_tag :survey_id, @survey.id %>
                <select name="alliance_picker"
                        onchange="document.getElementById('add-to-alliance-form').action = '/alliances/' + this.value + '/alliance_vertos'"
                        style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.12);border-radius:10px;padding:8px 10px;color:rgba(255,255,255,0.85);font-family:'ABeeZee',sans-serif;font-size: var(--text-base);">
                  <% available_allys.each do |a| %>
                    <option value="<%= a.id %>" style="background:#1C2034;color:#fff;"><%= a.name %></option>
                  <% end %>
                </select>
                <%= f.submit "Add to alliance →",
                      style: "background:rgba(1,234,203,0.12);border:1px solid rgba(1,234,203,0.35);border-radius:10px;padding:8px;color:#01EACB;font-family:'ABeeZee',sans-serif;font-size: var(--text-base);cursor:pointer;" %>
              <% end %>
            <% end %>
            <% if in_alliances.any? %>
              <div style="display:flex;flex-direction:column;gap:6px;margin-top:12px;">
                <% in_alliances.each do |a| %>
                  <%= link_to alliance_path(a),
                        style: "display:flex;align-items:center;justify-content:space-between;gap:6px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);border-radius:10px;padding:9px 11px;text-decoration:none;" do %>
                    <span style="font-family:'Alata',sans-serif;font-size: var(--text-base);color:rgba(255,255,255,0.78);"><%= a.name %></span>
                    <span style="font-family:'ABeeZee',sans-serif;font-size: var(--text-xs);color:rgba(255,255,255,0.5);">Manage →</span>
                  <% end %>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>

      </div><%# /publish-panel-body %>

    </div><%# /publish panel %>

    <%# ── Design panel: colours, background and logo (toggles in place of the answer-type panel) ── %>
    <div class="type-panel hidden" data-publish-panel-target="designView">

      <div class="type-panel-top">
        <button type="button" class="publish-panel-back"
                data-action="click->publish-panel#close">← Answer type</button>
        <div style="font-family:'Alata',sans-serif;font-size: var(--text-sm);text-transform:uppercase;letter-spacing:0.1em;color:rgba(255,255,255,0.5);margin-bottom:5px;margin-top:8px;">
          Design
        </div>
        <div style="font-family:'ABeeZee',sans-serif;font-size: var(--text-lg);color:#fff;line-height:1.3;">
          Colours, background and logo for this Verto.
        </div>
      </div>

      <div class="publish-panel-body">

        <%# Brand colours — edits THIS Verto's palette (not other Vertos). %>
        <div class="publish-block">
          <div class="publish-block-title">Brand colours</div>
          <div style="font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.55);margin-bottom:12px;line-height:1.45;">
            Applied to this Verto's cards, preview and player. Changes here don't affect your other Vertos.
          </div>
          <% pal = @survey.brand_palette %>
          <% [["primary", "Primary", "Headings &amp; accents"],
              ["cta",     "Buttons (CTA)", "Next / Submit buttons"],
              ["bg",      "Background", "The canvas behind cards"]].each do |role, label, desc| %>
            <div style="display:flex;align-items:center;gap:11px;margin-bottom:10px;">
              <input type="color" value="<%= pal[role] %>"
                     data-brand-palette-target="colorInput" data-brand-role="<%= role %>"
                     data-action="input->brand-palette#onColor"
                     aria-label="<%= label %> colour"
                     style="width:36px;height:36px;border:none;border-radius:9px;background:none;cursor:pointer;padding:0;flex-shrink:0;" />
              <div style="flex:1;min-width:0;">
                <div style="font-family:'Alata',sans-serif;font-size: var(--text-base);color:#fff;line-height:1.2;"><%= label.html_safe %></div>
                <div style="font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.45);"><%= desc.html_safe %></div>
              </div>
              <input type="text" value="<%= pal[role] %>"
                     data-brand-palette-target="hexInput" data-brand-role="<%= role %>"
                     data-action="input->brand-palette#onHex"
                     maxlength="7" spellcheck="false"
                     style="width:86px;padding:7px 9px;border-radius:9px;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.15);color:rgba(255,255,255,0.85);font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);outline:none;text-transform:uppercase;" />
            </div>
          <% end %>
          <div data-brand-palette-target="status"
               style="font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.4);min-height:16px;margin-top:2px;"></div>

          <%# Background image — fills the backdrop behind the whole Verto. %>
          <div style="margin-top:14px;padding-top:14px;border-top:1px solid rgba(255,255,255,0.08);">
            <div style="font-family:'Alata',sans-serif;font-size: var(--text-base);color:#fff;line-height:1.2;">Background image</div>
            <div style="font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.45);margin:3px 0 10px;line-height:1.45;">Optional — sits behind every card, over the background colour.</div>
            <div style="display:flex;align-items:center;gap:11px;">
              <div data-media-picker-target="bgThumb"
                   style="width:54px;height:54px;border-radius:9px;flex-shrink:0;background-color:rgba(255,255,255,0.06);background-size:cover;background-position:center;border:1px solid rgba(255,255,255,0.12);<%= "background-image:url('#{@survey.background_image.to_s.gsub(/['\"]/, '')}');".html_safe if @survey.background_image.present? %>"></div>
              <button type="button"
                      data-action="click->media-picker#openBackground"
                      style="flex:1;padding:9px;border-radius:10px;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.15);color:rgba(255,255,255,0.85);font-family:'ABeeZee',sans-serif;font-size: var(--text-base);cursor:pointer;">Choose image</button>
              <button type="button"
                      data-media-picker-target="bgRemoveBtn"
                      data-action="click->media-picker#removeBackground"
                      <%= "hidden" unless @survey.background_image.present? %>
                      style="padding:9px 12px;border-radius:10px;background:transparent;border:1px solid rgba(255,255,255,0.15);color:rgba(255,255,255,0.55);font-family:'ABeeZee',sans-serif;font-size: var(--text-base);cursor:pointer;">Remove</button>
            </div>
          </div>
        </div>

        <%# Logo — the organisation's logo, shown across all its Vertos. %>
        <div class="publish-block" data-controller="logo-uploader"
             data-logo-uploader-url-value="<%= organisation_path(current_organisation) %>"
             data-logo-uploader-fallback-value="<%= image_path('playverto.svg') %>">
          <div class="publish-block-title">Logo</div>
          <div style="font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.55);margin-bottom:12px;line-height:1.45;">
            Shown at the top of every Verto preview and shared play link. Applies across your organisation.
          </div>
          <div style="display:flex;align-items:center;gap:11px;">
            <div data-logo-uploader-target="preview"
                 style="height:48px;min-width:90px;display:flex;align-items:center;justify-content:center;padding:6px 12px;border-radius:9px;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.12);flex-shrink:0;">
              <%= brand_logo_tag current_organisation, style: "height:30px;width:auto;max-width:150px;" %>
            </div>
            <% if current_membership&.admin? %>
              <button type="button" class="publish-block-btn" style="flex:1;"
                      data-action="click->logo-uploader#choose">Upload logo</button>
              <button type="button"
                      data-logo-uploader-target="removeBtn"
                      data-action="click->logo-uploader#remove"
                      <%= "hidden" unless current_organisation.logo.attached? %>
                      style="padding:9px 12px;border-radius:10px;background:transparent;border:1px solid rgba(255,255,255,0.15);color:rgba(255,255,255,0.55);font-family:'ABeeZee',sans-serif;font-size: var(--text-base);cursor:pointer;">Remove</button>
              <input type="file" hidden accept="image/png,image/jpeg,image/svg+xml,image/webp"
                     data-logo-uploader-target="input"
                     data-action="change->logo-uploader#upload" />
            <% end %>
          </div>
          <% if current_membership&.admin? %>
            <div data-logo-uploader-target="status"
                 style="font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.4);min-height:16px;margin-top:8px;"></div>
            <div style="font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.3);margin-top:2px;">
              PNG, JPG, SVG or WebP · transparent backgrounds work best.
            </div>
          <% else %>
            <div style="font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.35);margin-top:8px;">
              Ask an organisation admin to change the logo.
            </div>
          <% end %>
        </div>

      </div><%# /design panel body %>

    </div><%# /design panel %>

    </div><%# /right column %>

  </div><%# /main grid %>

  <%# Toast %>
  <div class="toast-bar" data-type-panel-target="toast">
    <span style="display:inline-block;width:7px;height:7px;border-radius:50%;background:#01EACB;margin-right:7px;vertical-align:middle;"></span>
    <span data-type-panel-target="toastMsg"></span>
  </div>

  <%# ── Preview Verto overlay ── %>
  <div class="preview-overlay hidden"
       data-preview-verto-target="overlay"
       data-brand-palette-target="preview"
       style="<%= verto_backdrop_style_attr(@survey) %>">

    <%# Nav — respondents see the org's brand here, not Playverto's %>
    <nav class="preview-nav">
      <%= brand_logo_tag current_organisation, style: "height:24px;width:auto;max-width:160px;flex-shrink:0;" %>
      <span class="preview-nav-title">Preview Verto</span>
      <button type="button" class="preview-close-btn"
              data-action="click->preview-verto#close">✕ Close</button>
    </nav>

    <%# Card display area %>
    <div class="preview-body">

      <%# One preview-card div per survey card — only the active one is shown %>
      <%
        prev_q_idx = 0
        prev_total = cards.count { |c| c["type"] != "welcome_card" }
      %>
      <% cards.each_with_index do |pcard, pidx| %>
        <%
          ptype    = pcard["type"].to_s
          p_is_q   = ptype != "welcome_card"
          prev_q_idx += 1 if p_is_q
          pprogress = prev_total > 0 ? ((prev_q_idx.to_f / prev_total) * 100).round : 5
          pprogress = 5 unless p_is_q
        %>
        <div class="preview-card" data-preview-verto-target="card">
          <%= render "surveys/preview_card",
                card: pcard,
                progress: pprogress,
                default_locale: @survey.default_locale %>
        </div>
      <% end %>

      <%# Thank you screen — shown after Finish. "Powered by" is mentioned
          only once here, followed by the Playverto wordmark image. %>
      <div class="preview-thankyou" data-preview-verto-target="thankyou">
        <div class="preview-thankyou-card">
          <div class="preview-thankyou-emoji">🎉</div>
          <div class="preview-thankyou-title">Thank you!</div>
          <div class="preview-thankyou-sub">
            Your responses have been recorded.<br>Thanks for completing this Verto.
          </div>
          <div style="margin-top:14px;display:flex;align-items:center;justify-content:center;gap:8px;opacity:0.55;">
            <span style="font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.6);">Powered by</span>
            <%= image_tag "playverto.svg", alt: "", style: "height:14px;width:auto;" %>
          </div>
        </div>
      </div>

    </div><%# /preview-body %>

    <%# Footer navigation %>
    <div class="preview-footer">
      <button type="button" class="preview-btn preview-btn-back"
              data-preview-verto-target="backBtn"
              data-action="click->preview-verto#back">← Back</button>

      <button type="button" class="preview-btn preview-btn-edit"
              data-preview-verto-target="editBtn"
              data-action="click->preview-verto#edit">✎ Edit</button>

      <span class="preview-progress-text"
            data-preview-verto-target="progress"></span>

      <button type="button" class="preview-btn preview-btn-next"
              data-preview-verto-target="nextBtn"
              data-action="click->preview-verto#next">Next →</button>

      <button type="button" class="preview-btn preview-btn-finish hidden"
              data-preview-verto-target="finishBtn"
              data-action="click->preview-verto#finish">Finish ✓</button>

      <button type="button" class="preview-btn preview-btn-return hidden"
              data-preview-verto-target="returnBtn"
              data-action="click->preview-verto#returnToDesign">← Back to Design</button>
    </div>

  </div><%# /preview-overlay %>

  <%= render "surveys/media_modal" %>
  <%= render "surveys/add_question_modal" %>

</div><%# /editor %>
