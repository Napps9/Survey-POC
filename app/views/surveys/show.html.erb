<%
  cards   = Array(@survey.cards)
  total_q = cards.count { |c| !%w[welcome_card static_page].include?(c["type"]) }
  q_idx   = 0
  est_min = [(total_q * 30 / 60.0).ceil, 1].max
%>

<div class="results-rainbow flex flex-col h-screen"
     data-controller="type-panel">

  <%# Nav %>
  <nav style="height:54px;background:#1C2034;border-bottom:1px solid rgba(255,255,255,0.08);flex-shrink:0;"
       class="flex items-center justify-between px-9">
    <%= link_to root_path do %>
      <%= image_tag "playverto.svg", alt: "Playverto", class: "h-7 w-auto" %>
    <% end %>
    <span style="font-family:'ABeeZee',sans-serif;font-size:13px;color:rgba(255,255,255,0.45);">Survey Generator</span>
  </nav>

  <%# Main grid: cards feed | type panel %>
  <div class="flex-1 overflow-hidden" style="display:grid;grid-template-columns:1fr 300px;">

    <%# ── LEFT: Cards column ── %>
    <div class="flex flex-col overflow-hidden">

      <%# Brief strip %>
      <div class="brief-strip">
        <span style="color:rgba(255,255,255,0.85);font-weight:600;"><%= @survey.theme %></span>
        <span style="color:rgba(255,255,255,0.3);">·</span>
        <span style="color:rgba(255,255,255,0.85);font-weight:600;"><%= @survey.audience_age %></span>
        <span style="color:rgba(255,255,255,0.3);">·</span>
        <span style="color:rgba(255,255,255,0.35);font-size:11px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:340px;">
          <%= @survey.key_insight %>
        </span>
        <div class="brief-q-count"><%= total_q %> questions</div>
      </div>

      <%# Cards feed %>
      <div class="flex-1 overflow-y-auto p-5 flex flex-col gap-4"
           style="scrollbar-width:thin;scrollbar-color:rgba(255,255,255,0.08) transparent;">

        <% cards.each_with_index do |card, idx| %>
          <%
            type    = card["type"].to_s
            meta    = card_type_meta(type)
            is_q    = !%w[welcome_card static_page].include?(type)
            q_idx  += 1 if is_q
            progress = total_q > 0 ? ((q_idx.to_f / total_q) * 100).round : 5
            progress = 5 if !is_q
          %>
          <div class="s-card"
               data-type-panel-target="card"
               data-card-type="<%= type %>"
               data-card-num="<%= idx + 1 %>"
               data-action="click->type-panel#selectCard">

            <%# Card header %>
            <div class="s-card-header">
              <span class="s-badge <%= meta[:badge_css] %>"><%= meta[:badge] %></span>
              <span style="font-size:11px;color:rgba(255,255,255,0.3);">Card <%= idx + 1 %></span>
              <button type="button"
                      style="margin-left:auto;background:none;border:none;cursor:pointer;color:rgba(255,255,255,0.25);font-size:15px;padding:2px 6px;border-radius:4px;transition:color 0.2s;"
                      onmouseover="this.style.color='rgba(255,255,255,0.7)'"
                      onmouseout="this.style.color='rgba(255,255,255,0.25)'"
                      data-action="click->type-panel#deleteCard">×</button>
            </div>

            <%# Card body: left green panel + right white panel %>
            <div class="s-card-body">

              <%# Left panel %>
              <div class="card-left">
                <div class="left-progress">
                  <div class="left-progress-fill" style="width:<%= progress %>%;"></div>
                </div>
                <div class="left-tagline">Build the change</div>
                <div class="left-preview">
                  <%= mini_preview_html(card) %>
                </div>
              </div>

              <%# Right panel %>
              <div class="card-right">
                <% if meta[:q_label].present? %>
                  <div class="card-q-label"><%= meta[:q_label] %></div>
                <% end %>
                <div class="card-q-text"><%= card["text"] %></div>
                <% if card["description"].present? %>
                  <div class="card-q-sub"><%= card["description"] %></div>
                <% end %>
              </div>

            </div>
          </div>
        <% end %>

      </div><%# /cards feed %>

      <%# Finalize bar %>
      <div class="finalize-bar">
        <div style="font-size:13px;color:rgba(255,255,255,0.45);">
          <strong style="color:#fff;" data-type-panel-target="cardCount"><%= cards.size %> cards</strong>
          &nbsp;·&nbsp; Estimated ~<%= est_min %> min<%= est_min != 1 ? "s" : "" %>
        </div>
        <%= link_to root_path,
              style: "padding:10px 26px;border-radius:16px;background:#00A950;color:white;font-family:'ABeeZee',sans-serif;font-size:13px;text-decoration:none;transition:background 0.15s;",
              onmouseover: "this.style.background='#009044'",
              onmouseout:  "this.style.background='#00A950'" do %>
          Publish Verto →
        <% end %>
      </div>

    </div><%# /cards column %>

    <%# ── RIGHT: Answer type panel ── %>
    <div class="type-panel">

      <div class="type-panel-top">
        <div style="font-family:'Alata',sans-serif;font-size:10px;text-transform:uppercase;letter-spacing:0.1em;color:rgba(255,255,255,0.35);margin-bottom:4px;">
          Answer Type
        </div>
        <div style="font-family:'ABeeZee',sans-serif;font-size:12px;color:#FF1E6F;line-height:1.3;min-height:16px;"
             data-type-panel-target="panelCardName">Select a card to change its type</div>
        <div style="font-size:11px;color:rgba(255,255,255,0.3);margin-top:3px;line-height:1.4;"
             data-type-panel-target="panelHint">Click any card on the left.</div>
      </div>

      <%# Empty state %>
      <div class="type-panel-empty" data-type-panel-target="panelEmpty">
        <div style="font-size:28px;opacity:0.18;">↖</div>
        <div style="font-size:12px;color:rgba(255,255,255,0.28);line-height:1.5;">
          Select a question card to switch its answer format
        </div>
      </div>

      <%# Type options list (hidden until a card is selected) %>
      <div class="type-list" style="display:none;" data-type-panel-target="typeList">
        <% [
          { key: "range",    icon: "↔", name: "Range / Slider",    desc: "Drag along a 5-point scale" },
          { key: "pick",     icon: "☰", name: "Pick One — List",   desc: "Vertical list, single selection" },
          { key: "choice4",  icon: "▣", name: "Image Choice × 4",  desc: "2×2 image grid, pick one" },
          { key: "choice6",  icon: "⊞", name: "Image Choice × 6",  desc: "3×2 image grid, pick one" },
          { key: "text",     icon: "✏", name: "Open Text",         desc: "Free-form written answer" },
          { key: "swipe",    icon: "⇄", name: "Swipe",             desc: "Agree / disagree card stack" },
          { key: "rotate",   icon: "↻", name: "Rotate",            desc: "Turn a dial to express feeling" },
          { key: "rank",     icon: "⇅", name: "Prioritise",        desc: "Drag & drop to rank" },
          { key: "audio",    icon: "🎤", name: "Audio Capture",     desc: "Record a voice response" },
          { key: "video",    icon: "▶", name: "Video",             desc: "Watch before continuing" },
          { key: "activity", icon: "✔", name: "Activity",          desc: "Off-screen task + checkbox" },
          { key: "welcome",  icon: "👋", name: "Welcome Card",      desc: "Intro — no answer required" },
        ].each do |opt| %>
          <div class="type-opt"
               data-type="<%= opt[:key] %>"
               data-type-panel-target="typeOpt"
               data-action="click->type-panel#setType">
            <div class="type-opt-icon"><%= opt[:icon] %></div>
            <div style="flex:1;min-width:0;">
              <div class="type-opt-name"><%= opt[:name] %></div>
              <div class="type-opt-desc"><%= opt[:desc] %></div>
            </div>
            <div class="type-opt-radio"></div>
          </div>
        <% end %>
      </div>

      <%# Footer buttons (hidden until a card is selected) %>
      <div class="type-panel-footer" style="display:none;" data-type-panel-target="panelFooter">
        <button type="button"
                style="width:100%;padding:10px;border-radius:16px;background:#00A950;color:white;font-family:'ABeeZee',sans-serif;font-size:13px;border:none;cursor:pointer;transition:background 0.15s;"
                onmouseover="this.style.background='#009044'"
                onmouseout="this.style.background='#00A950'"
                data-action="click->type-panel#applyType">Apply to this card</button>
        <button type="button"
                style="width:100%;padding:8px;border-radius:16px;background:transparent;color:rgba(255,255,255,0.4);font-family:'ABeeZee',sans-serif;font-size:12px;border:1px solid rgba(255,255,255,0.1);cursor:pointer;transition:all 0.15s;"
                onmouseover="this.style.color='#fff';this.style.borderColor='rgba(255,255,255,0.25)'"
                onmouseout="this.style.color='rgba(255,255,255,0.4)';this.style.borderColor='rgba(255,255,255,0.1)'"
                data-action="click->type-panel#applyAll">Apply to all cards</button>
      </div>

    </div><%# /type panel %>

  </div><%# /main grid %>

  <%# Toast %>
  <div class="toast-bar" data-type-panel-target="toast">
    <span style="display:inline-block;width:7px;height:7px;border-radius:50%;background:#00A950;margin-right:7px;vertical-align:middle;"></span>
    <span data-type-panel-target="toastMsg"></span>
  </div>

</div><%# /results-rainbow %>
