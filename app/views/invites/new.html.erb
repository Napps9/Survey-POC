<div style="display:flex;min-height:100vh;background:#1C2034;">
  <%= render "shared/sidebar", active: "members" %>

  <div style="flex:1;display:flex;flex-direction:column;align-items:flex-start;padding:60px 48px;overflow-y:auto;">
    <div style="width:100%;max-width:460px;">

      <div style="margin-bottom:32px;">
        <h1 style="font-family:'Alata',sans-serif;font-size: var(--text-3xl);color:#F7F7F7;margin:0 0 8px;">Invite someone</h1>
        <p style="font-family:'ABeeZee',sans-serif;font-size: var(--text-md);color:rgba(255,255,255,0.4);margin:0;">
          Enter their email and choose a role. You'll get a link to share with them — no email required.
        </p>
      </div>

      <% if flash[:alert] %>
        <div class="alert-error">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <%= form_with url: organisation_invites_path(current_organisation), method: :post do |f| %>

        <div style="margin-bottom:20px;">
          <label style="display:block;font-family:'Alata',sans-serif;font-size: var(--text-base);letter-spacing:0.08em;color:rgba(247,247,247,0.6);margin-bottom:8px;text-transform:uppercase;">Email address</label>
          <%= f.email_field :email_address,
                required: true, autofocus: true, placeholder: "colleague@example.com",
                value: params[:email_address],
                class: "form-input" %>
        </div>

        <div style="margin-bottom:32px;">
          <label style="display:block;font-family:'Alata',sans-serif;font-size: var(--text-base);letter-spacing:0.08em;color:rgba(247,247,247,0.6);margin-bottom:8px;text-transform:uppercase;">Role</label>
          <%= f.select :role,
                [["Member — can create and view Vertos", "member"],
                 ["Admin — can also manage members", "admin"]],
                { selected: "member" },
                class: "form-input" %>
        </div>

        <div style="display:flex;gap:12px;align-items:center;">
          <%= f.submit "Generate invite link →",
                style: "background:#01EACB;border:none;border-radius:8px;padding:12px 24px;color:#1C2034;font-family:'Alata',sans-serif;font-size: var(--text-lg);letter-spacing:0.05em;cursor:pointer;" %>
          <%= link_to "Cancel",
                organisation_memberships_path(current_organisation),
                style: "font-family:'ABeeZee',sans-serif;font-size: var(--text-md);color:rgba(255,255,255,0.35);text-decoration:none;" %>
        </div>

      <% end %>
    </div>
  </div>
</div>
