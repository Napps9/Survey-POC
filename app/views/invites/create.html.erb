<div style="display:flex;min-height:100vh;background:#1C2034;">
  <%= render "shared/sidebar", active: "members" %>

  <div style="flex:1;display:flex;flex-direction:column;align-items:flex-start;padding:60px 48px;overflow-y:auto;">
    <div style="width:100%;max-width:520px;">

      <%# Success badge %>
      <div style="display:inline-flex;align-items:center;gap:8px;background:rgba(1,234,203,0.15);border:1px solid rgba(1,234,203,0.3);border-radius:20px;padding:6px 14px;margin-bottom:28px;">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" stroke="#01EACB" stroke-width="1.4"/><path d="M4.5 7l1.8 1.8L9.5 5.5" stroke="#01EACB" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span style="font-family:'Alata',sans-serif;font-size: var(--text-base);color:#01EACB;letter-spacing:0.06em;">Invite created</span>
      </div>

      <h1 style="font-family:'Alata',sans-serif;font-size: var(--text-3xl);color:#F7F7F7;margin:0 0 8px;">Share this link</h1>
      <p style="font-family:'ABeeZee',sans-serif;font-size: var(--text-md);color:rgba(255,255,255,0.4);margin:0 0 28px;line-height:1.6;">
        Send this link to <strong style="color:rgba(255,255,255,0.7);"><%= @invite.email_address %></strong>.
        They'll be added to <strong style="color:rgba(255,255,255,0.7);"><%= @invite.organisation.name %></strong>
        as a <strong style="color:rgba(255,255,255,0.7);"><%= @invite.role %></strong> when they accept.
        The link expires in 7 days.
      </p>

      <%# Link box with copy button %>
      <% invite_url = invite_url(@invite.token) %>
      <div style="background:#161B2E;border:1px solid rgba(255,255,255,0.1);border-radius:10px;padding:16px 18px;display:flex;align-items:center;gap:12px;margin-bottom:32px;">
        <span id="invite-link"
              style="flex:1;font-family:'ABeeZee',sans-serif;font-size: var(--text-md);color:rgba(255,255,255,0.6);word-break:break-all;line-height:1.5;">
          <%= invite_url %>
        </span>
        <button type="button"
                onclick="navigator.clipboard.writeText('<%= invite_url %>').then(()=>{this.textContent='Copied!';this.style.color='#01EACB';setTimeout(()=>{this.textContent='Copy';this.style.color=''},2000)})"
                style="flex-shrink:0;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.12);border-radius:7px;padding:7px 14px;color:rgba(255,255,255,0.6);font-family:'Alata',sans-serif;font-size: var(--text-base);letter-spacing:0.04em;cursor:pointer;white-space:nowrap;">
          Copy
        </button>
      </div>

      <div style="display:flex;gap:16px;">
        <%= link_to "Invite another →",
              new_organisation_invite_path(current_organisation),
              style: "background:#01EACB;border-radius:8px;padding:11px 22px;color:#1C2034;font-family:'Alata',sans-serif;font-size: var(--text-md);letter-spacing:0.05em;text-decoration:none;" %>
        <%= link_to "Back to members",
              organisation_memberships_path(current_organisation),
              style: "border:1px solid rgba(255,255,255,0.12);border-radius:8px;padding:11px 22px;color:rgba(255,255,255,0.45);font-family:'Alata',sans-serif;font-size: var(--text-md);text-decoration:none;" %>
      </div>

    </div>
  </div>
</div>
