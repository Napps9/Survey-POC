<% content_for :title, "Accept invite — Playverto" %>

<div style="min-height:100vh;background:#272D4A;display:flex;align-items:center;justify-content:center;padding:24px;">
  <div style="width:100%;max-width:480px;">

    <div style="text-align:center;margin-bottom:36px;">
      <%= image_tag "playverto.svg", style: "height:40px;margin:0 auto 16px;display:block;" rescue nil %>
      <% if @invite.accepted? %>
        <h1 style="font-family:'Alata',sans-serif;font-size: var(--text-3xl);color:#F7F7F7;margin:0 0 8px;">Invite already used</h1>
        <p style="font-family:'ABeeZee',sans-serif;font-size: var(--text-md);color:rgba(255,255,255,0.4);margin:0;">
          This invite link has already been accepted. <%= link_to "Sign in", new_session_path, style: "color:#01EACB;text-decoration:none;" %>
        </p>
      <% elsif @invite.expired? %>
        <h1 style="font-family:'Alata',sans-serif;font-size: var(--text-3xl);color:#F7F7F7;margin:0 0 8px;">Invite expired</h1>
        <p style="font-family:'ABeeZee',sans-serif;font-size: var(--text-md);color:rgba(255,255,255,0.4);margin:0;">
          This link is more than 7 days old. Ask your admin to send a new one.
        </p>
      <% else %>
        <div style="font-family:'ABeeZee',sans-serif;font-size: var(--text-base);color:rgba(255,255,255,0.35);margin-bottom:8px;">
          <% if @invite.partner? %>
            You've been invited to join
          <% else %>
            You've been invited to join
          <% end %>
        </div>
        <h1 style="font-family:'Alata',sans-serif;font-size: var(--text-4xl);color:#F7F7F7;letter-spacing:0.04em;margin:0 0 4px;">
          <% if @invite.partner? && @invite.alliance %>
            <%= @invite.alliance.name %>
          <% else %>
            <%= @invite.organisation.name %>
          <% end %>
        </h1>
        <div style="font-family:'ABeeZee',sans-serif;font-size: var(--text-base);color:rgba(255,255,255,0.3);">
          <% if @invite.partner? %>
            an alliance by <span style="color:rgba(255,255,255,0.55);"><%= @invite.organisation.name %></span>
          <% else %>
            as a <span style="color:rgba(255,255,255,0.55);"><%= @invite.role %></span>
          <% end %>
          <% if @invite.addressed_email.present? %>
            · for <span style="color:rgba(255,255,255,0.55);"><%= @invite.addressed_email %></span>
          <% end %>
        </div>
      <% end %>
    </div>

    <% unless @invite.accepted? || @invite.expired? %>

      <% if flash[:alert] %>
        <div class="alert-error">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <% if @signed_in_user && @invite.partner? %>
        <%# ─── Signed-in flow: pick which existing org joins ─── %>
        <div style="font-family:'ABeeZee',sans-serif;font-size: var(--text-md);color:rgba(255,255,255,0.55);margin-bottom:18px;text-align:center;">
          Signed in as <span style="color:rgba(255,255,255,0.85);"><%= @signed_in_user.name.presence || @signed_in_user.email_address %></span>
        </div>

        <% if @joinable_orgs.any? %>
          <%= form_with url: accept_invite_path(@invite.token), method: :post, local: true do |f| %>
            <div style="margin-bottom:18px;">
              <label style="display:block;font-family:'Alata',sans-serif;font-size: var(--text-base);letter-spacing:0.08em;color:rgba(247,247,247,0.6);margin-bottom:8px;text-transform:uppercase;">
                <% if @joinable_orgs.size == 1 %>
                  Join with
                <% else %>
                  Pick which organisation joins
                <% end %>
              </label>
              <% if @joinable_orgs.size == 1 %>
                <%# Single eligible org — just show it as a static label %>
                <%= hidden_field_tag :join_as_organisation_id, @joinable_orgs.first.id %>
                <div style="width:100%;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:8px;padding:12px 16px;color:#fff;font-family:'Alata',sans-serif;font-size: var(--text-xl);box-sizing:border-box;">
                  <%= @joinable_orgs.first.name %>
                </div>
              <% else %>
                <%= select_tag :join_as_organisation_id,
                      options_for_select(@joinable_orgs.map { |o| [o.name, o.id] }),
                      class: "form-input",
                      style: "appearance:menulist;" %>
              <% end %>
            </div>

            <%= f.submit "Join #{@invite.alliance.name} →",
                  style: "width:100%;background:#01EACB;border:none;border-radius:8px;padding:14px;color:#1C2034;font-family:'Alata',sans-serif;font-size: var(--text-xl);letter-spacing:0.05em;cursor:pointer;" %>
          <% end %>

          <% if @already_member_orgs.any? %>
            <div style="margin-top:18px;font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.35);text-align:center;">
              Already in this alliance: <%= @already_member_orgs.map(&:name).join(", ") %>
            </div>
          <% end %>
        <% else %>
          <%# No joinable orgs — all already in, or user only admins the creator %>
          <div style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:16px;font-family:'ABeeZee',sans-serif;font-size: var(--text-md);color:rgba(255,255,255,0.6);line-height:1.5;text-align:center;">
            <% if @creator_admin_orgs.any? %>
              You run this alliance — visit it instead.
            <% elsif @already_member_orgs.any? %>
              <%= @already_member_orgs.map(&:name).join(", ") %>
              <%= @already_member_orgs.size == 1 ? "is" : "are" %> already in this alliance.
            <% else %>
              You don't have an admin organisation that can join this alliance.
            <% end %>
          </div>
          <% if (@creator_admin_orgs + @already_member_orgs).any? && @invite.alliance %>
            <%= link_to "Open #{@invite.alliance.name} →", alliance_path(@invite.alliance),
                  style: "display:block;text-align:center;margin-top:18px;color:#01EACB;font-family:'Alata',sans-serif;font-size: var(--text-md);text-decoration:none;" %>
          <% end %>
        <% end %>

        <div style="margin-top:24px;text-align:center;">
          <%= button_to "Sign out and use a different account", session_path, method: :delete,
                style: "background:none;border:none;color:rgba(255,255,255,0.35);font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);text-decoration:underline;cursor:pointer;padding:0;",
                form: { style: "margin:0;" },
                data: { turbo_confirm: "Sign out of your current account?" } %>
        </div>

      <% else %>
        <%# ─── Not signed in: signup form by default, with toggle to sign-in ─── %>
        <% sign_in_default = (params[:mode] == "sign_in") && @invite.partner? %>

        <div id="invite-signup-form" <%= "hidden" if sign_in_default %>>
          <%= form_with url: accept_invite_path(@invite.token), method: :post do |f| %>

            <div style="margin-bottom:18px;">
              <label style="display:block;font-family:'Alata',sans-serif;font-size: var(--text-base);letter-spacing:0.08em;color:rgba(247,247,247,0.6);margin-bottom:8px;text-transform:uppercase;">Your name</label>
              <%= f.text_field :name,
                    required: true, autofocus: !sign_in_default, autocomplete: "name",
                    placeholder: "Jane Smith", value: params[:name],
                    class: "form-input" %>
            </div>

            <% if @invite.partner? && (@invite.addressed_email.blank? || !User.exists?(email_address: @invite.addressed_email)) %>
              <div style="margin-bottom:18px;">
                <label style="display:block;font-family:'Alata',sans-serif;font-size: var(--text-base);letter-spacing:0.08em;color:rgba(247,247,247,0.6);margin-bottom:8px;text-transform:uppercase;">Your organisation name</label>
                <%= f.text_field :organisation_name,
                      required: true, placeholder: "Acme Partners",
                      value: params[:organisation_name], class: "form-input" %>
              </div>
            <% end %>

            <div style="margin-bottom:18px;">
              <label style="display:block;font-family:'Alata',sans-serif;font-size: var(--text-base);letter-spacing:0.08em;color:rgba(247,247,247,0.6);margin-bottom:8px;text-transform:uppercase;">Email</label>
              <% if @invite.addressed_email.present? %>
                <div style="width:100%;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:8px;padding:12px 16px;color:rgba(255,255,255,0.4);font-family:'ABeeZee',sans-serif;font-size: var(--text-xl);box-sizing:border-box;">
                  <%= @invite.addressed_email %>
                </div>
              <% else %>
                <%= f.email_field :email_address,
                      required: true, autocomplete: "email",
                      placeholder: "you@example.com", value: params[:email_address],
                      class: "form-input" %>
              <% end %>
            </div>

            <div style="margin-bottom:18px;">
              <label style="display:block;font-family:'Alata',sans-serif;font-size: var(--text-base);letter-spacing:0.08em;color:rgba(247,247,247,0.6);margin-bottom:8px;text-transform:uppercase;">Password</label>
              <%= f.password_field :password,
                    required: true, autocomplete: "new-password",
                    placeholder: "At least 12 characters", maxlength: 72, minlength: 12,
                    class: "form-input" %>
            </div>

            <div style="margin-bottom:24px;">
              <label style="display:block;font-family:'Alata',sans-serif;font-size: var(--text-base);letter-spacing:0.08em;color:rgba(247,247,247,0.6);margin-bottom:8px;text-transform:uppercase;">Confirm password</label>
              <%= f.password_field :password_confirmation,
                    required: true, autocomplete: "new-password",
                    placeholder: "••••••••••••", maxlength: 72,
                    class: "form-input" %>
            </div>

            <%= f.submit "Accept invite →",
                  style: "width:100%;background:#01EACB;border:none;border-radius:8px;padding:14px;color:#1C2034;font-family:'Alata',sans-serif;font-size: var(--text-xl);letter-spacing:0.05em;cursor:pointer;" %>

          <% end %>

          <% if @invite.partner? %>
            <div style="margin-top:18px;text-align:center;font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.45);">
              Already have a Playverto account?
              <button type="button"
                      onclick="document.getElementById('invite-signup-form').hidden=true;document.getElementById('invite-signin-form').hidden=false;document.querySelector('#invite-signin-form input[type=email]').focus();"
                      style="background:none;border:none;color:#01EACB;font-family:inherit;font-size:inherit;text-decoration:underline;cursor:pointer;padding:0;">
                Sign in instead
              </button>
            </div>
          <% end %>
        </div>

        <% if @invite.partner? %>
          <div id="invite-signin-form" <%= "hidden" unless sign_in_default %>>
            <%= form_with url: accept_invite_path(@invite.token), method: :post do |f| %>
              <%= hidden_field_tag :mode, "sign_in" %>

              <div style="margin-bottom:18px;">
                <label style="display:block;font-family:'Alata',sans-serif;font-size: var(--text-base);letter-spacing:0.08em;color:rgba(247,247,247,0.6);margin-bottom:8px;text-transform:uppercase;">Email</label>
                <%= f.email_field :email_address,
                      required: true, autofocus: sign_in_default, autocomplete: "email",
                      placeholder: "you@example.com", value: params[:email_address],
                      class: "form-input" %>
              </div>

              <div style="margin-bottom:24px;">
                <label style="display:block;font-family:'Alata',sans-serif;font-size: var(--text-base);letter-spacing:0.08em;color:rgba(247,247,247,0.6);margin-bottom:8px;text-transform:uppercase;">Password</label>
                <%= f.password_field :password,
                      required: true, autocomplete: "current-password",
                      placeholder: "Your Playverto password", maxlength: 72,
                      class: "form-input" %>
              </div>

              <%= f.submit "Sign in to join →",
                    style: "width:100%;background:#01EACB;border:none;border-radius:8px;padding:14px;color:#1C2034;font-family:'Alata',sans-serif;font-size: var(--text-xl);letter-spacing:0.05em;cursor:pointer;" %>
            <% end %>

            <div style="margin-top:18px;text-align:center;font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.45);">
              New to Playverto?
              <button type="button"
                      onclick="document.getElementById('invite-signin-form').hidden=true;document.getElementById('invite-signup-form').hidden=false;document.querySelector('#invite-signup-form input[name=name]').focus();"
                      style="background:none;border:none;color:#01EACB;font-family:inherit;font-size:inherit;text-decoration:underline;cursor:pointer;padding:0;">
                Create a new account
              </button>
            </div>
          </div>
        <% end %>

      <% end %>

    <% end %>
  </div>
</div>
