<% content_for :title, "Accept invite — Playverto" %>

<div style="min-height:100vh;background:#272D4A;display:flex;align-items:center;justify-content:center;padding:24px;">
  <div style="width:100%;max-width:420px;">

    <div style="text-align:center;margin-bottom:36px;">
      <%= image_tag "playverto.svg", style: "height:40px;margin:0 auto 16px;display:block;" rescue nil %>
      <% if @invite.accepted? %>
        <h1 style="font-family:'Alata',sans-serif;font-size:22px;color:#F7F7F7;margin:0 0 8px;">Invite already used</h1>
        <p style="font-family:'ABeeZee',sans-serif;font-size:13px;color:rgba(255,255,255,0.4);margin:0;">
          This invite link has already been accepted. <%= link_to "Sign in", new_session_path, style: "color:#01EACB;text-decoration:none;" %>
        </p>
      <% elsif @invite.expired? %>
        <h1 style="font-family:'Alata',sans-serif;font-size:22px;color:#F7F7F7;margin:0 0 8px;">Invite expired</h1>
        <p style="font-family:'ABeeZee',sans-serif;font-size:13px;color:rgba(255,255,255,0.4);margin:0;">
          This link is more than 7 days old. Ask your admin to send a new one.
        </p>
      <% else %>
        <div style="font-family:'ABeeZee',sans-serif;font-size:12px;color:rgba(255,255,255,0.35);margin-bottom:8px;">
          You've been invited to join
        </div>
        <h1 style="font-family:'Alata',sans-serif;font-size:24px;color:#F7F7F7;letter-spacing:0.04em;margin:0 0 4px;">
          <%= @invite.organisation.name %>
        </h1>
        <div style="font-family:'ABeeZee',sans-serif;font-size:12px;color:rgba(255,255,255,0.3);">
          as a <span style="color:rgba(255,255,255,0.55);"><%= @invite.role %></span>
          · for <span style="color:rgba(255,255,255,0.55);"><%= @invite.email_address %></span>
        </div>
      <% end %>
    </div>

    <% unless @invite.accepted? || @invite.expired? %>

      <% if flash[:alert] %>
        <div style="background:rgba(216,0,39,0.15);border:1px solid rgba(216,0,39,0.4);border-radius:8px;padding:12px 16px;margin-bottom:20px;color:#ff6b6b;font-size:14px;font-family:'ABeeZee',sans-serif;">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <%= form_with url: accept_invite_path(@invite.token), method: :post do |f| %>

        <div style="margin-bottom:18px;">
          <label style="display:block;font-family:'Alata',sans-serif;font-size:12px;letter-spacing:0.08em;color:rgba(247,247,247,0.6);margin-bottom:8px;text-transform:uppercase;">Your name</label>
          <%= f.text_field :name,
                required: true, autofocus: true, autocomplete: "name",
                placeholder: "Jane Smith", value: params[:name],
                style: "width:100%;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.15);border-radius:8px;padding:12px 16px;color:#F7F7F7;font-family:'ABeeZee',sans-serif;font-size:15px;box-sizing:border-box;outline:none;" %>
        </div>

        <div style="margin-bottom:18px;">
          <label style="display:block;font-family:'Alata',sans-serif;font-size:12px;letter-spacing:0.08em;color:rgba(247,247,247,0.6);margin-bottom:8px;text-transform:uppercase;">Email</label>
          <div style="width:100%;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:8px;padding:12px 16px;color:rgba(255,255,255,0.4);font-family:'ABeeZee',sans-serif;font-size:15px;box-sizing:border-box;">
            <%= @invite.email_address %>
          </div>
        </div>

        <div style="margin-bottom:18px;">
          <label style="display:block;font-family:'Alata',sans-serif;font-size:12px;letter-spacing:0.08em;color:rgba(247,247,247,0.6);margin-bottom:8px;text-transform:uppercase;">Password</label>
          <%= f.password_field :password,
                required: true, autocomplete: "new-password",
                placeholder: "At least 12 characters", maxlength: 72, minlength: 12,
                style: "width:100%;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.15);border-radius:8px;padding:12px 16px;color:#F7F7F7;font-family:'ABeeZee',sans-serif;font-size:15px;box-sizing:border-box;outline:none;" %>
        </div>

        <div style="margin-bottom:32px;">
          <label style="display:block;font-family:'Alata',sans-serif;font-size:12px;letter-spacing:0.08em;color:rgba(247,247,247,0.6);margin-bottom:8px;text-transform:uppercase;">Confirm password</label>
          <%= f.password_field :password_confirmation,
                required: true, autocomplete: "new-password",
                placeholder: "••••••••••••", maxlength: 72,
                style: "width:100%;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.15);border-radius:8px;padding:12px 16px;color:#F7F7F7;font-family:'ABeeZee',sans-serif;font-size:15px;box-sizing:border-box;outline:none;" %>
        </div>

        <%= f.submit "Accept invite →",
              style: "width:100%;background:#01EACB;border:none;border-radius:8px;padding:14px;color:#fff;font-family:'Alata',sans-serif;font-size:15px;letter-spacing:0.05em;cursor:pointer;" %>

      <% end %>

    <% end %>
  </div>
</div>
