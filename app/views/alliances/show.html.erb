<% content_for :title, "#{@alliance.partner_organisation.name} — Partners" %>
<% content_for :head do %>
  <style>body { overflow: auto !important; height: auto !important; }</style>
<% end %>

<% partner = @alliance.partner_organisation %>
<% is_admin = current_membership&.admin? %>

<div style="display:flex;min-height:100vh;background:#1C2034;">
  <div style="flex:1;display:flex;flex-direction:column;min-width:0;">

    <%# ── Hero ── %>
    <div style="position:relative;overflow:hidden;padding:36px 36px 32px;border-bottom:1px solid rgba(255,255,255,0.05);flex-shrink:0;">
      <div class="gen-orbs" style="opacity:0.25;">
        <div class="gen-orb gen-orb-2"></div>
        <div class="gen-orb gen-orb-3"></div>
      </div>

      <div style="position:relative;z-index:1;">
        <%= link_to alliances_path,
              style: "display:inline-flex;align-items:center;gap:6px;font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.45);text-decoration:none;margin-bottom:18px;" do %>
          <span style="opacity:0.7;">←</span> All partners
        <% end %>

        <div style="display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:20px;">
          <div>
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;">
              <span style="width:8px;height:8px;border-radius:50%;background:#FF1E6F;box-shadow:0 0 12px rgba(255,30,111,0.7);"></span>
              <span style="font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.45);letter-spacing:0.12em;text-transform:uppercase;">Partner</span>
              <span style="font-family:'ABeeZee',sans-serif;font-size: var(--text-2xs);letter-spacing:0.1em;text-transform:uppercase;padding:3px 9px;border-radius:100px;background:<%= @alliance.active? ? 'rgba(1,234,203,0.15)' : 'rgba(255,255,255,0.08)' %>;color:<%= @alliance.active? ? '#01EACB' : 'rgba(255,255,255,0.5)' %>;">
                <%= @alliance.status.capitalize %>
              </span>
            </div>
            <h1 style="font-family:'Alata',sans-serif;font-size:38px;color:#fff;line-height:1.1;margin:0 0 6px;"><%= partner.name %></h1>
            <p style="font-family:'ABeeZee',sans-serif;font-size: var(--text-md);color:rgba(255,255,255,0.4);margin:0;">
              In alliance since <%= @alliance.created_at.to_date.to_fs(:long) rescue @alliance.created_at.to_date %>
            </p>
          </div>

          <% if is_admin %>
            <%= button_to alliance_path(@alliance), method: :delete,
                  data: { turbo_confirm: "Remove #{partner.name}? Their existing share links will stop working." },
                  form: { style: "margin:0;" },
                  style: "background:none;border:1px solid rgba(255,255,255,0.15);border-radius:100px;padding:9px 18px;color:rgba(255,255,255,0.55);font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);cursor:pointer;" do %>
              Remove partner
            <% end %>
          <% end %>
        </div>

        <%# ── Top-line stats ── %>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:14px;margin-top:30px;">
          <% [
               [ @completion_rate ? "#{@completion_rate}%" : "—", "Completion rate", "#FF1E6F", "Of partner-driven responses" ],
               [ @total_respondents.to_s,         "Total respondents", "#01EACB", "Across all shared Vertos" ],
               [ @total_partner_responses.to_s,   "Partner respondents", "#615BF5", "Via #{partner.name}'s links" ],
             ].each do |value, label, accent, sub| %>
            <div style="background:rgba(22,27,46,0.85);border:1px solid rgba(255,255,255,0.07);border-radius:18px;padding:18px 20px;backdrop-filter:blur(8px);">
              <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;">
                <span style="width:6px;height:6px;border-radius:50%;background:<%= accent %>;"></span>
                <span style="font-family:'ABeeZee',sans-serif;font-size: var(--text-2xs);color:rgba(255,255,255,0.4);letter-spacing:0.1em;text-transform:uppercase;"><%= label %></span>
              </div>
              <div style="font-family:'Alata',sans-serif;font-size:34px;color:<%= accent %>;line-height:1;margin-bottom:8px;"><%= value %></div>
              <div style="font-family:'ABeeZee',sans-serif;font-size: var(--text-xs);color:rgba(255,255,255,0.35);line-height:1.4;"><%= sub %></div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <%# ── Body ── %>
    <div style="flex:1;padding:32px 36px 60px;">

      <% if flash[:notice] %>
        <div style="background:rgba(1,234,203,0.1);border:1px solid rgba(1,234,203,0.3);border-radius:10px;padding:11px 16px;margin-bottom:20px;color:#01EACB;font-family:'ABeeZee',sans-serif;font-size: var(--text-md);"><%= flash[:notice] %></div>
      <% end %>
      <% if flash[:alert] %>
        <div style="background:rgba(216,0,39,0.1);border:1px solid rgba(216,0,39,0.3);border-radius:10px;padding:11px 16px;margin-bottom:20px;color:#FF6B83;font-family:'ABeeZee',sans-serif;font-size: var(--text-md);"><%= flash[:alert] %></div>
      <% end %>

      <%# ── Shared Vertos ── %>
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;">
        <span style="font-family:'Alata',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.3);letter-spacing:0.1em;text-transform:uppercase;">Shared Vertos</span>
        <div style="flex:1;height:1px;background:rgba(255,255,255,0.06);"></div>
        <span style="font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.2);"><%= @shares.size %></span>
      </div>

      <% if @shares.empty? %>
        <div style="border:1px dashed rgba(255,255,255,0.12);border-radius:14px;padding:36px 24px;text-align:center;margin-bottom:32px;">
          <div style="font-family:'Alata',sans-serif;font-size: var(--text-xl);color:#fff;margin-bottom:6px;">Nothing shared yet</div>
          <div style="font-family:'ABeeZee',sans-serif;font-size: var(--text-md);color:rgba(255,255,255,0.4);max-width:340px;margin:0 auto;line-height:1.5;">
            Add a Verto below to give <%= partner.name %> their own distribution link.
          </div>
        </div>
      <% else %>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:14px;margin-bottom:32px;">
          <% @shares.each do |share| %>
            <% s         = share.survey %>
            <% sh_resp   = (@share_response_counts[share.id]  || 0) %>
            <% sh_comp   = (@share_completed_counts[share.id] || 0) %>
            <% sv_total  = (@survey_total_responses[s.id]     || 0) %>
            <% sh_rate   = sh_resp.positive? ? ((sh_comp.to_f / sh_resp) * 100).round : nil %>
            <% s_archived = s.deleted? %>
            <div style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);border-radius:16px;overflow:hidden;">
              <div style="height:3px;background:<%= s_archived ? 'rgba(255,255,255,0.1)' : 'linear-gradient(90deg,#01EACB,#FF1E6F)' %>;"></div>
              <div style="padding:14px 18px 12px;">
                <div style="display:flex;align-items:center;justify-content:space-between;gap:10px;margin-bottom:8px;">
                  <span style="font-family:'Alata',sans-serif;font-size: var(--text-2xs);letter-spacing:0.1em;text-transform:uppercase;padding:3px 9px;border-radius:100px;background:<%= s_archived ? 'rgba(255,255,255,0.08)' : (s.published? ? '#01EACB' : 'rgba(255,255,255,0.08)') %>;color:<%= s_archived ? 'rgba(255,255,255,0.5)' : (s.published? ? '#1C2034' : 'rgba(255,255,255,0.5)') %>;">
                    <%= s_archived ? "Archived" : (s.published? ? "Live" : "Draft") %>
                  </span>
                  <span style="font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.35);">
                    Linked <%= share.created_at.to_date.to_fs(:long) rescue share.created_at.to_date %>
                  </span>
                </div>
                <div style="font-family:'Alata',sans-serif;font-size: var(--text-2xl);color:#fff;line-height:1.25;margin-bottom:4px;">
                  <%= s.theme.presence&.truncate(48) || s.title.presence&.truncate(48) || "Untitled Verto" %>
                </div>
                <% if s.title.present? && s.title != s.theme %>
                  <div style="font-family:'ABeeZee',sans-serif;font-size: var(--text-base);color:rgba(255,255,255,0.4);line-height:1.4;"><%= s.title.truncate(60) %></div>
                <% end %>
              </div>

              <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:0;border-top:1px solid rgba(255,255,255,0.05);">
                <div style="padding:12px 14px;text-align:center;border-right:1px solid rgba(255,255,255,0.05);">
                  <div style="font-family:'Alata',sans-serif;font-size: var(--text-xl);color:<%= sh_rate ? '#FF1E6F' : 'rgba(255,255,255,0.25)' %>;line-height:1;"><%= sh_rate ? "#{sh_rate}%" : "—" %></div>
                  <div style="font-family:'ABeeZee',sans-serif;font-size: var(--text-2xs);color:rgba(255,255,255,0.4);margin-top:4px;letter-spacing:0.05em;">Completion</div>
                </div>
                <div style="padding:12px 14px;text-align:center;border-right:1px solid rgba(255,255,255,0.05);">
                  <div style="font-family:'Alata',sans-serif;font-size: var(--text-xl);color:<%= sv_total > 0 ? '#01EACB' : 'rgba(255,255,255,0.25)' %>;line-height:1;"><%= sv_total %></div>
                  <div style="font-family:'ABeeZee',sans-serif;font-size: var(--text-2xs);color:rgba(255,255,255,0.4);margin-top:4px;letter-spacing:0.05em;">Total resp.</div>
                </div>
                <div style="padding:12px 14px;text-align:center;">
                  <div style="font-family:'Alata',sans-serif;font-size: var(--text-xl);color:<%= sh_resp > 0 ? '#615BF5' : 'rgba(255,255,255,0.25)' %>;line-height:1;"><%= sh_resp %></div>
                  <div style="font-family:'ABeeZee',sans-serif;font-size: var(--text-2xs);color:rgba(255,255,255,0.4);margin-top:4px;letter-spacing:0.05em;">Via partner</div>
                </div>
              </div>

              <div style="display:flex;align-items:center;gap:8px;padding:12px 18px;border-top:1px solid rgba(255,255,255,0.05);">
                <% share_url = play_survey_url(share.share_token) rescue nil %>
                <% if share_url %>
                  <input type="text" readonly value="<%= share_url %>"
                         id="share-link-<%= share.id %>"
                         onclick="this.select()"
                         style="flex:1;min-width:0;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:8px;padding:7px 10px;color:rgba(255,255,255,0.6);font-family:'ABeeZee',sans-serif;font-size: var(--text-xs);outline:none;" />
                  <button type="button"
                          onclick="navigator.clipboard.writeText(document.getElementById('share-link-<%= share.id %>').value).then(()=>{this.textContent='✓';setTimeout(()=>{this.textContent='Copy'},1500)})"
                          style="background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.12);border-radius:8px;padding:6px 12px;color:rgba(255,255,255,0.65);font-family:'ABeeZee',sans-serif;font-size: var(--text-xs);cursor:pointer;">Copy</button>
                <% end %>
                <% if is_admin %>
                  <%= button_to "Remove", survey_share_path(survey_id: s.id, id: share.id), method: :delete,
                        data: { turbo_confirm: "Remove this Verto from #{partner.name}? Their link will stop working." },
                        form: { style: "margin:0;" },
                        style: "background:none;border:1px solid rgba(255,255,255,0.12);border-radius:8px;padding:6px 10px;color:rgba(255,255,255,0.45);font-family:'ABeeZee',sans-serif;font-size: var(--text-xs);cursor:pointer;" %>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>

      <%# ── Add a Verto ── %>
      <% if is_admin %>
        <div style="background:rgba(255,255,255,0.025);border:1px solid rgba(255,255,255,0.07);border-radius:16px;padding:20px 22px;">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
            <span style="width:6px;height:6px;border-radius:50%;background:#0CA7FF;"></span>
            <span style="font-family:'ABeeZee',sans-serif;font-size: var(--text-2xs);color:rgba(255,255,255,0.4);letter-spacing:0.1em;text-transform:uppercase;">Add to game</span>
          </div>
          <div style="font-family:'Alata',sans-serif;font-size: var(--text-xl);color:#fff;margin-bottom:4px;">Share another Verto with <%= partner.name %></div>
          <div style="font-family:'ABeeZee',sans-serif;font-size: var(--text-md);color:rgba(255,255,255,0.4);margin-bottom:14px;">
            Pick a published Verto and we'll generate a unique distribution link for them.
          </div>

          <% if @available_surveys.empty? %>
            <div style="font-family:'ABeeZee',sans-serif;font-size: var(--text-md);color:rgba(255,255,255,0.4);padding:14px 0;">
              No more published Vertos to share. <%= link_to "Create a new Verto →", new_survey_path, style: "color:#01EACB;text-decoration:none;" %>
            </div>
          <% else %>
            <%= form_with url: create_survey_share_path(survey_id: @available_surveys.first.id), method: :post, local: true,
                  html: { style: "display:flex;gap:10px;flex-wrap:wrap;align-items:center;", id: "add-share-form" } do |f| %>
              <%= hidden_field_tag :alliance_id, @alliance.id %>
              <select name="survey_picker"
                      onchange="document.getElementById('add-share-form').action = '/surveys/' + this.value + '/shares'"
                      style="flex:1;min-width:240px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.12);border-radius:10px;padding:11px 14px;color:#fff;font-family:'ABeeZee',sans-serif;font-size: var(--text-md);outline:none;">
                <% @available_surveys.each do |s| %>
                  <option value="<%= s.id %>" style="background:#1C2034;color:#fff;">
                    <%= [ s.theme.presence, s.title.presence ].compact.uniq.first(2).join(" — ").truncate(72) %>
                  </option>
                <% end %>
              </select>
              <button type="submit"
                      style="background:#01EACB;border:none;border-radius:100px;padding:11px 22px;color:#1C2034;font-family:'Alata',sans-serif;font-size: var(--text-md);letter-spacing:0.04em;cursor:pointer;">
                Add Verto →
              </button>
            <% end %>
          <% end %>
        </div>
      <% end %>

    </div>
  </div>
</div>
