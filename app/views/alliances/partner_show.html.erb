<% content_for :title, "#{@alliance.name} — Alliances" %>
<% content_for :head do %>
  <style>body { overflow: auto !important; height: auto !important; }</style>
<% end %>

<div style="display:flex;min-height:100vh;background:#1C2034;">
  <div style="flex:1;display:flex;flex-direction:column;min-width:0;">

    <%# ── Hero ── %>
    <div style="position:relative;overflow:hidden;padding:36px 36px 32px;border-bottom:1px solid rgba(255,255,255,0.05);flex-shrink:0;">
      <div class="gen-orbs" style="opacity:0.25;">
        <div class="gen-orb gen-orb-2"></div>
        <div class="gen-orb gen-orb-3"></div>
      </div>

      <div style="position:relative;z-index:1;">
        <%= link_to alliances_path,
              style: "display:inline-flex;align-items:center;gap:6px;font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.45);text-decoration:none;margin-bottom:18px;" do %>
          <span style="opacity:0.7;">←</span> All alliances
        <% end %>

        <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;">
          <span style="width:8px;height:8px;border-radius:50%;background:#01EACB;box-shadow:0 0 12px rgba(1,234,203,0.7);"></span>
          <span style="font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.45);letter-spacing:0.12em;text-transform:uppercase;">Alliance · Member</span>
        </div>
        <h1 style="font-family:'Alata',sans-serif;font-size:38px;color:#fff;line-height:1.1;margin:0 0 6px;"><%= @alliance.name %></h1>
        <p style="font-family:'ABeeZee',sans-serif;font-size: var(--text-md);color:rgba(255,255,255,0.4);margin:0;">
          Run by <%= @alliance.organisation.name %>
        </p>

        <%# ── Top-line stats ── %>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:14px;margin-top:24px;">
          <div style="background:rgba(22,27,46,0.85);border:1px solid rgba(255,255,255,0.07);border-radius:18px;padding:18px 20px;backdrop-filter:blur(8px);">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;">
              <span style="width:6px;height:6px;border-radius:50%;background:#FF1E6F;"></span>
              <span style="font-family:'ABeeZee',sans-serif;font-size: var(--text-2xs);color:rgba(255,255,255,0.4);letter-spacing:0.1em;text-transform:uppercase;">Partners in alliance</span>
            </div>
            <div style="font-family:'Alata',sans-serif;font-size:34px;color:#FF1E6F;line-height:1;margin-bottom:4px;"><%= @total_partner_count %></div>
            <div style="font-family:'ABeeZee',sans-serif;font-size: var(--text-xs);color:rgba(255,255,255,0.35);line-height:1.4;">Including you</div>
          </div>
          <div style="background:rgba(22,27,46,0.85);border:1px solid rgba(255,255,255,0.07);border-radius:18px;padding:18px 20px;backdrop-filter:blur(8px);">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;">
              <span style="width:6px;height:6px;border-radius:50%;background:#01EACB;"></span>
              <span style="font-family:'ABeeZee',sans-serif;font-size: var(--text-2xs);color:rgba(255,255,255,0.4);letter-spacing:0.1em;text-transform:uppercase;">Shared Vertos</span>
            </div>
            <div style="font-family:'Alata',sans-serif;font-size:34px;color:#01EACB;line-height:1;margin-bottom:4px;"><%= @alliance_vertos.size %></div>
            <div style="font-family:'ABeeZee',sans-serif;font-size: var(--text-xs);color:rgba(255,255,255,0.35);line-height:1.4;">Available for you to distribute</div>
          </div>
        </div>
      </div>
    </div>

    <%# ── Body ── %>
    <div style="flex:1;padding:32px 36px 60px;">

      <%# ── Other members ── %>
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;">
        <span style="font-family:'Alata',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.3);letter-spacing:0.1em;text-transform:uppercase;">Other partners</span>
        <div style="flex:1;height:1px;background:rgba(255,255,255,0.06);"></div>
        <span style="font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.2);"><%= @other_members.size %></span>
      </div>

      <% if @other_members.empty? %>
        <div style="border:1px dashed rgba(255,255,255,0.12);border-radius:14px;padding:24px;text-align:center;margin-bottom:32px;font-family:'ABeeZee',sans-serif;font-size: var(--text-md);color:rgba(255,255,255,0.4);">
          You're the only partner in this alliance for now.
        </div>
      <% else %>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:10px;margin-bottom:32px;">
          <% @other_members.each do |o| %>
            <div style="display:flex;align-items:center;gap:12px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);border-radius:12px;padding:10px 14px;">
              <div style="width:30px;height:30px;border-radius:50%;background:linear-gradient(135deg,#01EACB,#0CA7FF);display:flex;align-items:center;justify-content:center;font-family:'Alata',sans-serif;font-size: var(--text-sm);color:#fff;flex-shrink:0;">
                <%= o.name.first.upcase %>
              </div>
              <div style="font-family:'Alata',sans-serif;font-size: var(--text-md);color:#fff;line-height:1.2;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= o.name %></div>
            </div>
          <% end %>
        </div>
      <% end %>

      <%# ── Your Vertos ── %>
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;">
        <span style="font-family:'Alata',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.3);letter-spacing:0.1em;text-transform:uppercase;">Vertos shared with you</span>
        <div style="flex:1;height:1px;background:rgba(255,255,255,0.06);"></div>
        <span style="font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.2);"><%= @alliance_vertos.size %></span>
      </div>

      <% if @alliance_vertos.empty? %>
        <div style="border:1px dashed rgba(255,255,255,0.12);border-radius:14px;padding:36px 24px;text-align:center;">
          <div style="font-family:'Alata',sans-serif;font-size: var(--text-xl);color:#fff;margin-bottom:6px;">No Vertos yet</div>
          <div style="font-family:'ABeeZee',sans-serif;font-size: var(--text-md);color:rgba(255,255,255,0.4);max-width:340px;margin:0 auto;line-height:1.5;">
            When <%= @alliance.organisation.name %> adds a Verto to this alliance, you'll see your unique share link here.
          </div>
        </div>
      <% else %>
        <div style="display:flex;flex-direction:column;gap:14px;">
          <% @alliance_vertos.each do |av| %>
            <% s = av.survey %>
            <% share = @my_shares_by_verto[av.id] %>
            <% url = share ? play_survey_url(share.share_token) : nil %>
            <div style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);border-radius:16px;overflow:hidden;">
              <div style="height:3px;background:linear-gradient(90deg,#01EACB,#FF1E6F);"></div>
              <div style="padding:18px 22px 14px;">
                <div style="font-family:'ABeeZee',sans-serif;font-size: var(--text-sm);color:rgba(255,255,255,0.4);margin-bottom:4px;">From <%= s.organisation.name %></div>
                <div style="font-family:'Alata',sans-serif;font-size: var(--text-2xl);color:#fff;line-height:1.25;margin-bottom:4px;">
                  <%= s.title.presence || s.theme.presence || "Untitled Verto" %>
                </div>
                <% if s.description.present? %>
                  <div style="font-family:'ABeeZee',sans-serif;font-size: var(--text-base);color:rgba(255,255,255,0.45);line-height:1.4;"><%= s.description.truncate(140) %></div>
                <% end %>
              </div>

              <% if share && url %>
                <div style="border-top:1px solid rgba(255,255,255,0.05);padding:12px 22px;display:flex;align-items:center;gap:10px;">
                  <span style="font-family:'Alata',sans-serif;font-size: var(--text-xs);letter-spacing:0.08em;color:rgba(255,255,255,0.4);text-transform:uppercase;flex-shrink:0;">Your link</span>
                  <input type="text" readonly value="<%= url %>"
                         id="alliance-share-link-<%= share.id %>"
                         onclick="this.select()"
                         style="flex:1;min-width:0;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:6px;padding:6px 10px;color:rgba(255,255,255,0.6);font-family:'ABeeZee',sans-serif;font-size: var(--text-xs);outline:none;" />
                  <button type="button"
                          onclick="navigator.clipboard.writeText(document.getElementById('alliance-share-link-<%= share.id %>').value).then(()=>{this.textContent='Copied!';setTimeout(()=>{this.textContent='Copy'},1500)})"
                          style="background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.12);border-radius:6px;padding:6px 12px;color:rgba(255,255,255,0.65);font-family:'ABeeZee',sans-serif;font-size: var(--text-xs);cursor:pointer;flex-shrink:0;">Copy</button>
                  <%= link_to "Results →", alliance_alliance_verto_path(@alliance, av),
                        style: "background:rgba(1,234,203,0.12);border:1px solid rgba(1,234,203,0.35);border-radius:6px;padding:6px 12px;color:#01EACB;font-family:'ABeeZee',sans-serif;font-size: var(--text-xs);text-decoration:none;flex-shrink:0;" %>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>

    </div>
  </div>
</div>
