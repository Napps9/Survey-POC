<%# Public player card. Same renderers as editor / preview, with
    mode: :player so it's read-only and skips edit chrome. Renders in the
    respondent's chosen content language (falls back to the Verto's primary). %>
<% locale ||= nil %>
<% default_locale ||= SupportedLocales::DEFAULT %>
<div class="split-card">
  <%= render "shared/split_left",     card: card, progress: progress, mode: :player %>
  <%= render "shared/card_component", card: card, mode: :player,
        locale: locale, default_locale: default_locale %>
</div>
