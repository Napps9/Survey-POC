<div style="display:flex;min-height:100vh;background:#1C2034;">
  <%= render "shared/sidebar", active: "members" %>

  <div style="flex:1;display:flex;flex-direction:column;min-width:0;padding:40px 48px;overflow-y:auto;">
    <div style="max-width:700px;margin:0 auto;width:100%;">

      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:32px;">
        <h1 style="font-family:'Alata',sans-serif;font-size:24px;color:#F7F7F7;margin:0;">Members</h1>
        <%= link_to "Invite member →", new_organisation_invite_path(current_organisation),
              style: "background:#00A950;color:#fff;font-family:'Alata',sans-serif;font-size:13px;letter-spacing:0.05em;padding:10px 22px;border-radius:20px;text-decoration:none;" %>
      </div>

      <% if flash[:alert] %>
        <div style="background:rgba(216,0,39,0.15);border:1px solid rgba(216,0,39,0.4);border-radius:8px;padding:12px 16px;margin-bottom:20px;color:#ff6b6b;font-size:14px;font-family:'ABeeZee',sans-serif;">
          <%= flash[:alert] %>
        </div>
      <% end %>
      <% if flash[:notice] %>
        <div style="background:rgba(0,169,80,0.15);border:1px solid rgba(0,169,80,0.4);border-radius:8px;padding:12px 16px;margin-bottom:20px;color:#00A950;font-size:14px;font-family:'ABeeZee',sans-serif;">
          <%= flash[:notice] %>
        </div>
      <% end %>

      <%# Active members %>
      <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:32px;">
        <% @memberships.each do |membership| %>
          <div style="background:#161B2E;border:1px solid rgba(255,255,255,0.08);border-radius:12px;padding:16px 20px;display:flex;align-items:center;gap:16px;">
            <div style="flex:1;">
              <div style="font-family:'Alata',sans-serif;font-size:14px;color:#F7F7F7;"><%= membership.user.name.presence || "—" %></div>
              <div style="font-family:'ABeeZee',sans-serif;font-size:12px;color:rgba(255,255,255,0.4);"><%= membership.user.email_address %></div>
            </div>
            <span style="font-family:'Alata',sans-serif;font-size:11px;letter-spacing:0.08em;text-transform:uppercase;padding:3px 10px;border-radius:20px;background:<%= membership.admin? ? 'rgba(0,169,80,0.15)' : 'rgba(255,255,255,0.06)' %>;color:<%= membership.admin? ? '#00A950' : 'rgba(255,255,255,0.4)' %>;">
              <%= membership.role %>
            </span>
            <% if membership.user != Current.user %>
              <%= button_to "Remove",
                    organisation_membership_path(current_organisation, membership),
                    method: :delete,
                    data: { turbo_confirm: "Remove #{membership.user.name} from #{current_organisation.name}?" },
                    style: "background:none;border:1px solid rgba(216,0,39,0.3);border-radius:8px;padding:5px 12px;color:rgba(216,0,39,0.7);font-family:'ABeeZee',sans-serif;font-size:12px;cursor:pointer;" %>
            <% end %>
          </div>
        <% end %>
      </div>

      <%# Pending invites %>
      <% if @pending_invites.any? %>
        <div style="margin-top:8px;">
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;">
            <span style="font-family:'Alata',sans-serif;font-size:11px;color:rgba(255,255,255,0.3);letter-spacing:0.1em;text-transform:uppercase;">Pending invites</span>
            <div style="flex:1;height:1px;background:rgba(255,255,255,0.06);"></div>
          </div>
          <div style="display:flex;flex-direction:column;gap:8px;">
            <% @pending_invites.each do |invite| %>
              <div style="background:#161B2E;border:1px solid rgba(255,255,255,0.06);border-radius:12px;padding:14px 20px;display:flex;align-items:center;gap:16px;">
                <div style="flex:1;">
                  <div style="font-family:'ABeeZee',sans-serif;font-size:13px;color:rgba(255,255,255,0.6);"><%= invite.email_address %></div>
                  <div style="font-family:'ABeeZee',sans-serif;font-size:11px;color:rgba(255,255,255,0.25);margin-top:2px;">
                    Expires <%= distance_of_time_in_words_to_now(invite.expires_at) %> from now
                    · invited by <%= invite.invited_by.name.presence || invite.invited_by.email_address %>
                  </div>
                </div>
                <span style="font-family:'Alata',sans-serif;font-size:11px;letter-spacing:0.08em;text-transform:uppercase;padding:3px 10px;border-radius:20px;background:rgba(255,255,255,0.06);color:rgba(255,255,255,0.35);">
                  <%= invite.role %>
                </span>
                <button type="button"
                        onclick="navigator.clipboard.writeText('<%= invite_url(invite.token) %>').then(()=>{this.textContent='Copied!';setTimeout(()=>{this.textContent='Copy link'},2000)})"
                        style="background:none;border:1px solid rgba(255,255,255,0.1);border-radius:7px;padding:5px 12px;color:rgba(255,255,255,0.4);font-family:'ABeeZee',sans-serif;font-size:12px;cursor:pointer;white-space:nowrap;">
                  Copy link
                </button>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

    </div>
  </div>
</div>
