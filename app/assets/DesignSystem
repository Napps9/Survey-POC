  background: white;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  box-shadow: var(--shadow-card);
  font-size: 20px;
  transition: transform 0.12s;
}
.rotate-action-btn:hover { transform: scale(1.1); }
.rotate-action-no { border-color: #D80027; color: #D80027; }
.rotate-action-yes { border-color: var(--green); color: var(--green); }
.swipe-indicator { display: flex; gap: 8px; align-items: center; }
.swipe-arrow { font-size: 18px; color: rgba(0,0,0,0.25); }

/* ── 9. PROFILE CREATION ───────────────────────── */
.profile-fields { display: flex; flex-direction: column; gap: 10px; }
.profile-field {
  display: flex; align-items: center;
