/* ============================================================
   VERTO DESIGN SYSTEM — colors_and_type.css
   Base + Semantic CSS variables for Play Verto Client 2.0
   ============================================================ */

@import url('https://fonts.googleapis.com/css2?family=ABeeZee:ital@0;1&family=Alata&display=swap');

/* ── FONTS ─────────────────────────────────────────────── */
/* Primary: ABeeZee (Google Fonts — loaded above)          */
/* Secondary: Eina 03 — commercial font; substitute Alata  */
/* Fallback stack uses rounded sans-serifs                 */

:root {

  /* ── BASE COLOR TOKENS ─────────────────────────────── */

  /* Green (Primary Action) */
  --color-green-500: #00A950;   /* rgb(0,169,80)   — primary CTA */
  --color-green-400: #01A850;   /* rgb(1,168,80)   — slight variant */
  --color-green-300: #02A750;   /* rgb(2,167,80)   — slider/active */

  /* Navy / Dark (Backgrounds & Secondary Buttons) */
  --color-navy-900: #1C2034;    /* rgb(28,32,52)   — darkest, back buttons */
  --color-navy-800: #272D4A;    /* rgb(39,45,74)   — desktop background */
  --color-navy-750: #2A2D3A;    /* rgb(42,45,58)   — mobile background */
  --color-navy-700: #333B5F;    /* rgb(51,59,95)   — panel bg */
  --color-navy-600: #4D588A;    /* rgb(77,88,138)  — lighter navy accent */
  --color-navy-500: #4F5E9C;    /* rgb(79,94,156)  — mid navy */
  --color-navy-deep: #070F41;   /* rgb(7,15,65)    — content canvas */

  /* Neutrals */
  --color-black: #000000;
  --color-grey-900: #1D1D1D;    /* near-black text */
  --color-grey-700: #434343;
  --color-grey-500: #767680;    /* muted grey */
  --color-grey-300: #C4C4C4;    /* unchecked checkbox */
  --color-grey-200: #D2D2D2;
  --color-grey-100: #E7E7E7;
  --color-grey-50:  #F0F0F0;
  --color-white: #FFFFFF;

  /* Accent / Brand */
  --color-yellow: #FFD21D;      /* rgb(255,210,29) — LEGO accent */
  --color-blue-ios: #007AFF;    /* rgb(0,122,255)  — iOS blue */
  --color-blue-600: #0052B4;    /* rgb(0,82,180)   — deeper blue */
  --color-red: #D80027;         /* rgb(216,0,39)   — flag/error */
  --color-orange: #EB6B35;      /* rgb(235,107,53) — occasional accent */
  --color-purple: #A10097;      /* rgb(161,0,151)  — flag */


  /* ── SEMANTIC COLOR TOKENS ─────────────────────────── */

  /* Backgrounds */
  --bg-page-desktop: var(--color-navy-800);       /* desktop page bg */
  --bg-page-mobile: var(--color-navy-750);        /* mobile page bg */
  --bg-card: var(--color-white);                  /* content card */
  --bg-input: rgba(0,0,0,0.04);                   /* form field bg */
  --bg-input-hover: rgba(0,0,0,0.06);
  --bg-slider-track: rgba(0,0,0,0.07);
  --bg-overlay: rgba(0,0,0,0.5);                  /* modal overlay */
  --bg-nav-ios: rgba(29,29,29,0.94);              /* iOS nav bar */
  --bg-frosted: rgba(255,255,255,0.6);            /* language picker */

  /* Text */
  --text-primary: var(--color-black);             /* main text on white */
  --text-secondary: rgba(0,0,0,0.75);             /* body copy on white */
  --text-muted: rgba(0,0,0,0.5);                  /* captions/hints */
  --text-on-dark: var(--color-white);             /* text on dark bg */
  --text-on-dark-muted: rgba(255,255,255,0.65);   /* muted on dark */
  --text-accent: var(--color-green-500);          /* green label/link */
  --text-inactive: rgba(255,255,255,0.5);         /* disabled btn text */

  /* Interactive */
  --color-cta: var(--color-green-500);            /* primary button */
  --color-cta-active: var(--color-green-300);
  --color-btn-secondary: var(--color-navy-900);   /* back button */
  --color-checkbox-checked: var(--color-green-400);
  --color-checkbox-unchecked: var(--color-grey-300);
  --color-progress-track: rgba(0,0,0,0.5);
  --color-progress-fill: var(--color-white);


  /* ── BORDER RADII ───────────────────────────────────── */
  --radius-card: 20px;
  --radius-btn: 16px;
  --radius-input: 12px;
  --radius-input-lg: 15px;
  --radius-checkbox: 5px;
  --radius-progress: 8px;
  --radius-slider-track: 20px;
  --radius-tag: 100px;


  /* ── SHADOWS ────────────────────────────────────────── */
  --shadow-card: 0px 10px 40px rgba(0,0,0,0.15);
  --shadow-card-raised: 0px 20px 40px rgba(0,0,0,0.15);
  --shadow-btn: 0px 10px 40px rgba(0,0,0,0.15);
  --shadow-tooltip: 0px 4px 40px rgba(0,0,0,0.15);
  --shadow-play: 0px 10px 30px rgba(0,0,0,0.3);


  /* ── SPACING ────────────────────────────────────────── */
  --space-1: 4px;
  --space-2: 8px;
  --space-3: 12px;
  --space-4: 16px;
  --space-5: 20px;
  --space-6: 24px;
  --space-8: 32px;
  --space-10: 40px;
  --space-12: 48px;
  --space-16: 64px;

  /* Mobile layout */
  --layout-mobile-width: 375px;
  --layout-mobile-inset: 23px;       /* horizontal card padding */
  --layout-btn-height-mobile: 54px;
  --layout-btn-height-desktop: 72px;

  /* Desktop layout */
  --layout-desktop-width: 1152px;
  --layout-card-panel-width: 444px;
  --layout-card-height: 680px;


  /* ── TYPOGRAPHY ─────────────────────────────────────── */

  /* Font families */
  --font-primary: 'ABeeZee', 'Nunito', 'Varela Round', sans-serif;
  --font-label: 'Alata', 'Eina 03', 'DM Sans', sans-serif;
                                       /* Alata = nearest free match to Eina 03 */
  --font-system: -apple-system, 'SF Pro Text', BlinkMacSystemFont, sans-serif;
  --font-mono: 'Roboto Mono', monospace;

  /* Font sizes */
  --text-xs: 12px;      /* label/tag */
  --text-sm: 13px;      /* caption */
  --text-base: 14px;    /* small body */
  --text-md: 16px;      /* body */
  --text-lg: 19px;      /* section label */
  --text-xl: 20px;      /* brand tagline */
  --text-2xl: 25px;     /* desktop body */
  --text-3xl: 26px;     /* question heading */
  --text-4xl: 30px;     /* display heading */

  /* Line heights */
  --leading-tight: 1.2;
  --leading-snug: 1.4;
  --leading-normal: 1.5;
  --leading-relaxed: 1.625;

  /* Semantic type roles */
  --type-display: 600 var(--text-4xl)/1.2 var(--font-primary);
  --type-question: 400 var(--text-3xl)/1.4 var(--font-primary);
  --type-body-lg: 400 var(--text-2xl)/1.5 var(--font-primary);
  --type-body: 400 var(--text-md)/1.625 var(--font-primary);
  --type-body-sm: 400 var(--text-base)/1.4 var(--font-primary);
  --type-caption: 400 var(--text-sm)/1.1 var(--font-primary);
  --type-label: 600 var(--text-base)/1.4 var(--font-label);
  --type-label-sm: 600 var(--text-xs)/1.4 var(--font-label);
  --type-brand: 700 var(--text-xl)/1.5 var(--font-label);
  --type-btn-desktop: 400 var(--text-2xl)/1.6 var(--font-primary);
  --type-btn-mobile: 400 var(--text-md)/1.625 var(--font-primary);
}

/* ── UTILITY CLASSES ──────────────────────────────────── */

body {
  font-family: var(--font-primary);
  color: var(--text-primary);
  background: var(--bg-page-mobile);
}

.text-display  { font: var(--type-display); }
.text-question { font: var(--type-question); }
.text-body-lg  { font: var(--type-body-lg); }
.text-body     { font: var(--type-body); }
.text-body-sm  { font: var(--type-body-sm); }
.text-caption  { font: var(--type-caption); color: var(--text-muted); }
.text-label    { font: var(--type-label); }
.text-label-sm { font: var(--type-label-sm); }
.text-brand    { font: var(--type-brand); opacity: 0.65; color: var(--color-white); }
.text-accent   { color: var(--text-accent); }
.text-muted    { color: var(--text-muted); }
.text-on-dark  { color: var(--text-on-dark); }

.card {
  background: var(--bg-card);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
}

.btn-primary {
  background: var(--color-cta);
  color: var(--color-white);
  border-radius: var(--radius-btn);
  box-shadow: var(--shadow-btn);
  border: none;
  cursor: pointer;
  font: var(--type-btn-mobile);
}

.btn-secondary {
  background: var(--color-btn-secondary);
  color: rgba(255,255,255,0.5);
  border-radius: var(--radius-btn);
  box-shadow: var(--shadow-btn);
  border: none;
  cursor: pointer;
  font: var(--type-btn-mobile);
}

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Verto — Question Types</title>
<link href="https://fonts.googleapis.com/css2?family=ABeeZee:ital@0;1&family=Alata&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --green: #00A950;
  --green-dark: #009044;
  --navy-900: #1C2034;
  --navy-800: #272D4A;
  --navy-750: #2A2D3A;
  --white: #ffffff;
  --grey-100: #E7E7E7;
  --grey-200: #D2D2D2;
  --grey-300: #C4C4C4;
  --shadow-card: 0 10px 40px rgba(0,0,0,0.15);
  --shadow-raised: 0 20px 40px rgba(0,0,0,0.15);
  --font-ui: 'ABeeZee', sans-serif;
  --font-label: 'Alata', sans-serif;
}

html { scroll-behavior: smooth; }

body {
  font-family: var(--font-ui);
  background: var(--navy-800);
  min-height: 100vh;
  padding: 48px 32px 80px;
}

/* ── PAGE HEADER ───────────────────────────────── */
.page-header {
  text-align: center;
  margin-bottom: 56px;
}
.page-tagline {
  font-family: var(--font-label);
  font-size: 13px;
  font-weight: 700;
  color: var(--green);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  margin-bottom: 10px;
}
.page-title {
  font-family: var(--font-ui);
  font-size: 36px;
  color: white;
  line-height: 1.2;
  margin-bottom: 12px;
}
.page-subtitle {
  font-family: var(--font-ui);
  font-size: 16px;
  color: rgba(255,255,255,0.5);
  max-width: 500px;
  margin: 0 auto;
  line-height: 1.6;
}

/* ── SECTION ───────────────────────────────────── */
.section {
  margin-bottom: 64px;
}
.section-header {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 24px;
}
.section-num {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: var(--green);
  color: white;
  font-family: var(--font-label);
  font-size: 14px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.section-name {
  font-family: var(--font-label);
  font-size: 18px;
  font-weight: 700;
  color: white;
}
.section-desc {
  font-family: var(--font-ui);
  font-size: 13px;
  color: rgba(255,255,255,0.4);
  margin-left: 46px;
  margin-top: -18px;
  margin-bottom: 20px;
}

/* ── DESKTOP SPLIT CARD ────────────────────────── */
.split-card {
  width: 100%;
  max-width: 900px;
  margin: 0 auto;
  display: flex;
  border-radius: 20px;
  overflow: hidden;
  box-shadow: var(--shadow-raised);
  background: white;
  min-height: 480px;
}

.split-left {
  width: 380px;
  flex-shrink: 0;
  position: relative;
  overflow: hidden;
}
.split-left-img {
  position: absolute;
  inset: 0;
  background-size: cover;
  background-position: center;
}
.split-left-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, transparent 60%, rgba(0,0,0,0.3));
}
.split-left-dark {
  background: var(--navy-750);
}

.split-right {
  flex: 1;
  padding: 40px 36px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 16px;
  position: relative;
}

/* Progress bar on left panel top */
.panel-progress {
  position: absolute;
  top: 14px;
  left: 14px;
  right: 14px;
  height: 10px;
  border-radius: 8px;
  background: rgba(0,0,0,0.35);
  overflow: hidden;
  z-index: 5;
}
.panel-progress-fill {
  height: 100%;
  border-radius: 8px;
  background: white;
}

/* Brand tagline on image */
.panel-tagline {
  position: absolute;
  top: 36px;
  left: 0; right: 0;
  text-align: center;
  font-family: var(--font-label);
  font-size: 16px;
  font-weight: 700;
  color: rgba(255,255,255,0.65);
  z-index: 5;
}

/* ── TYPE LABELS ───────────────────────────────── */
.q-eyebrow {
  font-family: var(--font-label);
  font-size: 13px;
  color: var(--green);
  letter-spacing: 0.01em;
}
.q-title {
  font-family: var(--font-ui);
  font-size: 26px;
  color: #000;
  line-height: 1.35;
}
.q-subtitle {
  font-family: var(--font-ui);
  font-size: 16px;
  color: rgba(0,0,0,0.6);
  line-height: 1.6;
}

/* ── NAV BUTTONS ───────────────────────────────── */
.btn-row {
  display: flex;
  gap: 12px;
  margin-top: auto;
  padding-top: 24px;
}
.btn-back {
  flex: 1;
  height: 56px;
  border-radius: 16px;
  background: var(--navy-900);
  border: none;
  cursor: pointer;
  font-family: var(--font-ui);
  font-size: 20px;
  color: rgba(255,255,255,0.5);
  box-shadow: var(--shadow-card);
  transition: opacity 0.15s;
}
.btn-back:hover { opacity: 0.8; }
.btn-next {
  flex: 1;
  height: 56px;
  border-radius: 16px;
  background: var(--green);
  border: none;
  cursor: pointer;
  font-family: var(--font-ui);
  font-size: 20px;
  color: white;
  box-shadow: var(--shadow-card);
  transition: background 0.15s, transform 0.1s;
}
.btn-next:hover { background: var(--green-dark); }
.btn-next:active { transform: scale(0.98); }

/* ══════════════════════════════════════════════
   COMPONENT STYLES
══════════════════════════════════════════════ */

/* ── 1. SLIDER ─────────────────────────────────── */
.slider-section {
  display: flex;
  flex-direction: column;
  gap: 0;
  margin-bottom: 8px;
}
.slider-track-wrap {
  position: relative;
  width: 100%;
  height: 80px;
}
.slider-track {
  width: 100%;
  height: 64px;
  border-radius: 20px;
  background: rgba(0,0,0,0.06);
  position: relative;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 0 24px;
}
.s-dot {
  width: 10px; height: 10px;
  border-radius: 50%;
  background: rgba(0,0,0,0.12);
  flex-shrink: 0;
  pointer-events: none;
  z-index: 1;
  transition: background 0.2s;
}
.s-dot.active { background: rgba(0,169,80,0.5); }
.slider-thumb {
  position: absolute;
  width: 52px; height: 48px;
  border-radius: 16px;
  background: var(--green);
  box-shadow: 0 4px 20px rgba(0,169,80,0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
  top: 8px;
  transition: left 0.18s cubic-bezier(.4,0,.2,1);
  pointer-events: none;
  z-index: 2;
}
.s-line { width: 2px; height: 20px; background: rgba(255,255,255,0.7); border-radius: 2px; }
.slider-tooltip {
  position: absolute;
  top: -38px;
  transform: translateX(-50%);
  background: var(--green);
  border-radius: 10px;
  padding: 6px 14px;
  box-shadow: 0 4px 20px rgba(0,169,80,0.3);
  white-space: nowrap;
  pointer-events: none;
  transition: left 0.18s cubic-bezier(.4,0,.2,1);
  z-index: 10;
}
.slider-tooltip::after {
  content: '';
  position: absolute;
  bottom: -7px; left: 50%; transform: translateX(-50%);
  border-left: 7px solid transparent;
  border-right: 7px solid transparent;
  border-top: 8px solid var(--green);
}
.slider-tooltip-text {
  font-family: var(--font-label);
  font-size: 13px;
  font-weight: 600;
  color: white;
}
.slider-labels {
  display: flex;
  justify-content: space-between;
  padding: 0 4px;
  margin-top: 6px;
}
.slider-label-text {
  font-family: var(--font-ui);
  font-size: 11px;
  color: rgba(0,0,0,0.35);
}

/* ── 2. MULTIPLE CHOICE 4 ──────────────────────── */
.choice-grid-4 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}
.choice-card {
  border-radius: 14px;
  height: 110px;
  position: relative;
  overflow: hidden;
  cursor: pointer;
  transition: transform 0.15s;
  box-shadow: 0 4px 16px rgba(0,0,0,0.1);
}
.choice-card:hover { transform: scale(1.02); }
.choice-card.selected { outline: 3px solid var(--green); outline-offset: 0; }
.choice-card-bg { position: absolute; inset: 0; background-size: cover; background-position: center; }
.choice-bg-1 { background: linear-gradient(135deg, #d4edda, #a8d5b5); }
.choice-bg-2 { background: linear-gradient(135deg, #d1ecf1, #9fd5df); }
.choice-bg-3 { background: linear-gradient(135deg, #fff3cd, #ffd88a); }
.choice-bg-4 { background: linear-gradient(135deg, #f8d7da, #f5a8b0); }
.choice-bg-5 { background: linear-gradient(135deg, #e2d9f3, #c3aee8); }
.choice-bg-6 { background: linear-gradient(135deg, #d0e8ff, #9fcfff); }
.choice-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(transparent 45%, rgba(0,0,0,0.4));
}
.choice-card.selected .choice-overlay { background: linear-gradient(transparent 45%, rgba(0,100,40,0.35)); }
.choice-tick {
  display: none;
  position: absolute; top: 8px; right: 8px;
  width: 22px; height: 22px;
  background: var(--green);
  border-radius: 50%;
  align-items: center; justify-content: center;
}
.choice-card.selected .choice-tick { display: flex; }
.choice-label {
  position: absolute; bottom: 8px; left: 0; right: 0;
  text-align: center;
  font-family: var(--font-label);
  font-size: 12px;
  font-weight: 600;
  color: white;
  text-shadow: 0 1px 4px rgba(0,0,0,0.5);
  padding: 0 8px;
}

/* ── 3. MULTIPLE CHOICE 6 ──────────────────────── */
.choice-grid-6 {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 8px;
}

/* ── 4. PICK LIST ──────────────────────────────── */
.pick-list { display: flex; flex-direction: column; border-radius: 14px; overflow: hidden; border: 1px solid rgba(0,0,0,0.07); }
.pick-item {
  display: flex; align-items: center;
  padding: 13px 16px; gap: 14px;
  border-bottom: 1px solid rgba(0,0,0,0.06);
  cursor: pointer;
  background: white;
  transition: background 0.12s;
}
.pick-item:last-child { border-bottom: none; }
.pick-item:hover { background: rgba(0,0,0,0.025); }
.pick-item.selected { background: rgba(0,169,80,0.05); }
.pick-dot {
  width: 18px; height: 18px;
  border-radius: 50%;
  border: 2px solid var(--grey-300);
  flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  transition: all 0.15s;
}
.pick-item.selected .pick-dot {
  background: var(--green);
  border-color: var(--green);
}
.pick-text {
  font-family: var(--font-ui);
  font-size: 16px;
  color: #111;
}
.pick-item.selected .pick-text {
  font-family: var(--font-label);
  font-weight: 600;
  color: var(--green);
}

/* ── 5. ACTIVITY ───────────────────────────────── */
.activity-content { display: flex; flex-direction: column; gap: 12px; }
.activity-tag {
  font-family: var(--font-label);
  font-size: 11px;
  font-weight: 700;
  color: rgba(0,0,0,0.35);
  text-transform: uppercase;
  letter-spacing: 0.1em;
}
.activity-title {
  font-family: var(--font-ui);
  font-size: 22px;
  color: #000;
  line-height: 1.4;
}
.activity-desc {
  font-family: var(--font-ui);
  font-size: 15px;
  color: rgba(0,0,0,0.55);
  line-height: 1.6;
}
.activity-check {
  display: flex; align-items: flex-start;
  gap: 14px; padding: 14px 16px;
  border-radius: 14px;
  background: rgba(0,0,0,0.04);
  cursor: pointer;
  margin-top: 4px;
  user-select: none;
}
.activity-check:hover { background: rgba(0,0,0,0.06); }
.check-box {
  width: 22px; height: 22px;
  border-radius: 5px;
  flex-shrink: 0;
  margin-top: 1px;
  display: flex; align-items: center; justify-content: center;
  transition: background 0.2s;
  background: var(--grey-300);
}
.check-box.checked { background: #01A850; }
.check-texts { display: flex; flex-direction: column; gap: 3px; }
.check-main { font-size: 14px; color: #000; line-height: 1.4; }
.check-sub { font-size: 12px; color: rgba(0,0,0,0.45); }

/* ── 6. VIDEO ──────────────────────────────────── */
.video-wrap {
  width: 100%;
  aspect-ratio: 16/9;
  border-radius: 16px;
  background: var(--navy-750);
  overflow: hidden;
  position: relative;
  cursor: pointer;
  box-shadow: 0 6px 24px rgba(0,0,0,0.18);
}
.video-thumb {
