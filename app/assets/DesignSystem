  z-index: 3;
}
.video-played-overlay.show { display: flex; }
.video-played-msg {
  font-family: var(--font-ui);
  font-size: 18px;
  color: white;
  text-align: center;
}

/* ── 7. AUDIO CAPTURE ──────────────────────────── */
.audio-ui {
  display: flex; flex-direction: column;
  align-items: center; gap: 20px;
  padding: 16px 0;
}
.audio-visualiser {
  display: flex; align-items: center; gap: 5px;
  height: 60px;
}
.audio-bar {
  width: 5px;
  border-radius: 3px;
  background: var(--green);
  opacity: 0.7;
  animation: none;
  transition: height 0.15s;
}
.audio-bar.animating {
  animation: audioPulse 0.8s ease-in-out infinite alternate;
}
@keyframes audioPulse {
  from { height: 8px; opacity: 0.4; }
  to { height: var(--h, 40px); opacity: 1; }
}
.audio-time {
  font-family: var(--font-label);
  font-size: 28px;
  font-weight: 700;
  color: #111;
  letter-spacing: 0.05em;
}
.audio-controls { display: flex; gap: 12px; align-items: center; }
.audio-btn {
  width: 64px; height: 64px;
  border-radius: 50%;
  border: none; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  box-shadow: var(--shadow-card);
  transition: transform 0.12s;
}
.audio-btn:hover { transform: scale(1.06); }
.audio-btn-record { background: var(--green); }
.audio-btn-stop { background: #D80027; }
.audio-btn-play { background: var(--navy-900); }
.audio-hint {
  font-family: var(--font-ui);
  font-size: 13px;
  color: rgba(0,0,0,0.4);
  text-align: center;
}
.audio-recorded {
  display: none;
  align-items: center; gap: 10px;
  padding: 10px 14px;
  border-radius: 12px;
  background: rgba(0,169,80,0.08);
  border: 1px solid rgba(0,169,80,0.2);
  width: 100%;
}
.audio-recorded.show { display: flex; }
.audio-wave { flex: 1; height: 32px; background: rgba(0,169,80,0.15); border-radius: 8px; position: relative; overflow: hidden; }
.audio-wave-inner { height: 100%; background: repeating-linear-gradient(90deg, transparent 0px, transparent 3px, rgba(0,169,80,0.5) 3px, rgba(0,169,80,0.5) 5px); }
.audio-rec-time { font-family: var(--font-label); font-size: 13px; font-weight: 600; color: var(--green); }

/* ── 8. ROTATE / SWIPE ─────────────────────────── */
.rotate-wrap {
  display: flex; flex-direction: column;
  align-items: center; gap: 16px;
}
.rotate-card-stack {
  position: relative;
  width: 260px; height: 180px;
  margin: 0 auto;
}
.rotate-card {
  position: absolute;
  width: 230px; height: 160px;
  border-radius: 18px;
  box-shadow: var(--shadow-card);
  background: white;
  display: flex; align-items: center; justify-content: center;
  cursor: grab;
  font-family: var(--font-ui);
  font-size: 15px;
  color: rgba(0,0,0,0.4);
  transition: transform 0.3s cubic-bezier(.4,0,.2,1);
  user-select: none;
  overflow: hidden;
}
.rotate-card:active { cursor: grabbing; }
.rotate-card-1 { transform: rotate(-4deg) translate(-10px, 10px); z-index: 1; background: #f0f4f8; }
.rotate-card-2 { transform: rotate(2deg) translate(8px, 6px); z-index: 2; background: #e8f5e9; }
.rotate-card-top { transform: rotate(0deg); z-index: 3; background: white; }
.rotate-card-img {
  width: 100%; height: 100%;
  background: url('assets/activity-image.png') center/cover;
  opacity: 0.6;
}
.rotate-hint {
  font-family: var(--font-ui);
  font-size: 13px;
  color: rgba(0,0,0,0.4);
  text-align: center;
}
.rotate-actions { display: flex; gap: 24px; margin-top: 8px; }
.rotate-action-btn {
  width: 52px; height: 52px;
