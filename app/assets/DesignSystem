<script>
/* ── SLIDER ──────────────────────────────── */
const sliderLabels = ['Very scared.', 'A bit scared.', 'I feel fine!', 'Pretty good!', 'Amazing!'];
const sliderPositions = [8, 25, 43, 61, 80]; // % from left
let sliderPos = 2;
let isDragging = false;

function setSlider(pct) {
  const pos = Math.max(0, Math.min(4, Math.round((pct / 100) * 4)));
  sliderPos = pos;
  const leftPct = sliderPositions[pos];
  document.getElementById('sliderThumb').style.left = `calc(${leftPct}% - 26px)`;
  document.getElementById('sliderTooltip').style.left = `${leftPct}%`;
  document.getElementById('sliderTooltipText').textContent = sliderLabels[pos];
  for (let i = 0; i < 5; i++) {
    document.getElementById('sdot' + i).className = 's-dot' + (i === pos ? ' active' : '');
  }
}

function startSlider(e) {
  isDragging = true;
  moveSlider(e);
  document.addEventListener('mousemove', moveSlider);
  document.addEventListener('mouseup', () => { isDragging = false; document.removeEventListener('mousemove', moveSlider); });
}
function startSliderTouch(e) {
  document.addEventListener('touchmove', moveSliderTouch, { passive: false });
  document.addEventListener('touchend', () => document.removeEventListener('touchmove', moveSliderTouch));
  moveSliderTouch(e);
}
function moveSlider(e) {
  if (!isDragging && e.type === 'mousemove') return;
  const track = document.getElementById('sliderTrack');
  const rect = track.getBoundingClientRect();
  const pct = ((e.clientX - rect.left) / rect.width) * 100;
  setSlider(pct);
}
function moveSliderTouch(e) {
  e.preventDefault();
  const track = document.getElementById('sliderTrack');
  const rect = track.getBoundingClientRect();
  const pct = ((e.touches[0].clientX - rect.left) / rect.width) * 100;
  setSlider(pct);
}

/* ── CHOICE GRID ─────────────────────────── */
function selectChoice(gridId, card) {
  document.querySelectorAll('#' + gridId + ' .choice-card').forEach(c => c.classList.remove('selected'));
  card.classList.add('selected');
}

/* ── PICK LIST ───────────────────────────── */
function selectPick(item) {
  const list = item.closest('.pick-list');
  list.querySelectorAll('.pick-item').forEach(p => {
    p.classList.remove('selected');
    p.querySelector('.pick-dot').innerHTML = '';
  });
  item.classList.add('selected');
  item.querySelector('.pick-dot').innerHTML = '<svg width="8" height="7" viewBox="0 0 10 8" fill="white"><path d="M3 7.295L.499 4.79C.22 4.511-.222 4.511-.501 4.79-.78 5.069-.78 5.513-.501 5.792L2.495 8.791c.278.279.729.279 1.008 0L10.08 1.211c.279-.279.279-.723 0-1.002-.279-.279-.722-.279-1.001 0z"/></svg>';
}

/* ── ACTIVITY ────────────────────────────── */
function toggleActivityCheck(el) {
  const box = el.querySelector('.check-box');
  const next = document.getElementById('actNextBtn');
  const checked = box.classList.toggle('checked');
  box.innerHTML = checked ? '<svg width="12" height="9" viewBox="0 0 12 9" fill="white"><path d="M3.712 7.295L1.21 4.79C.931 4.511.488 4.511.209 4.79-.07 5.069-.07 5.513.209 5.792L3.205 8.791c.278.279.729.279 1.008 0L11.791 1.211c.279-.279.279-.723 0-1.002-.279-.279-.722-.279-1.001 0z"/></svg>' : '';
  next.style.opacity = checked ? '1' : '0.5';
  next.style.pointerEvents = checked ? 'auto' : 'none';
}

/* ── VIDEO ───────────────────────────────── */
let videoPlaying = false;
function playVideo() {
  videoPlaying = !videoPlaying;
  const overlay = document.getElementById('videoPlayedOverlay');
  const circle = document.getElementById('playCircle');
  overlay.classList.toggle('show', videoPlaying);
  circle.innerHTML = videoPlaying
    ? '<svg width="14" height="18" viewBox="0 0 24 24" fill="#272D4A"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>'
    : '<svg width="20" height="24" viewBox="0 0 45 55" fill="#272D4A"><path d="M0 4.455L0 50.545C0 54.059 3.859 56.195 6.831 54.282L42.937 31.237C45.688 29.502 45.688 25.498 42.937 23.718L6.831.718C3.859-1.195 0 .941 0 4.455z"/></svg>';
}

/* ── AUDIO CAPTURE ───────────────────────── */
let audioRecording = false;
let audioTimer = null;
let audioSeconds = 0;
let hasRecording = false;

function toggleRecord() {
  if (audioRecording) {
    stopRecording();
  } else {
    startRecording();
  }
}
function startRecording() {
  audioRecording = true;
  audioSeconds = 0;
  document.getElementById('audioHint').textContent = 'Recording… tap to stop';
  document.getElementById('audioRecBtn').className = 'audio-btn audio-btn-stop';
  document.getElementById('audioRecBtn').innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="white"><rect x="6" y="6" width="12" height="12" rx="2"/></svg>';
  document.querySelectorAll('.audio-bar').forEach(b => b.classList.add('animating'));
  audioTimer = setInterval(() => {
    audioSeconds++;
    const m = Math.floor(audioSeconds / 60);
    const s = audioSeconds % 60;
    document.getElementById('audioTime').textContent = m + ':' + String(s).padStart(2, '0');
  }, 1000);
}
function stopRecording() {
  audioRecording = false;
  clearInterval(audioTimer);
  hasRecording = true;
  document.querySelectorAll('.audio-bar').forEach(b => b.classList.remove('animating'));
  document.getElementById('audioRecBtn').className = 'audio-btn audio-btn-record';
  document.getElementById('audioRecBtn').innerHTML = '<svg width="20" height="20" viewBox="0 0 16 16" fill="white"><path d="M8 1a3 3 0 0 1 3 3v4a3 3 0 0 1-6 0V4a3 3 0 0 1 3-3z"/><path d="M12.5 8a.5.5 0 0 1 .5.5A5 5 0 0 1 3 8.5.5.5 0 0 1 4 8.5a4 4 0 0 0 8 0 .5.5 0 0 1 .5-.5z"/></svg>';
  document.getElementById('audioHint').textContent = 'Recording saved';
  const m = Math.floor(audioSeconds / 60);
  const s = audioSeconds % 60;
  document.getElementById('audioRecTime').textContent = m + ':' + String(s).padStart(2, '0');
  document.getElementById('audioRecorded').classList.add('show');
  document.getElementById('audioPlayBtn').style.display = 'flex';
}
function playRecording() {
  document.getElementById('audioHint').textContent = 'Playing recording…';
  setTimeout(() => { document.getElementById('audioHint').textContent = 'Recording saved'; }, 2000);
}
function deleteRecording() {
  hasRecording = false;
  audioSeconds = 0;
  document.getElementById('audioTime').textContent = '0:00';
  document.getElementById('audioRecorded').classList.remove('show');
  document.getElementById('audioPlayBtn').style.display = 'none';
  document.getElementById('audioHint').textContent = 'Tap the microphone to start recording';
}

/* ── ROTATE / SWIPE ──────────────────────── */
let rotateCount = 0;
const rotateColors = [
  'linear-gradient(135deg,#d4edda,#a8d5b5)',
  'linear-gradient(135deg,#d1ecf1,#9fd5df)',
  'linear-gradient(135deg,#fff3cd,#ffd88a)',
  'linear-gradient(135deg,#f8d7da,#f5a8b0)',
  'linear-gradient(135deg,#e2d9f3,#c3aee8)',
];
function swipeCard(dir) {
  const top = document.getElementById('rotateTopCard');
  const x = dir === 'yes' ? 300 : -300;
  top.style.transition = 'transform 0.35s cubic-bezier(.4,0,.2,1), opacity 0.3s';
  top.style.transform = `translateX(${x}px) rotate(${dir === 'yes' ? 15 : -15}deg)`;
  top.style.opacity = '0';
  setTimeout(() => {
    rotateCount++;
    top.style.transition = 'none';
    top.style.transform = 'rotate(0deg)';
    top.style.opacity = '1';
    top.style.background = rotateColors[rotateCount % rotateColors.length];
    top.innerHTML = `<div style="width:100%;height:100%;background:${rotateColors[rotateCount % rotateColors.length]};border-radius:18px;display:flex;align-items:center;justify-content:center;color:rgba(0,0,0,0.25);font-family:var(--font-ui);font-size:13px;">Image ${rotateCount + 1}</div>`;
  }, 380);
}

/* ── PROFILE ─────────────────────────────── */
function toggleDropdown(id, field) {
  const dd = document.getElementById(id);
  const isOpen = dd.classList.contains('open');
  document.querySelectorAll('.profile-dropdown').forEach(d => d.classList.remove('open'));
  if (!isOpen) dd.classList.add('open');
}
function pickOption(labelId, dropdownId, value, item) {
  document.getElementById(labelId).textContent = value;
  document.getElementById(labelId).style.color = '#111';
  document.getElementById(labelId).style.fontFamily = 'var(--font-label)';
  document.querySelectorAll('#' + dropdownId + ' .profile-dropdown-item').forEach(i => i.classList.remove('chosen'));
  item.classList.add('chosen');
  document.getElementById(dropdownId).classList.remove('open');
  event.stopPropagation();
}
</script>

</body>
