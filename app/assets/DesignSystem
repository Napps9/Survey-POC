          <div class="progress-fill" style="width:100%"></div>
        </div>
        <div style="position:absolute;bottom:12px;left:50%;transform:translateX(-50%);">
          <img src="../../assets/lego-logo.png" alt="LEGO" style="height:40px;filter:drop-shadow(0 2px 8px rgba(0,0,0,0.3));">
        </div>
      </div>
      <div class="screen-content" style="padding-top:20px">
        <div class="screen-title">Thanks for playing!</div>
        <div class="screen-desc">What did you think of this Verto?</div>
        <div style="display:flex;gap:10px;justify-content:center;margin-top:8px;">
          <div style="width:40px;height:40px;border-radius:50%;background:rgba(0,0,0,0.05);display:flex;align-items:center;justify-content:center;font-size:20px;cursor:pointer;">😊</div>
          <div style="width:40px;height:40px;border-radius:50%;background:rgba(0,169,80,0.1);border:2px solid #00A950;display:flex;align-items:center;justify-content:center;font-size:20px;cursor:pointer;">😍</div>
          <div style="width:40px;height:40px;border-radius:50%;background:rgba(0,0,0,0.05);display:flex;align-items:center;justify-content:center;font-size:20px;cursor:pointer;">😐</div>
        </div>
      </div>
      <!-- Modal -->
      <div class="modal-overlay" id="finishModal">
        <div class="modal-card">
          <div class="modal-title">Thank you!</div>
          <div class="modal-desc">Would you like to play again?</div>
          <div class="modal-btns">
            <button class="modal-btn modal-btn-finish" onclick="goTo(1)">Finish</button>
            <button class="modal-btn modal-btn-results" onclick="document.getElementById('finishModal').style.display='none'">Show Results</button>
          </div>
        </div>
      </div>
      <div class="nav-buttons">
        <button class="btn-back" onclick="goTo(7)">Back</button>
        <button class="btn-next" onclick="document.getElementById('finishModal').style.display='flex'">Finish</button>
      </div>
    </div>

  </div><!-- end screen-wrap -->
</div><!-- end phone-frame -->

<script>
const TOTAL = 8;
let current = 1;

const sliderLabels = ['Very scared.', 'A bit scared.', 'I feel fine!', 'Pretty good!', 'Amazing!'];
let sliderPos = 2;

function goTo(n) {
  document.getElementById('screen-' + current).classList.remove('active');
  current = n;
  document.getElementById('screen-' + current).classList.add('active');
  document.getElementById('stepIndicator').textContent = n + ' / ' + TOTAL;
  document.getElementById('screenWrap').scrollTop = 0;
  // hide modal if visible
  const modal = document.getElementById('finishModal');
  if (modal) modal.style.display = '';
}

function toggleCheckbox(row) {
  const box = row.querySelector('.checkbox-box');
  if (box.classList.contains('checked')) {
    box.classList.remove('checked');
    box.classList.add('unchecked');
    box.innerHTML = '';
  } else {
    box.classList.remove('unchecked');
    box.classList.add('checked');
    box.innerHTML = '<svg width="12" height="9" viewBox="0 0 12 9" fill="white"><path d="M 3.712 7.295 L 1.21 4.79 C 0.931 4.511 0.488 4.511 0.209 4.79 C -0.07 5.069 -0.07 5.513 0.209 5.792 L 3.205 8.791 C 3.483 9.07 3.934 9.07 4.213 8.791 L 11.791 1.211 C 12.07 0.932 12.07 0.488 11.791 0.209 C 11.512 -0.07 11.069 -0.07 10.79 0.209 Z"/></svg>';
  }
}

function selectChoice(card) {
  document.querySelectorAll('#choiceGrid .choice-card').forEach(c => c.classList.remove('selected'));
  card.classList.add('selected');
}

function selectPick(item) {
  document.querySelectorAll('#pickList .pick-item').forEach(p => {
    p.classList.remove('selected');
    p.querySelector('.pick-item-dot').className = 'pick-item-dot unselected';
    p.querySelector('.pick-item-text').style.color = '#000';
  });
  item.classList.add('selected');
  item.querySelector('.pick-item-dot').className = 'pick-item-dot selected';
}

function handleSliderClick(e) {
  const track = document.getElementById('sliderTrack');
  const rect = track.getBoundingClientRect();
  const x = (e.clientX - rect.left) / rect.width;
  const pos = Math.max(0, Math.min(4, Math.round(x * 4)));
  updateSlider(pos);
}

function updateSlider(pos) {
  sliderPos = pos;
  const positions = [7, 25, 43, 61, 79]; // percentages
  const thumb = document.getElementById('sliderThumb');
  thumb.style.left = 'calc(' + positions[pos] + '% - 24.5px)';
  document.getElementById('sliderLabel').textContent = sliderLabels[pos];
  for (let i = 0; i < 5; i++) {
    const dot = document.getElementById('dot-' + i);
    dot.className = 'slider-dot' + (i === pos ? ' active' : '');
  }
}
</script>

</body>
</html>
