.profile-field-value { font-family: var(--font-label); font-size: 15px; color: #111; flex: 1; }
.profile-field-arrow { font-size: 11px; color: rgba(0,0,0,0.3); }
.profile-divider { height: 1px; background: rgba(0,0,0,0.07); margin: 4px 0; }
.profile-dropdown {
