.profile-dropdown-item:last-child { border-bottom: none; }
.profile-dropdown-item:hover { background: rgba(0,169,80,0.07); }
.profile-dropdown-item.chosen { color: var(--green); font-family: var(--font-label); font-weight: 600; }

/* ── LEFT PANEL ILLUSTRATIONS ──────────────────── */
