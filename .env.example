ANTHROPIC_API_KEY=

# ── Feature flags ────────────────────────────────────────
# NPS "reactive scale" question type (themed slider + reacting face). Off by
# default: when unset/false it's hidden from the answer-type picker and the AI
# generator won't emit it. Set to "true" to enable.
NPS_REACTIVE_ENABLED=false

# ── Email (password reset, invites) ──────────────────────
# Set these to enable outbound email. Any free SMTP provider works.
#
# Brevo  (300/day free)  — smtp-relay.brevo.com : 587  | user = login email | pass = SMTP key
# SendGrid (100/day)     — smtp.sendgrid.net    : 587  | user = "apikey"    | pass = API key
# Resend  (3,000/month)  — smtp.resend.com      : 465  | user = "resend"    | pass = API key   (SMTP_TLS=true)
# Mailtrap (sandbox)     — sandbox.smtp.mailtrap.io : 2525
# Gmail SMTP (low cap)   — smtp.gmail.com       : 587  | user = address     | pass = app password
#
# Without these, mail falls back to Rails defaults (dev logs to stdout).
#
# 🛡️  Deliverability tip: to keep reset emails out of spam, use SendGrid's
# *Domain Authentication* (Settings → Sender Authentication → Authenticate
# Your Domain) instead of *Single Sender Verification*. Domain Auth adds
# SPF + DKIM DNS records on your sending domain, which is what spam filters
# look for. Single Sender works for testing but lands in junk most of the time.
MAIL_FROM="Playverto <no-reply@example.com>"
MAIL_REPLY_TO=hello@example.com
APP_HOST=
APP_PROTOCOL=https
SMTP_ADDRESS=
SMTP_PORT=587
SMTP_DOMAIN=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTHENTICATION=plain
SMTP_STARTTLS=true
SMTP_TLS=false
