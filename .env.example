ANTHROPIC_API_KEY=

# ── Claude model selection (optional) ────────────────────
# Override which model each tier uses without a code change. DEFAULT is used for
# high-stakes generation (full survey design, PDF import); FAST (cheaper Haiku)
# for well-constrained / conversational tasks (single question, translation,
# results summary + chat). Leave unset to use the built-in defaults.
# CLAUDE_MODEL_DEFAULT=claude-sonnet-4-6
# CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001

# ── Google Sheets export (per-user OAuth) ────────────────
# Lets users export a Verto's results into a spreadsheet in their own Drive.
# In Google Cloud Console: create a project → enable the "Google Sheets API" →
# create an OAuth 2.0 Client ID (type "Web application") → under "Authorized
# redirect URIs" add the callback for each environment:
#   http://localhost:3000/google/callback   (dev)
#   https://<APP_HOST>/google/callback       (prod)
# On the OAuth consent screen (External / Testing) add yourself as a test user;
# the drive.file scope needs no Google verification while in Testing.
# When these are unset, the "Connect to Google Sheets" button is hidden.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Active Record Encryption keys — encrypt the stored Google tokens at rest.
# Generate with: bin/rails db:encryption:init  (then paste the values here).
# Required in production; dev/test fall back to built-in disposable keys.
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=

# ── Email (password reset, invites) ──────────────────────
# Set these to enable outbound email. Any free SMTP provider works.
#
# Brevo  (300/day free)  — smtp-relay.brevo.com : 587  | user = login email | pass = SMTP key
# SendGrid (100/day)     — smtp.sendgrid.net    : 587  | user = "apikey"    | pass = API key
# Resend  (3,000/month)  — smtp.resend.com      : 465  | user = "resend"    | pass = API key   (SMTP_TLS=true)
# Mailtrap (sandbox)     — sandbox.smtp.mailtrap.io : 2525
# Gmail SMTP (low cap)   — smtp.gmail.com       : 587  | user = address     | pass = app password
#
# Without these, mail falls back to Rails defaults (dev logs to stdout).
#
# 🛡️  Deliverability tip: to keep reset emails out of spam, use SendGrid's
# *Domain Authentication* (Settings → Sender Authentication → Authenticate
# Your Domain) instead of *Single Sender Verification*. Domain Auth adds
# SPF + DKIM DNS records on your sending domain, which is what spam filters
# look for. Single Sender works for testing but lands in junk most of the time.
MAIL_FROM="Playverto <no-reply@example.com>"
MAIL_REPLY_TO=hello@example.com
APP_HOST=
APP_PROTOCOL=https
SMTP_ADDRESS=
SMTP_PORT=587
SMTP_DOMAIN=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTHENTICATION=plain
SMTP_STARTTLS=true
SMTP_TLS=false
