ANTHROPIC_API_KEY=

# ── Email (password reset, invites) ──────────────────────
# Set these to enable outbound email. Any free SMTP provider works.
#
# Brevo  (300/day free)  — smtp-relay.brevo.com : 587  | user = login email | pass = SMTP key
# SendGrid (100/day)     — smtp.sendgrid.net    : 587  | user = "apikey"    | pass = API key
# Resend  (3,000/month)  — smtp.resend.com      : 465  | user = "resend"    | pass = API key   (SMTP_TLS=true)
# Mailtrap (sandbox)     — sandbox.smtp.mailtrap.io : 2525
# Gmail SMTP (low cap)   — smtp.gmail.com       : 587  | user = address     | pass = app password
#
# Without these, mail falls back to Rails defaults (dev logs to stdout).
MAIL_FROM="Playverto <no-reply@example.com>"
APP_HOST=
APP_PROTOCOL=https
SMTP_ADDRESS=
SMTP_PORT=587
SMTP_DOMAIN=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTHENTICATION=plain
SMTP_STARTTLS=true
SMTP_TLS=false
